---
import "../styles/global.css";
// 👇 移除了 Members 的匯入，只保留 News 和 Videos
import News from "../components/News.astro";
import Videos from "../components/Videos.astro";
---

<html lang="zh-TW" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <!-- 👇 網頁分頁的小圖示 -->
  <link rel="icon" type="image/png" href="/images/lab-logo.png" />
  
  <!-- 標題列文字不支援HTML標籤，直接改為小寫i -->
  <title>iCPS Lab | 智慧網宇實體系統實驗室 - 國立高雄科技大學</title>
</head>

<body class="bg-[#f8fafc] text-slate-800 font-sans antialiased selection:bg-blue-200 selection:text-blue-900 relative">

  <!-- 🔷 頂部導覽列 (Navbar) -->
  <nav class="w-full bg-white border-b border-slate-200 shadow-sm relative z-30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center justify-between py-3 md:py-4">
      
      <!-- 學校/實驗室寬版 Logo 區塊 (修復手機版破版與分散問題) -->
      <!-- 移除 w-full 與 justify-between，讓 Logo 自然靠左並排 -->
      <div class="flex items-center gap-3 sm:gap-6 lg:gap-8 min-w-0">
        
        <!-- 高科大 Logo -->
        <a href="https://www.nkust.edu.tw/" target="_blank" class="flex items-center shrink-0 transition-transform duration-300 hover:scale-105">
          <!-- 依靠高度自動縮放即可，移除多餘的 max-w 限制 -->
          <img src="/images/nkust-logo.png" alt="NKUST 國立高雄科技大學" class="h-6 sm:h-9 md:h-10 lg:h-11 w-auto object-contain" onerror="this.src='https://upload.wikimedia.org/wikipedia/zh/thumb/4/46/National_Kaohsiung_University_of_Science_and_Technology_logo.svg/800px-National_Kaohsiung_University_of_Science_and_Technology_logo.svg.png';" />
        </a>
        
        <!-- 分隔線 (縮小間距保持精緻感) -->
        <div class="h-4 sm:h-6 md:h-8 border-l-[1.5px] border-slate-300/80 shrink-0 rounded-full"></div>

        <!-- 實驗室 Logo -->
        <a href="/" class="flex items-center shrink-0 transition-transform duration-300 hover:scale-105">
          <img src="/images/sicp-logo.png" alt="iCPS Lab 智慧網宇實體系統實驗室" class="h-7 sm:h-11 md:h-12 lg:h-[3.25rem] w-auto object-contain" onerror="this.style.display='none';" />
        </a>
        
      </div>

      <!-- 右側導覽連結 -->

<div class="hidden md:flex space-x-8 text-sm font-bold text-slate-600 shrink-0 ml-4">
  
  <a href="/about" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
    <span>關於 iCPS Lab</span>
    <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">About</span>
  </a>

  <a href="/#news" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
    <span>最新消息</span>
    <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">News</span>
  </a>

  <a href="/activities" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
    <span>活動花絮</span>
    <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Events</span>
  </a>

  <a href="/#videos" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
    <span>影音專區</span>
    <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Media</span>
  </a>

  <a href="/members" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
    <span>實驗室成員</span>
    <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Members</span>
  </a>
          <a href="/faq" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>常見問題</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">FAQ</span>
        </a>

</div>

      <!-- 👇 新增的手機版漢堡選單按鈕 (只在手機版顯示) -->
      <button id="mobile-menu-btn" class="md:hidden p-2 text-slate-600 hover:text-blue-800 transition focus:outline-none" aria-label="打開選單">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <!-- 預設為三條線 -->
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>

    </div>

    <!-- 👇 新增的手機版下拉選單 (預設隱藏，位於 navbar 正下方) -->
    <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 w-full bg-white border-b border-slate-200 shadow-lg flex flex-col z-20">
      <a href="/about" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800 border-b border-slate-100">關於 iCPS Lab</a>
      <a href="/#news" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800 border-b border-slate-100">最新消息</a>
      <a href="/activities" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800 border-b border-slate-100">活動花絮</a>
      <a href="/#videos" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800 border-b border-slate-100">影音專區</a>
      <a href="/members" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">實驗室成員</a>
	  <a href="/faq" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">常見問題</a>
    </div>
  </nav>

  <!-- 🔷 封面視覺 (Hero Section) - 最終完美修復方案 -->
  <!-- 👇 【修改處】捨棄 flex-col，改回原本的滿版堆疊，高度完全由 aspect 比例決定 -->
  <header class="relative w-full bg-[#0f172a] overflow-hidden border-b-4 border-blue-700 aspect-[16/9] sm:aspect-[21/9] lg:aspect-[12/5]">
    
    <!-- 輪播圖片容器 (滿版背景) -->
    <div id="hero-slider" class="absolute inset-0 w-full h-full z-10 group/slider">
      <!-- 
        【關鍵設定】保持 object-left，確保圖片中左邊的內建文字不會被裁掉。
      -->
      <img src="/images/hero-bg-1.png" alt="實驗室背景 1" class="slider-img absolute inset-0 w-full h-full object-cover object-left lg:object-center transition-opacity duration-1000 ease-in-out opacity-100" onerror="this.src='https://images.unsplash.com/photo-1518770660439-4636190af475?q=80&w=2070&auto=format&fit=crop';" />
      <img src="/images/hero-bg-3.jpg" alt="實驗室背景 3" class="slider-img absolute inset-0 w-full h-full object-cover object-left lg:object-center bg-[#0f172a] transition-opacity duration-1000 ease-in-out opacity-0" onerror="this.src='https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?q=80&w=2070&auto=format&fit=crop';" />
      <img src="/images/hero-bg-4.png" alt="實驗室背景 4" class="slider-img absolute inset-0 w-full h-full object-cover object-left lg:object-center bg-[#0f172a] transition-opacity duration-1000 ease-in-out opacity-0" onerror="this.src='https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?q=80&w=2070&auto=format&fit=crop';" />
      <img src="/images/hero-bg-2.png" alt="實驗室背景 2" class="slider-img absolute inset-0 w-full h-full object-cover object-left lg:object-center bg-[#0f172a] transition-opacity duration-1000 ease-in-out opacity-0" onerror="this.src='https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?q=80&w=2070&auto=format&fit=crop';" />
    
      <!-- 左右切換按鈕 -->
      <button id="prev-btn" class="absolute left-2 sm:left-6 top-1/2 -translate-y-1/2 z-30 p-2 sm:p-3 bg-black/30 hover:bg-black/60 backdrop-blur-sm text-white/80 hover:text-white rounded-full transition-all cursor-pointer opacity-100 lg:opacity-0 lg:group-hover/slider:opacity-100">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5 sm:w-8 sm:h-8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
      </button>
      <button id="next-btn" class="absolute right-2 sm:right-6 top-1/2 -translate-y-1/2 z-30 p-2 sm:p-3 bg-black/30 hover:bg-black/60 backdrop-blur-sm text-white/80 hover:text-white rounded-full transition-all cursor-pointer opacity-100 lg:opacity-0 lg:group-hover/slider:opacity-100">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5 sm:w-8 sm:h-8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
      </button>
    </div>

    <!-- 漸層遮罩：避免某些背景圖太亮導致 HTML 文字看不清 -->
    <div class="absolute inset-0 z-10 bg-gradient-to-t from-[#0f172a]/80 via-[#0f172a]/20 to-transparent pointer-events-none"></div>

    <!-- 文字內容區塊 -->
    <!-- 👇 【重要】改為 absolute 浮動定位。這樣文字消失時就不會留下黑色空白區塊 -->
    <div class="absolute inset-0 z-20 w-full h-full max-w-7xl mx-auto px-6 py-6 sm:py-10 flex flex-col justify-end lg:justify-center pointer-events-none">
      
      <div id="hero-text" class="w-full text-center md:text-left transition-opacity duration-1000 ease-in-out opacity-100 pointer-events-auto">
        <div class="inline-block px-3 py-1 mb-2 sm:mb-6 border border-slate-500/50 text-slate-200 text-[10px] sm:text-xs font-bold tracking-widest uppercase rounded bg-slate-900/50 backdrop-blur-md">
          Intelligent Cyber-Physical Systems Laboratory
        </div>
        <h1 class="text-3xl sm:text-5xl lg:text-7xl font-extrabold mb-2 sm:mb-6 tracking-tight drop-shadow-lg text-white">
          <span class="italic font-['Times_New_Roman',_Times,_serif] text-[1.15em] mr-1">i</span>CPS Lab
        </h1>
        <p class="text-xs sm:text-lg lg:text-xl text-slate-100 font-light max-w-3xl leading-relaxed drop-shadow-md mx-auto md:mx-0 hidden sm:block">
          AI × Healthcare × Smart Manufacturing
        </p>
      </div>
      
    </div>
  </header>

  <!-- 🔷 網站主體區域 -->
  <main class="max-w-7xl mx-auto px-6 py-16 space-y-20 relative z-20">
    <News />
    
    <!-- 👇 團隊成員區塊 -->
    <section id="members" class="scroll-mt-24">
      
      <!-- 主標題：團隊成員 TEAM MEMBERS -->
      <div class="border-b border-slate-800 pb-3 mb-10 flex items-end gap-3">
        <div class="w-2.5 h-8 bg-[#3b5998]"></div>
        <h2 class="text-2xl font-bold text-slate-900 leading-none">團隊成員</h2>
        <span class="text-sm font-light text-[#8c9bb0] uppercase tracking-widest leading-none mb-0.5">TEAM MEMBERS</span>
      </div>

      <!-- 副標題：指導教授 Principal Investigator -->
      <div class="border-b-[3px] border-[#3b5998] pb-3 mb-6 flex items-end gap-3">
        <div class="w-1 h-6 bg-slate-300"></div>
        <h3 class="text-xl font-bold text-slate-800 leading-none">指導教授 Principal Investigator</h3>
      </div>

      <!-- 👑 指導教授資訊卡片 -->
      <div class="bg-white border border-slate-200 shadow-sm">
        
        <!-- 上半部：照片與基本資訊 -->
        <div class="p-8 flex flex-col md:flex-row gap-8 lg:gap-12">
          
          <!-- 左側：照片 -->
          <div class="w-56 shrink-0">
            <img src="/images/professor.jpg" alt="張萬榮 教授" class="w-full h-auto object-cover border border-slate-200" onerror="this.src='/images/default-avatar.png';" />
          </div>
          
          <!-- 右側：資訊 -->
          <div class="flex-1">
            
            <!-- 姓名 -->
            <div class="mb-4">
              <h4 class="text-3xl font-bold text-slate-800 tracking-wider">
                張萬榮 <span class="text-lg text-slate-500 font-normal ml-1">教授</span>
              </h4>
              <p class="text-[#8c9bb0] font-mono text-sm mt-2">Wan-Jung Chang, Ph.D.</p>
            </div>
            
            <!-- 聯絡方式 -->
            <div class="flex flex-wrap items-center gap-6 text-sm text-slate-600 mb-6">
              <span class="flex items-center gap-2">
                <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                allenchang@nkust.edu.tw
              </span>
              <span class="flex items-center gap-2">
                <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                校內分機：15672
              </span>
            </div>

            <!-- 外部連結 -->
            <div class="mb-8">
              <a href="https://ec.nkust.edu.tw/p/404-1122-98302.php?Lang=zh-tw" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm text-blue-600 hover:text-blue-800 transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                查看教授詳細資訊 (論文發表、研究計畫、產學合作等)
              </a>
            </div>

            <!-- 分隔線 -->
            <div class="w-full h-px bg-slate-100 mb-6"></div>

            <!-- 學歷與所屬組別 (雙欄) -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <!-- 學歷 -->
              <div>
                <h5 class="text-xs text-[#94a3b8] mb-3 tracking-widest uppercase font-semibold">EDUCATION 學歷</h5>
                <p class="text-sm text-slate-700 leading-relaxed">
                  國立成功大學 電機工程研究所<br />
                  電腦與網路組 博士
                </p>
              </div>
              
              <!-- 所屬組別 -->
              <div>
                <h5 class="text-xs text-[#94a3b8] mb-3 tracking-widest uppercase font-semibold">AFFILIATIONS 所屬組別</h5>
                <div class="flex flex-wrap gap-2">
                  <span class="border border-slate-200 bg-white text-slate-600 text-xs px-2.5 py-1">醫學工程組(合聘)</span>
                  <span class="border border-slate-200 bg-white text-slate-600 text-xs px-2.5 py-1">醫學工程組</span>
                  <span class="border border-slate-200 bg-white text-slate-600 text-xs px-2.5 py-1">AI資安組</span>
                  <span class="border border-slate-200 bg-white text-slate-600 text-xs px-2.5 py-1">電信組</span>
                </div>
              </div>
            </div>

          </div>
        </div>

        <!-- 下半部：研究專長 -->
        <div class="bg-[#f8fafc] border-t border-slate-100 p-8">
          <h5 class="text-xs text-[#94a3b8] mb-6 tracking-widest uppercase font-semibold">RESEARCH INTERESTS 研究專長</h5>
          
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-12 gap-y-6">
            
            <!-- 專長 1 -->
            <div class="flex items-start gap-3">
              <div class="w-1.5 h-1.5 bg-[#3b5998] mt-1.5 shrink-0"></div>
              <div>
                <div class="text-sm text-slate-700 font-medium mb-1">雲端與智慧物聯網系統</div>
                <div class="text-[13px] text-[#94a3b8] font-mono">Cloud and AIoT Systems</div>
              </div>
            </div>
            
            <!-- 專長 2 -->
            <div class="flex items-start gap-3">
              <div class="w-1.5 h-1.5 bg-[#3b5998] mt-1.5 shrink-0"></div>
              <div>
                <div class="text-sm text-slate-700 font-medium mb-1">無線感測網路與高速網路系統</div>
                <div class="text-[13px] text-[#94a3b8] font-mono">Wireless Sensor Networks & High-Speed Networks</div>
              </div>
            </div>

            <!-- 專長 3 -->
            <div class="flex items-start gap-3">
              <div class="w-1.5 h-1.5 bg-[#3b5998] mt-1.5 shrink-0"></div>
              <div>
                <div class="text-sm text-slate-700 font-medium mb-1">人工智慧穿戴式裝置聯網系統</div>
                <div class="text-[13px] text-[#94a3b8] font-mono">Wearable Devices IoT Systems</div>
              </div>
            </div>

            <!-- 專長 4 -->
            <div class="flex items-start gap-3">
              <div class="w-1.5 h-1.5 bg-[#3b5998] mt-1.5 shrink-0"></div>
              <div>
                <div class="text-sm text-slate-700 font-medium mb-1">人工智慧醫療聯網系統</div>
                <div class="text-[13px] text-[#94a3b8] font-mono">Artificial Intelligent Medical IoT (MIoT) Systems</div>
              </div>
            </div>

            <!-- 專長 5 -->
            <div class="flex items-start gap-3">
              <div class="w-1.5 h-1.5 bg-[#3b5998] mt-1.5 shrink-0"></div>
              <div>
                <div class="text-sm text-slate-700 font-medium mb-1">人工智慧製造聯網系統</div>
                <div class="text-[13px] text-[#94a3b8] font-mono">Artificial Intelligent Industrial IoT (IIoT) Systems</div>
              </div>
            </div>

            <!-- 專長 6 -->
            <div class="flex items-start gap-3">
              <div class="w-1.5 h-1.5 bg-[#3b5998] mt-1.5 shrink-0"></div>
              <div>
                <div class="text-sm text-slate-700 font-medium mb-1">擴增實境聯網系統</div>
                <div class="text-[13px] text-[#94a3b8] font-mono">Augmented Reality IoT (ARIoT) Systems</div>
              </div>
            </div>

            <!-- 專長 7 -->
            <div class="flex items-start gap-3">
              <div class="w-1.5 h-1.5 bg-[#3b5998] mt-1.5 shrink-0"></div>
              <div>
                <div class="text-sm text-slate-700 font-medium mb-1">人工智慧機器人技術</div>
                <div class="text-[13px] text-[#94a3b8] font-mono">Artificial Intelligent Robotics</div>
              </div>
            </div>

          </div>
        </div>
      </div>

      <!-- 前往完整名單的按鈕 -->
      <div class="flex justify-center mt-8">
        <a href="/members" class="inline-flex items-center justify-center px-8 py-4 bg-slate-800 hover:bg-blue-700 text-white font-medium rounded-sm transition-all duration-300 shadow-sm hover:shadow-md group/btn">
          查看所有實驗室成員
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2 transition-transform group-hover/btn:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>
    </section>

    <!-- 👇 活動花絮 (首頁簡化入口) -->
    <section id="activities" class="scroll-mt-24">
      
      <!-- 主標題：活動花絮 ACTIVITIES & ALBUMS -->
      <div class="border-b border-slate-800 pb-3 mb-10 flex items-end gap-3">
        <div class="w-2.5 h-8 bg-[#3b5998]"></div>
        <h2 class="text-2xl font-bold text-slate-900 leading-none">活動花絮</h2>
        <span class="text-sm font-light text-[#8c9bb0] uppercase tracking-widest leading-none mb-0.5">ACTIVITIES & ALBUMS</span>
      </div>

      <!-- 活動花絮單一入口橫幅 (Banner) -->
      <div class="relative w-full rounded-sm overflow-hidden shadow-sm h-[320px] sm:h-[360px] flex items-center justify-center group border border-slate-200">
        
        <!-- 背景圖片 (您可以將 src 替換為實際活動的合照) -->
        <img src="/images/activity-banner.jpg" alt="活動花絮背景" class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" onerror="this.src='https://images.unsplash.com/photo-1511632765486-a01980e01a18?q=80&w=2070&auto=format&fit=crop';" />
        
