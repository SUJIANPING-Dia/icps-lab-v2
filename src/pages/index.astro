---
import "../styles/global.css";
// 👇 移除了 Members 的匯入，只保留 News 和 Videos
import News from "../components/News.astro";
import Videos from "../components/Videos.astro";
---

<html lang="zh-TW" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <!-- 👇 網頁分頁的小圖示 -->
  <link rel="icon" type="image/png" href="/images/lab-logo.png" />
  
  <!-- 標題列文字不支援HTML標籤，直接改為小寫i -->
  <title>iCPS Lab | 智慧網宇實體系統實驗室 - 國立高雄科技大學</title>
</head>

<body class="bg-[#f8fafc] text-slate-800 font-sans antialiased selection:bg-blue-200 selection:text-blue-900 relative">

  <!-- 🔷 頂部導覽列 (Navbar) -->
  <nav class="w-full bg-white border-b border-slate-200 shadow-sm relative z-30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center justify-between py-3 md:py-4">
      
      <!-- 學校/實驗室寬版 Logo 區塊 (修復手機版破版與分散問題) -->
      <!-- 移除 w-full 與 justify-between，讓 Logo 自然靠左並排 -->
      <div class="flex items-center gap-3 sm:gap-6 lg:gap-8 min-w-0">
        
        <!-- 高科大 Logo -->
        <a href="https://www.nkust.edu.tw/" target="_blank" class="flex items-center shrink-0 transition-transform duration-300 hover:scale-105">
          <!-- 依靠高度自動縮放即可，移除多餘的 max-w 限制 -->
          <img src="/images/nkust-logo.png" alt="NKUST 國立高雄科技大學" class="h-6 sm:h-9 md:h-10 lg:h-11 w-auto object-contain" onerror="this.src='https://upload.wikimedia.org/wikipedia/zh/thumb/4/46/National_Kaohsiung_University_of_Science_and_Technology_logo.svg/800px-National_Kaohsiung_University_of_Science_and_Technology_logo.svg.png';" />
        </a>
        
        <!-- 分隔線 (縮小間距保持精緻感) -->
        <div class="h-4 sm:h-6 md:h-8 border-l-[1.5px] border-slate-300/80 shrink-0 rounded-full"></div>

        <!-- 實驗室 Logo -->
        <a href="/" class="flex items-center shrink-0 transition-transform duration-300 hover:scale-105">
          <img src="/images/sicp-logo.png" alt="iCPS Lab 智慧網宇實體系統實驗室" class="h-7 sm:h-11 md:h-12 lg:h-[3.25rem] w-auto object-contain" onerror="this.style.display='none';" />
        </a>
        
      </div>

      <!-- 右側導覽連結 -->
      <div class="hidden md:flex space-x-8 text-sm font-bold text-slate-600 shrink-0 ml-4">
        <a href="/#news" class="hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">最新消息</a>
        <a href="/#videos" class="hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">影音專區</a>
        <a href="/#members" class="hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">實驗室成員</a>
      </div>
    </div>
  </nav>

  <!-- 🔷 封面視覺 (Hero Section) - 修復下方空白與比例問題 -->
  <!-- 廢棄固定高度，改用 aspect-ratio。手機使用 4:3 或 16:9，確保圖片自然縮放不嚴重裁切 -->
  <header class="relative w-full bg-[#0f172a] overflow-hidden border-b-4 border-blue-700 aspect-[4/3] sm:aspect-[16/9] lg:aspect-[12/5]">
    
    <!-- 輪播圖片容器 (滿版背景) -->
    <div id="hero-slider" class="absolute inset-0 w-full h-full z-10 group/slider">
      <!-- object-cover 讓圖片完美填滿背景不變形 -->
      <img src="/images/hero-bg-1.png" alt="實驗室背景 1" class="slider-img absolute inset-0 w-full h-full object-cover object-center transition-opacity duration-1000 ease-in-out opacity-100" onerror="this.src='https://images.unsplash.com/photo-1518770660439-4636190af475?q=80&w=2070&auto=format&fit=crop';" />
      <img src="/images/hero-bg-2.png" alt="實驗室背景 2" class="slider-img absolute inset-0 w-full h-full object-cover object-center bg-[#0f172a] transition-opacity duration-1000 ease-in-out opacity-0" onerror="this.src='https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?q=80&w=2070&auto=format&fit=crop';" />
      
      <!-- 左右切換按鈕 -->
      <button id="prev-btn" class="absolute left-2 sm:left-6 top-1/2 -translate-y-1/2 z-30 p-2 sm:p-3 bg-black/20 hover:bg-black/50 backdrop-blur-sm text-white/70 hover:text-white rounded-full transition-all cursor-pointer opacity-100 lg:opacity-0 lg:group-hover/slider:opacity-100">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6 sm:w-8 sm:h-8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
      </button>

      <button id="next-btn" class="absolute right-2 sm:right-6 top-1/2 -translate-y-1/2 z-30 p-2 sm:p-3 bg-black/20 hover:bg-black/50 backdrop-blur-sm text-white/70 hover:text-white rounded-full transition-all cursor-pointer opacity-100 lg:opacity-0 lg:group-hover/slider:opacity-100">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6 sm:w-8 sm:h-8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
      </button>
    </div>

    <!-- 手機版加一層底部漸層，確保文字能清晰顯示 (電腦版不需要) -->
    <div class="absolute inset-0 z-10 bg-gradient-to-t from-[#0f172a]/90 via-[#0f172a]/20 to-transparent lg:hidden pointer-events-none"></div>

    <!-- 文字內容區塊 (絕對定位覆蓋於圖片上方) -->
    <div class="relative z-20 w-full h-full max-w-7xl mx-auto px-6 flex flex-col justify-end pb-8 sm:pb-12 lg:pb-0 lg:justify-center pointer-events-none">
      <!-- pointer-events-auto 讓文字和按鈕可以被選取 -->
      <div id="hero-text" class="w-full text-center md:text-left transition-opacity duration-1000 ease-in-out opacity-100 pointer-events-auto">
        <div class="inline-block px-3 py-1 mb-4 sm:mb-6 border border-slate-400 text-slate-200 text-[10px] sm:text-xs font-bold tracking-widest uppercase rounded bg-slate-900/50 backdrop-blur-md">
          Intelligent Cyber-Physical Systems Laboratory
        </div>
        <!-- 調整手機版文字大小 -->
        <h1 class="text-4xl sm:text-5xl lg:text-7xl font-extrabold mb-4 sm:mb-6 tracking-tight drop-shadow-lg text-white">
          <span class="italic font-['Times_New_Roman',_Times,_serif] text-[1.15em] mr-1">i</span>CPS Lab
        </h1>
        <p class="text-sm sm:text-lg lg:text-xl text-slate-100 font-light max-w-3xl leading-relaxed drop-shadow-md mx-auto md:mx-0">
          致力於雲端與智慧物聯網系統 (AIoT)、人工智慧醫療與製造聯網等前瞻技術之學術研究與產業應用落地。
        </p>
      </div>
    </div>
  </header>

  <!-- 🔷 網站主體區域 -->
  <main class="max-w-7xl mx-auto px-6 py-16 space-y-20 relative z-20">
    <News />
    
    <!-- 👇 團隊成員區塊 -->
    <section id="members" class="scroll-mt-24">
      
