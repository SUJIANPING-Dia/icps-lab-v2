              </div>
              
              <!-- 所屬組別 -->
              <div>
                <h5 class="text-xs text-[#94a3b8] mb-3 tracking-widest uppercase font-semibold">AFFILIATIONS 所屬組別</h5>
                <div class="flex flex-wrap gap-2">
                  <span class="border border-slate-200 bg-white text-slate-600 text-xs px-2.5 py-1">醫學工程組(合聘)</span>
                  <span class="border border-slate-200 bg-white text-slate-600 text-xs px-2.5 py-1">醫學工程組</span>
                  <span class="border border-slate-200 bg-white text-slate-600 text-xs px-2.5 py-1">AI資安組</span>
                  <span class="border border-slate-200 bg-white text-slate-600 text-xs px-2.5 py-1">電信組</span>
                </div>
              </div>
            </div>

          </div>
        </div>

        <!-- 下半部：研究專長 -->
        <div class="bg-[#f8fafc] border-t border-slate-100 p-8">
          <h5 class="text-xs text-[#94a3b8] mb-6 tracking-widest uppercase font-semibold">RESEARCH INTERESTS 研究專長</h5>
          
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-12 gap-y-6">
            
            <!-- 專長 1 -->
            <div class="flex items-start gap-3">
              <div class="w-1.5 h-1.5 bg-[#3b5998] mt-1.5 shrink-0"></div>
              <div>
                <div class="text-sm text-slate-700 font-medium mb-1">雲端與智慧物聯網系統</div>
