      <section id="videos" class="scroll-mt-24" data-reveal="up">
        <div class="mb-8 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
          <div>
            <span class="inline-flex items-center px-3 py-1 rounded-full bg-indigo-50 text-indigo-700 text-xs font-black tracking-widest uppercase border border-indigo-100">Media</span>
            <h2 class="mt-4 text-3xl sm:text-4xl font-black text-slate-950 tracking-tight">影音專區</h2>
          </div>
          <p class="text-sm text-slate-500 max-w-md sm:text-right">用影片降低研究理解門檻，讓訪客更快看懂系統功能與應用場景。</p>
        </div>
        <div class="rounded-[2rem] bg-white/85 backdrop-blur-xl border border-white shadow-[0_18px_60px_rgba(15,23,42,0.07)] p-4 sm:p-6 lg:p-8 overflow-hidden">
          <Videos />
        </div>
      </section>

    </div>
  </main>

  <!-- 🔷 頁尾 (Footer) -->
  <footer class="bg-[#0f172a] py-16 mt-12 border-t border-slate-800 relative z-20">
