        <span class="text-xs text-slate-600 mx-1">|</span>
        <!-- 👇 替換成真實會自動增加的第三方計數器 (綁定 https://icps-lab.com) -->
        <img src="https://hits.seeyoufarm.com/api/count/incr/badge.svg?url=https%3A%2F%2Ficps-lab.com&count_bg=%231E293B&title_bg=%231E293B&title=&edge_flat=true" alt="累積造訪人數" class="h-4 rounded-[3px]" />
      </div>

    </div>
  </footer>

  <!-- 👇 控制封面輪播與按鈕的 JavaScript -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const images = document.querySelectorAll('.slider-img');
      const prevBtn = document.getElementById('prev-btn');
      const nextBtn = document.getElementById('next-btn');
      const heroText = document.getElementById('hero-text'); 
      
      let currentIndex = 0;
      let slideInterval;

      if (images.length < 2) {
        if(prevBtn) prevBtn.style.display = 'none';
        if(nextBtn) nextBtn.style.display = 'none';
        return;
      }

      const showImage = (index) => {
        images[currentIndex].classList.remove('opacity-100');
        images[currentIndex].classList.add('opacity-0');

        currentIndex = index;

        images[currentIndex].classList.remove('opacity-0');
        images[currentIndex].classList.add('opacity-100');

        if (heroText) {
          if (currentIndex === 0) {
            heroText.classList.remove('opacity-0', 'pointer-events-none');
            heroText.classList.add('opacity-100');
          } else {
            heroText.classList.remove('opacity-100');
            heroText.classList.add('opacity-0', 'pointer-events-none');
          }
        }
      };

      const nextImage = () => {
        const nextIndex = (currentIndex + 1) % images.length;
        showImage(nextIndex);
      };

      const prevImage = () => {
        const prevIndex = (currentIndex - 1 + images.length) % images.length;
        showImage(prevIndex);
      };

      const startSlide = () => {
        slideInterval = setInterval(nextImage, 10000); 
      };

      const resetSlide = () => {
        clearInterval(slideInterval);
        startSlide();
      };

      if (nextBtn) {
        nextBtn.addEventListener('click', () => {
          nextImage();
          resetSlide();
        });
      }

      if (prevBtn) {
        prevBtn.addEventListener('click', () => {
          prevImage();
          resetSlide();
        });
      }

      startSlide();
    });
  </script>

</body>
</html>