  <!-- 🪟 海報燈箱 (Modal) 結構，預設隱藏 -->
  <div id="poster-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 sm:p-8 bg-slate-900/90 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300">
    <!-- 關閉按鈕 -->
    <button onclick="closePosterModal()" class="absolute top-4 right-4 sm:top-8 sm:right-8 w-12 h-12 bg-white/10 hover:bg-white/20 text-white rounded-full flex items-center justify-center backdrop-blur-md transition-colors z-10">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    
    <!-- 圖片容器 (點擊背景關閉) -->
    <div class="relative w-full max-w-5xl max-h-full flex flex-col items-center justify-center" onclick="closePosterModal()">
      <div class="relative w-full max-h-[85vh] flex justify-center" onclick="event.stopPropagation()">
        <!-- 高畫質海報圖 -->
        <img id="modal-image" src="" alt="Poster View" class="w-auto h-auto max-w-full max-h-[85vh] object-contain rounded-lg shadow-2xl scale-95 transition-transform duration-300" />
      </div>
      <h3 id="modal-title" class="text-white text-xl sm:text-2xl font-bold mt-4 tracking-wider"></h3>
    </div>
  </div>

  <script>
    // --- 🎯 Hero + Selector 切換邏輯 ---
    window.selectPoster = function(btn) {
      const thumbSrc = btn.getAttribute('data-thumb');
      const fullSrc = btn.getAttribute('data-full');
      const title = btn.getAttribute('data-title');
      const category = btn.getAttribute('data-category');
      const desc = btn.getAttribute('data-desc');

      const heroImg = document.getElementById('hero-img');
      const heroCategory = document.getElementById('hero-category');
      const heroTitle = document.getElementById('hero-title');
      const heroDesc = document.getElementById('hero-desc');
      const heroContainer = document.getElementById('hero-container');

      if (!heroImg || !heroCategory || !heroTitle || !heroDesc || !heroContainer) return;

      heroImg.style.opacity = '0.35';
      heroImg.style.transform = 'scale(1.015)';

      setTimeout(() => {
        heroImg.src = thumbSrc;
        heroCategory.innerText = category;
        heroTitle.innerText = title;
        heroDesc.innerText = desc;
        heroContainer.setAttribute('data-poster-full', fullSrc);
        heroContainer.setAttribute('data-poster-title', title);
        heroImg.style.opacity = '1';
        heroImg.style.transform = '';
      }, 160);

      document.querySelectorAll('.selector-btn').forEach(b => {
        b.classList.remove('bg-slate-950', 'text-white', 'ring-2', 'ring-blue-500', 'shadow-xl', 'shadow-slate-900/15');
        b.classList.add('bg-white', 'text-slate-900', 'border', 'border-slate-200', 'hover:bg-slate-50', 'hover:border-blue-200', 'shadow-sm', 'hover:shadow-lg');
        const meta = b.querySelector('.text-blue-200');
        const descText = b.querySelector('.text-slate-300');
        if (meta) { meta.classList.remove('text-blue-200'); meta.classList.add('text-blue-600'); }
        if (descText) { descText.classList.remove('text-slate-300'); descText.classList.add('text-slate-500'); }
      });

      btn.classList.add('bg-slate-950', 'text-white', 'ring-2', 'ring-blue-500', 'shadow-xl', 'shadow-slate-900/15');
      btn.classList.remove('bg-white', 'text-slate-900', 'border', 'border-slate-200', 'hover:bg-slate-50', 'hover:border-blue-200', 'shadow-sm', 'hover:shadow-lg');
      const activeMeta = btn.querySelector('.text-blue-600');
      const activeDesc = btn.querySelector('.text-slate-500');
      if (activeMeta) { activeMeta.classList.remove('text-blue-600'); activeMeta.classList.add('text-blue-200'); }
      if (activeDesc) { activeDesc.classList.remove('text-slate-500'); activeDesc.classList.add('text-slate-300'); }
    };


    // --- 🖼️ 海報燈箱 (Modal) 互動邏輯 ---
    window.openPosterModal = function(element) {
      const fullSrc = element.getAttribute('data-poster-full');
      const title = element.getAttribute('data-poster-title');
      
      const modal = document.getElementById('poster-modal');
      const modalImage = document.getElementById('modal-image');
      const modalTitle = document.getElementById('modal-title');
      
      if (modal && modalImage && modalTitle) {
        
        modalImage.src = fullSrc;
        // 如果載入高畫質圖片失敗，就顯示原來的縮圖
        modalImage.onerror = function() {
          this.src = element.querySelector('img').src || element.getAttribute('src');
        };
        
        modalTitle.textContent = title;
        
        // 顯示 Modal
        modal.classList.remove('opacity-0', 'pointer-events-none');
        document.body.classList.add('modal-open'); // 鎖定背景滾動
        
        // 加入圖片縮放動畫
        setTimeout(() => {
          modalImage.classList.remove('scale-95');
          modalImage.classList.add('scale-100');
        }, 10);
      }
    };

    window.closePosterModal = function() {
      const modal = document.getElementById('poster-modal');
      const modalImage = document.getElementById('modal-image');
      
      if (modal && modalImage) {
        // 隱藏 Modal
        modal.classList.add('opacity-0', 'pointer-events-none');
        document.body.classList.remove('modal-open'); // 恢復背景滾動
        
        // 還原圖片縮放狀態
        modalImage.classList.remove('scale-100');
        modalImage.classList.add('scale-95');
      }
    };

    // 監聽 ESC 鍵關閉燈箱
    document.addEventListener('keydown', function(event) {
      if (event.key === 'Escape') {
        window.closePosterModal();
      }
    });

    document.addEventListener("DOMContentLoaded", () => {
      
      // --- 0. 手機版導覽列 (漢堡選單) 邏輯 ---
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const hamburgerIcon = document.getElementById('hamburger-icon');

      if (mobileMenuBtn && mobileMenu && hamburgerIcon) {
        mobileMenuBtn.addEventListener('click', () => {
          const isHidden = mobileMenu.classList.contains('hidden');
          if (isHidden) {
            mobileMenu.classList.remove('hidden');
            hamburgerIcon.setAttribute('d', 'M6 18L18 6M6 6l12 12');
          } else {
            mobileMenu.classList.add('hidden');
            hamburgerIcon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
          }
        });

        const mobileLinks = mobileMenu.querySelectorAll('a');
        mobileLinks.forEach(link => {
          link.addEventListener('click', () => {
            mobileMenu.classList.add('hidden');
            hamburgerIcon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
          });
        });
      }

      // --- 1. 封面輪播邏輯 ---
      const images = document.querySelectorAll('.slider-img');
      const prevBtn = document.getElementById('prev-btn');
      const nextBtn = document.getElementById('next-btn');
      
      let currentIndex = 0;
      let slideInterval;

      if (images.length >= 2) {
        const showImage = (index) => {
          images[currentIndex].classList.remove('opacity-100');
          images[currentIndex].classList.add('opacity-0');

          currentIndex = index;

          images[currentIndex].classList.remove('opacity-0');
          images[currentIndex].classList.add('opacity-100');
        };

        const nextImage = () => { showImage((currentIndex + 1) % images.length); };
        const prevImage = () => { showImage((currentIndex - 1 + images.length) % images.length); };
        
        const startSlide = () => { slideInterval = setInterval(nextImage, 6000); };
        const resetSlide = () => { clearInterval(slideInterval); startSlide(); };

        if (nextBtn) { nextBtn.addEventListener('click', () => { nextImage(); resetSlide(); }); }
        if (prevBtn) { prevBtn.addEventListener('click', () => { prevImage(); resetSlide(); }); }
        startSlide();
      }

      // --- 2. 智慧訪客計數器邏輯 ---
      const initCounter = async () => {
        const counterEl = document.getElementById('visitor-count');
        if (!counterEl) return;

        const namespace = 'icpslab_site';
        const key = 'visits';
        const localCountKey = 'icps_saved_count';
        const lastVisitTimeKey = 'icps_last_visit_time';
        const TWENTY_FOUR_HOURS = 24 * 60 * 60 * 1000;

        let currentCount = localStorage.getItem(localCountKey) || '------';
        const lastVisitTime = localStorage.getItem(lastVisitTimeKey);
        const now = Date.now();
        const hasVisitedWithin24Hours = lastVisitTime && (now - parseInt(lastVisitTime, 10) < TWENTY_FOUR_HOURS);
        
        try {
          const url = `https://api.counterapi.dev/v1/${namespace}/${key}`;
          if (!hasVisitedWithin24Hours) {
            const response = await fetch(url + '/up');
            if (!response.ok) throw new Error('API 回應錯誤');
            const data = await response.json();
            currentCount = String(data.count).padStart(6, '0');
            localStorage.setItem(lastVisitTimeKey, now.toString());
            localStorage.setItem(localCountKey, currentCount);
          } else {
            try {
              const response = await fetch(url);
              if (response.ok) {
                const data = await response.json();
                currentCount = String(data.count).padStart(6, '0');
                localStorage.setItem(localCountKey, currentCount);
              }
            } catch (e) {}
          }
          counterEl.textContent = currentCount;
        } catch (error) {
          counterEl.textContent = currentCount;
        }
      };

      initCounter();

      // --- 3. 數字跳動動畫 (Counter Animation) ---
      const counters = document.querySelectorAll('.counter-anim');
      const animationDuration = 2000;

      const animateCounter = (counter) => {
        const target = parseFloat(counter.getAttribute('data-target'));
        const suffix = counter.getAttribute('data-suffix') || '';
        const decimals = parseInt(counter.getAttribute('data-decimals')) || 0;
        let startTime = null;

        const step = (currentTime) => {
          if (!startTime) startTime = currentTime;
          const progress = Math.min((currentTime - startTime) / animationDuration, 1);
          
          const easeProgress = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
          const currentNum = (easeProgress * target).toFixed(decimals);

          counter.innerText = currentNum + suffix;

          if (progress < 1) {
            window.requestAnimationFrame(step);
          } else {
            counter.innerText = target.toFixed(decimals) + suffix;
          }
        };
        
        window.requestAnimationFrame(step);
      };

      const counterObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            animateCounter(entry.target);
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.3 });

      counters.forEach(counter => {
        counterObserver.observe(counter);
      });

      // --- ✨ 4. 新增：滾動觸發動畫 (Scroll Reveal) 邏輯 ---
      const revealElements = document.querySelectorAll('[data-reveal]');
      
      const revealObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            // 當元素進入畫面，加上 .is-revealed 類別觸發 CSS 動畫
            entry.target.classList.add('is-revealed');
            // 觸發一次後就取消觀察，確保動畫只在第一次滾到時播放
            observer.unobserve(entry.target);
          }
        });
      }, {
        root: null,
        // 設定觸發邊界：元素進入視窗底部上方 10% 左右時才觸發，看起來比較自然
        rootMargin: '0px 0px -10% 0px', 
        threshold: 0.1
      });

      revealElements.forEach(el => revealObserver.observe(el));

    });
  </script>

