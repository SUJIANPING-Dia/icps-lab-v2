---
import "../styles/global.css";

// ==========================================
// 🔹 最新消息資料區 (新增公告只需在這裡加入)
// ==========================================
const newsData = [
  {
    date: "2026.03.01",
    tag: "系統公告",
    tagTheme: "text-blue-800 bg-blue-50 border-blue-200",
    title: "實驗室全新官方網站正式上線，提供最新研究成果與成員資訊。",
    img: "/images/news-placeholder.jpg",
    imgAlt: "實驗室大合照 1477x1108",
    content: `
      <p>為了提供更豐富的學術交流與研究資訊展示，智慧網宇實體系統實驗室 (ICPS Lab) 全新官方網站已於今日正式上線。新版網站不僅優化了整體視覺設計，更加入了響應式介面，讓使用者無論在桌機或手機上都能獲得最佳的瀏覽體驗。</p>
      <p>本實驗室致力於雲端與智慧物聯網系統 (AIoT)、人工智慧醫療與製造聯網等前瞻技術之學術研究。透過此網站，我們將不定期更新以下資訊：</p>
      <ul class="list-disc list-inside space-y-1 pl-2 text-slate-800 font-medium mt-2 mb-2">
        <li>國內外頂尖期刊與會議之研究論文發表 (Publications)</li>
        <li>產學合作計畫與科技部計畫執行進度 (Projects)</li>
        <li>實驗室成員的競賽獲獎與卓越表現 (Honors & Awards)</li>
      </ul>
      <p>歡迎對本實驗室研究領域有興趣的同學、學者與業界先進，隨時關注我們的最新動態。若有任何產學合作提案或招生相關問題，也歡迎透過網站下方的聯絡資訊與張萬榮教授聯繫。</p>
    `
  },
  {
    date: "2026.02.15",
    tag: "招生資訊",
    tagTheme: "text-amber-800 bg-amber-50 border-amber-200",
    title: "【115學年度】熱烈招收新進碩士生與專題生，歡迎加入 ICPS Lab 研究團隊！",
    img: "",
    imgAlt: "",
    content: `
      <p class="text-base font-bold text-slate-900 mb-4">歡迎具備電機、資工、醫工或相關科系背景，且對軟硬體整合充滿熱忱的同學加入我們！</p>
      <div class="mb-4">
        <h4 class="font-bold text-blue-800 mb-2 border-l-2 border-blue-500 pl-2">🔬 實驗室重點研究方向：</h4>
        <p>在本實驗室，你將有機會參與大型產學合作計畫，並將演算法實際落地於產業場域。我們目前的研究涵蓋：智慧物聯網 (AIoT) 與邊緣運算、醫療影像分析與穿戴式生理訊號辨識、以及智慧製造與擴增實境 (AR) 協作系統。</p>
      </div>
      <div class="mb-4">
        <h4 class="font-bold text-blue-800 mb-2 border-l-2 border-blue-500 pl-2">💡 我們能提供給你：</h4>
        <ul class="list-disc list-inside space-y-1 pl-2 text-slate-700">
          <li>依參與計畫表現，提供<span class="font-bold text-amber-700">優渥的每月計畫津貼</span>。</li>
          <li>豐富的硬體資源：多台高階 GPU 伺服器、AR/VR 設備、多元感測器與開發板。</li>
          <li>扎實的實作訓練與產學接軌經驗，大幅提升畢業後的就業競爭力。</li>
          <li>融洽的實驗室氛圍與不定期聚餐活動。</li>
        </ul>
      </div>
      <div class="bg-blue-50 p-4 rounded border border-blue-100">
        <h4 class="font-bold text-slate-900 mb-2">📩 面談報名方式：</h4>
        <p>意者請將您的 <strong class="text-blue-700">1. 個人簡歷</strong>、<strong class="text-blue-700">2. 歷年成績單</strong> 與 <strong class="text-blue-700">3. 專題報告或相關作品(若有)</strong> 寄至張教授信箱： <a href="mailto:allenchang@nkust.edu.tw" class="text-blue-600 hover:underline">allenchang@nkust.edu.tw</a></p>
        <p class="text-xs text-slate-500 mt-2">※ 信件主旨請註明：「[加入實驗室] 姓名 - 欲報考碩士班/專題生」，我們收到後將盡快與您安排實驗室參觀與面談時間！</p>
      </div>
    `
  },
  {
    date: "2026.01.20",
    tag: "榮譽榜單",
    tagTheme: "text-emerald-800 bg-emerald-50 border-emerald-200",
    title: "恭賀！本實驗室團隊榮獲「2025 全國智慧聯網創新應用競賽」特優。",
    img: "",
    imgAlt: "",
    content: "<p>恭喜實驗室碩士班同學開發之「智慧醫療輔助系統」榮獲全國特優，展現卓越研發實力！</p>"
  },
  {
    date: "2025.12.10",
    tag: "學術發表",
    tagTheme: "text-purple-800 bg-purple-50 border-purple-200",
    title: "張萬榮教授與團隊最新 AIoT 研究論文獲 IEEE IoT Journal 接受刊登。",
    img: "",
    imgAlt: "",
    content: "<p>本期論文針對邊緣運算於醫療影像辨識之延遲問題提出創新演算法，獲得國際期刊高度肯定。</p>"
  },
  {
    date: "2025.11.05",
    tag: "活動紀錄",
    tagTheme: "text-slate-800 bg-slate-100 border-slate-300",
    title: "舉辦 2025 智慧醫療與網宇實體系統產學交流研討會圓滿落幕。",
    img: "",
    imgAlt: "",
    content: "<p>感謝產官學界先進熱情參與，共同探討智慧醫院轉型與 AIoT 落地應用之挑戰與機遇。</p>"
  },
  {
    date: "2025.09.28",
    tag: "產學合作",
    tagTheme: "text-rose-800 bg-rose-50 border-rose-200",
    title: "本實驗室與知名科技大廠簽署三年期「智慧工廠邊緣 AI 協作計畫」。",
    img: "",
    imgAlt: "",
    content: "<p>將著重於利用 AR 技術結合邊緣運算，打造次世代產線維修輔助系統。</p>"
  }
];

// ==========================================
// 🔹 實驗室成員資料區 (新增成員只需在這裡加入)
// ==========================================
const assistants = [
  { name: "助理 A", desc: "計畫管理", img: "/images/member-placeholder.png" },
  { name: "助理 B", desc: "系統開發", img: "/images/member-placeholder.png" },
  { name: "助理 C", desc: "行政庶務", img: "/images/member-placeholder.png" },
  { name: "助理 D", desc: "軟體工程", img: "/images/member-placeholder.png" }
];

const phds = [
  { name: "博士生 A", desc: "人工智慧醫療聯網、深度學習影像辨識", img: "/images/member-placeholder.png" },
  { name: "博士生 B", desc: "智慧工廠架構、邊緣運算最佳化", img: "/images/member-placeholder.png" }
];

const masters = [
  { name: "碩士生 01", desc: "智慧工廠邊緣運算系統", img: "/images/member-placeholder.png" },
  { name: "碩士生 02", desc: "擴增實境與無人機協作", img: "/images/member-placeholder.png" },
  { name: "碩士生 03", desc: "穿戴式心電圖異常偵測", img: "/images/member-placeholder.png" },
  { name: "碩士生 04", desc: "產線瑕疵自動光學檢測", img: "/images/member-placeholder.png" },
  { name: "碩士生 05", desc: "低功耗藍牙室內定位", img: "/images/member-placeholder.png" },
  { name: "碩士生 06", desc: "5G 專網與機器人通訊", img: "/images/member-placeholder.png" },
  { name: "碩士生 07", desc: "聯邦學習於醫療資料隱私", img: "/images/member-placeholder.png" },
  { name: "碩士生 08", desc: "邊緣裝置上之輕量化 AI", img: "/images/member-placeholder.png" },
  { name: "碩士生 09", desc: "混合實境手術導航系統", img: "/images/member-placeholder.png" },
  { name: "碩士生 10", desc: "無人自走車避障演算法", img: "/images/member-placeholder.png" }
];

const undergrads = [
  { name: "專題生 01", desc: "穿戴式裝置訊號擷取" },
  { name: "專題生 02", desc: "室內定位系統演算法實作" },
  { name: "專題生 03", desc: "工廠機台數據爬蟲系統" },
  { name: "專題生 04", desc: "物聯網溫濕度感測介面設計" },
  { name: "專題生 05", desc: "醫療影像初步標註與清洗" },
  { name: "專題生 06", desc: "AR 眼鏡基礎互動模組" },
  { name: "專題生 07", desc: "邊緣端 YOLO 模型壓縮測試" },
  { name: "專題生 08", desc: "藍牙防丟器之韌體開發" },
  { name: "專題生 09", desc: "跌倒偵測演算法效能評估" },
  { name: "專題生 10", desc: "智慧病房儀表板前端切版" },
  { name: "專題生 11", desc: "無人機影像回傳延遲測試" },
  { name: "專題生 12", desc: "ROS 機器人作業系統通訊整合" }
