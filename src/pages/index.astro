                <div class="text-sm text-slate-700 font-medium mb-1">人工智慧穿戴式裝置聯網系統</div>
                <div class="text-[13px] text-[#94a3b8] font-mono">Wearable Devices IoT Systems</div>
              </div>
            </div>

            <!-- 專長 4 -->
            <div class="flex items-start gap-3">
              <div class="w-1.5 h-1.5 bg-[#3b5998] mt-1.5 shrink-0"></div>
              <div>
                <div class="text-sm text-slate-700 font-medium mb-1">人工智慧醫療聯網系統</div>
                <div class="text-[13px] text-[#94a3b8] font-mono">Artificial Intelligent Medical IoT (MIoT) Systems</div>
              </div>
            </div>

            <!-- 專長 5 -->
            <div class="flex items-start gap-3">
              <div class="w-1.5 h-1.5 bg-[#3b5998] mt-1.5 shrink-0"></div>
              <div>
                <div class="text-sm text-slate-700 font-medium mb-1">人工智慧製造聯網系統</div>
                <div class="text-[13px] text-[#94a3b8] font-mono">Artificial Intelligent Industrial IoT (IIoT) Systems</div>
              </div>
            </div>

            <!-- 專長 6 -->
            <div class="flex items-start gap-3">
              <div class="w-1.5 h-1.5 bg-[#3b5998] mt-1.5 shrink-0"></div>
              <div>
                <div class="text-sm text-slate-700 font-medium mb-1">擴增實境聯網系統</div>
