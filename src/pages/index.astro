  <!-- 🔷 展開式手風琴與分頁 控制腳本 -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // 手風琴展開功能
      const toggleButtons = document.querySelectorAll('.news-toggle-btn');
      toggleButtons.forEach(button => {
        button.addEventListener('click', function() {
          const content = this.nextElementSibling;
          const icon = this.querySelector('.toggle-icon');
          const isExpanded = content.getAttribute('data-expanded') === 'true';

          if (!isExpanded) {
            content.style.gridTemplateRows = '1fr';
            content.setAttribute('data-expanded', 'true');
            if (icon) icon.style.transform = 'rotate(180deg)';
          } else {
            content.style.gridTemplateRows = '0fr';
            content.setAttribute('data-expanded', 'false');
            if (icon) icon.style.transform = 'rotate(0deg)';
          }
        });
      });

      // 分頁功能 (一頁 5 筆)
      const itemsPerPage = 5;
      let currentPage = 1;
      const newsItems = Array.from(document.querySelectorAll('.news-item'));
      const paginationContainer = document.getElementById('pagination-controls');

      function renderPagination() {
        const totalPages = Math.ceil(newsItems.length / itemsPerPage);
        if (totalPages <= 1) {
          paginationContainer.innerHTML = '';
          return;
        }

        let html = '';
        const prevDisabled = currentPage === 1 ? 'opacity-30 cursor-not-allowed' : 'hover:bg-slate-100 hover:text-slate-800';
        html += `<button onclick="window.changePage(${currentPage - 1})" class="px-3 py-1.5 text-sm font-medium rounded border border-slate-300 text-slate-600 transition ${prevDisabled}" ${currentPage === 1 ? 'disabled' : ''}>上一頁</button>`;

        for (let i = 1; i <= totalPages; i++) {
          const activeClass = i === currentPage ? 'bg-blue-700 text-white border-blue-700 shadow-sm' : 'bg-white text-slate-600 border-slate-300 hover:bg-slate-50';
          html += `<button onclick="window.changePage(${i})" class="w-8 h-8 flex items-center justify-center text-sm font-bold rounded border transition ${activeClass}">${i}</button>`;
        }

        const nextDisabled = currentPage === totalPages ? 'opacity-30 cursor-not-allowed' : 'hover:bg-slate-100 hover:text-slate-800';
        html += `<button onclick="window.changePage(${currentPage + 1})" class="px-3 py-1.5 text-sm font-medium rounded border border-slate-300 text-slate-600 transition ${nextDisabled}" ${currentPage === totalPages ? 'disabled' : ''}>下一頁</button>`;

        paginationContainer.innerHTML = html;
      }

      // 加入 scrollToNews 參數，預設為 true。如果為 false 就不執行視角滑動
      window.changePage = function(page, scrollToNews = true) {
        const totalPages = Math.ceil(newsItems.length / itemsPerPage);
        if (page < 1 || page > totalPages) return;
        
        currentPage = page;
        const startIndex = (currentPage - 1) * itemsPerPage;
        const endIndex = startIndex + itemsPerPage;

        newsItems.forEach((item, index) => {
          const content = item.querySelector('[data-expanded]');
          const icon = item.querySelector('.toggle-icon');
          if(content && content.getAttribute('data-expanded') === 'true') {
            content.style.gridTemplateRows = '0fr';
            content.setAttribute('data-expanded', 'false');
            if (icon) icon.style.transform = 'rotate(0deg)';
          }

          if (index >= startIndex && index < endIndex) {
            item.style.display = 'block';
          } else {
            item.style.display = 'none';
          }
        });

        renderPagination();

        // 只有在 scrollToNews 為 true 時 (代表使用者手動點擊)，才滑動螢幕
        if (scrollToNews) {
          const newsSection = document.getElementById('news');
          const elementPosition = newsSection.getBoundingClientRect().top;
          const offsetPosition = elementPosition + window.pageYOffset;
          window.scrollTo({ top: offsetPosition, behavior: 'smooth' });
        }
      };

      // 網頁初始載入：顯示第一頁，傳入 false 避免觸發自動滑動
      window.changePage(1, false);
    });
  </script>

