<html lang="zh-TW" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <!-- 👇 網頁分頁的小圖示 -->
  <link rel="icon" type="image/png" href="/images/lab-logo.png" />
  
  <!-- 標題列文字不支援HTML標籤，直接改為小寫i -->
  <title>iCPS Lab | 智慧網宇實體系統實驗室 - 國立高雄科技大學</title>

  <!-- ✨ 新增：滾動觸發動畫、隱藏卷軸等共用 CSS -->
  <style is:global>
    /* 初始隱藏狀態設定 */
    [data-reveal] {
      opacity: 0;
      /* 使用貝茲曲線讓動畫更有彈性與質感 */
      transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    
    /* 各種方向的初始位移設定 */
    [data-reveal="up"] { transform: translateY(40px); }
    [data-reveal="down"] { transform: translateY(-40px); }
    [data-reveal="left"] { transform: translateX(-40px); }
    [data-reveal="right"] { transform: translateX(40px); }
    [data-reveal="zoom"] { transform: scale(0.95); }

    /* 當 JS 加上 .is-revealed 類別時，回歸原本狀態 */
    [data-reveal].is-revealed {
      opacity: 1;
      transform: translate(0) scale(1);
    }

    /* 鎖定背景滾動 */
    body.modal-open {
      overflow: hidden;
    }

    /* 隱藏水平滾動條但保留功能 (針對行動版選擇器) */
    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }
    .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }

    /* 🌟 全新新增：右側選單的垂直自訂精緻滾動條 (電腦版用) */
    .custom-scrollbar::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
      background: #f1f5f9; /* Tailwind slate-100 */
      border-radius: 8px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: #cbd5e1; /* Tailwind slate-300 */
      border-radius: 8px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
      background: #94a3b8; /* Tailwind slate-400 */
    }
  </style>
</head>

