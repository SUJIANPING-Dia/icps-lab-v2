      <News />
    </div>
    
    <!-- 👇 團隊成員區塊 (專業櫥窗版) -->
    <section id="members" class="scroll-mt-24">
      
      <!-- 區塊標題 -->
      <div class="mb-10 flex flex-col items-start" data-reveal="up">
        <div class="inline-flex items-center gap-3 mb-3">
          <div class="w-8 h-1 bg-blue-600 rounded-full opacity-80"></div>
