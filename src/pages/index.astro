---
import "../styles/global.css";
// 👇 移除了 Members 的匯入，只保留 News 和 Videos
import News from "../components/News.astro";
import Videos from "../components/Videos.astro";
// 🌟 讀取成就資料，用於自動計算首頁統計數據
import achievements from "../data/achievements.json";

// --- 📊 數據自動統計邏輯 (基於 achievements.json) ---

// 1. 國際期刊數量
const journalGroup = achievements.find(a => a.category && a.category.includes("國際期刊"));
const journalCount = journalGroup ? journalGroup.yearlyData.reduce((sum, year) => sum + year.items.length, 0) : 0;

// 2. 國際研討會數量
const confGroup = achievements.find(a => a.category && a.category.includes("國際研討會論文"));
const confCount = confGroup ? confGroup.yearlyData.reduce((sum, year) => sum + year.items.length, 0) : 0;

// 3. 合作廠商數量 (從計畫描述中提取不重複的公司/醫院/機構名稱)
const projectGroup = achievements.find(a => a.type === "project");
const partners = new Set();
projectGroup?.yearlyData.forEach(year => {
  year.items.forEach(item => {
    // 匹配包含「公司」、「企業」、「醫院」、「中心」、「學會」、「局」等關鍵字
    const match = item.project?.match(/([^,，、\s『「]+(?:公司|企業|醫院|中心|學會|局))/);
    if (match) partners.add(match[1].trim());
  });
});
const partnerCount = partners.size || 40; 

// 4. 計畫總金額彙整
let totalAmountValue = 0;
projectGroup?.yearlyData.forEach(year => {
  year.items.forEach(item => {
    // 將 "1,200,000元" 轉換為數字
    const num = parseInt(item.amount?.replace(/[^0-9]/g, '') || "0");
    totalAmountValue += num;
  });
});

// 格式化顯示 (拆分為純數字與後綴，方便前端動畫使用)
const isBillion = totalAmountValue > 100000000;
// 修改為保留兩位小數
const amountNum = isBillion ? (totalAmountValue / 100000000).toFixed(2) : Math.floor(totalAmountValue / 10000);
const amountSuffix = isBillion ? " 億+" : " 萬+";
// 讓前端動畫知道要跳到小數點後兩位
const amountDecimals = isBillion ? 2 : 0; 

// 5. 國內外競賽得獎數量
const awardGroup = achievements.find(a => a.category && (a.category.includes("競賽") || a.category.includes("得獎") || a.category.includes("榮譽")));
const awardCount = awardGroup ? awardGroup.yearlyData.reduce((sum, year) => sum + year.items.length, 0) : 0;

// 6. 專利數量 (新增)
const patentGroup = achievements.find(a => a.category && (a.category.includes("專利") || a.category.includes("Patent")));
const patentCount = patentGroup ? patentGroup.yearlyData.reduce((sum, year) => sum + year.items.length, 0) : 0;

// 🖼️ 7. 實驗室海報作品清單 (擴充為 10 個作品測試捲軸佈局)
const posters = [
  { id: 1, title: "PigView", category: "Smart Farming", desc: "AI 豬隻體重估測系統", thumb: "/images/pigview-full.png", full: "/images/pigview-full.png" },
  { id: 2, title: "iEar", category: "Healthcare AI", desc: "AI 智慧中耳炎診斷系統", thumb: "/images/iear-full.png", full: "/images/iear-full.png" },
  { id: 3, title: "iNoodle", category: "Smart Manufacturing", desc: "泡麵調味包 AI 辨識系統", thumb: "/images/inoodle-full.png", full: "/images/inoodle-full.png" },
  { id: 4, title: "ToFPose", category: "Healthcare AI", desc: "具隱私保護之飛時測距骨架估測", thumb: "/images/tofpose-full.png", full: "/images/tofpose-full.png" },
  { id: 5, title: "GaitMirror", category: "Healthcare AI", desc: "AI 步態偵測系統", thumb: "/images/gaitmirror-full.png", full: "/images/gaitmirror-full.png" }
  // 👇 模擬未來新增的作品
  
];
