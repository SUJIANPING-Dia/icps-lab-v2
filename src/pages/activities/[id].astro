import "../../styles/global.css";

// 🔷 第一步：動態生成所有相簿頁面的路徑
export async function getStaticPaths() {
  const cloudName = import.meta.env.CLOUDINARY_CLOUD_NAME;
  const apiKey = import.meta.env.CLOUDINARY_API_KEY;
  const apiSecret = import.meta.env.CLOUDINARY_API_SECRET;

  try {
    const response = await fetch(`https://api.cloudinary.com/v1_1/${cloudName}/folders/events`, {
      headers: {
        'Authorization': `Basic ${btoa(apiKey + ':' + apiSecret)}`
      }
    });
    
    const result = await response.json();
    
    if (result.folders && result.folders.length > 0) {
      return result.folders.map(folder => ({
        params: { id: folder.name }
      }));
    }
    
    return [];
  } catch (error) {
    console.error("生成相簿路徑失敗:", error);
    return [];
  }
}

// 🔷 第二步：根據目前的 ID 抓取該相簿內的所有照片
const { id } = Astro.params; 
let photos = [];

try {
  const cloudName = import.meta.env.CLOUDINARY_CLOUD_NAME;
  const apiKey = import.meta.env.CLOUDINARY_API_KEY;
  const apiSecret = import.meta.env.CLOUDINARY_API_SECRET;

  const response = await fetch(`https://api.cloudinary.com/v1_1/${cloudName}/resources/search`, {
    method: 'POST',
    headers: {
      'Authorization': `Basic ${btoa(apiKey + ':' + apiSecret)}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      expression: `folder="events/${id}"`, 
      sort_by: [{ created_at: 'desc' }],
      max_results: 500
    })
  });

  const result = await response.json();
  if (result.resources) {
    // 這裡我們產生兩種 URL：一個是列表用的縮圖 (thumb)，一個是放大用的原圖 (full)
    photos = result.resources.map(img => ({
      thumb: img.secure_url.replace('/upload/', '/upload/f_auto,q_auto,w_800/'),
      full: img.secure_url.replace('/upload/', '/upload/f_auto,q_auto/')
    }));
  }
} catch (error) {
  console.error("讀取相簿照片失敗:", error);
}
