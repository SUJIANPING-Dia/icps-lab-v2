  <!-- 🔷 燈箱互動邏輯、計數器與手機導覽列 -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      
      // --- 0. 手機版導覽列 (漢堡選單) 邏輯 (新增) ---
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const hamburgerIcon = document.getElementById('hamburger-icon');

      if (mobileMenuBtn && mobileMenu && hamburgerIcon) {
        mobileMenuBtn.addEventListener('click', () => {
          const isHidden = mobileMenu.classList.contains('hidden');
          if (isHidden) {
            mobileMenu.classList.remove('hidden');
            hamburgerIcon.setAttribute('d', 'M6 18L18 6M6 6l12 12');
          } else {
            mobileMenu.classList.add('hidden');
            hamburgerIcon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
          }
        });

        const mobileLinks = mobileMenu.querySelectorAll('a');
        mobileLinks.forEach(link => {
          link.addEventListener('click', () => {
            mobileMenu.classList.add('hidden');
            hamburgerIcon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
          });
        });
      }

      // --- 1. 燈箱放大邏輯 (保留原樣) ---
      const overlay = document.getElementById('lightbox-overlay');
      const lightboxImg = document.getElementById('lightbox-image');
      const galleryImgs = document.querySelectorAll('.gallery-img');

      if (overlay && lightboxImg) {
        galleryImgs.forEach(img => {
          img.addEventListener('click', () => {
            const fullUrl = img.getAttribute('data-full');
            if (fullUrl) {
              lightboxImg.src = fullUrl;
              overlay.style.display = 'flex';
              setTimeout(() => overlay.classList.add('active'), 10);
              document.body.classList.add('no-scroll');
            }
          });
        });

        overlay.addEventListener('click', () => {
          overlay.classList.remove('active');
          setTimeout(() => {
            overlay.style.display = 'none';
            lightboxImg.src = '';
          }, 300);
          document.body.classList.remove('no-scroll');
        });
      }

      // --- 2. 訪客計數器邏輯 (保留原樣) ---
      const initCounter = async () => {
        const counterEl = document.getElementById('visitor-count');
        if (!counterEl) return;
        const url = `https://api.counterapi.dev/v1/icpslab_site/visits`;
        try {
          const response = await fetch(url + '/up');
          const data = await response.json();
          counterEl.textContent = String(data.count).padStart(6, '0');
        } catch (e) {
          counterEl.textContent = '000000';
        }
      };
      initCounter();
    });
  </script>

