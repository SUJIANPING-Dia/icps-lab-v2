import React, { useState, useEffect } from 'react';

export default function App() {
  const [images, setImages] = useState([]);
  const [loading, setLoading] = useState(true);
  const [visitorCount, setVisitorCount] = useState('載入中...');

  // ==========================================
  // 🔹 抓取照片資料 (加上排序邏輯)
  // ==========================================
  useEffect(() => {
    const fetchImages = async () => {
      try {
        // 實際使用時，這裡是您的 API 呼叫：
        // const res = await fetch('https://icps-lab.com/api/cloudinary');
        // let data = await res.json();
        
        // 示範資料 (模擬 API 回傳格式)
        let mockData = [
          { secure_url: 'https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=800&q=80', created_at: '2026-04-01T10:00:00Z', id: 1 },
          { secure_url: 'https://images.unsplash.com/photo-1511556532299-8f662fc26c06?w=800&q=80', created_at: '2026-04-01T09:00:00Z', id: 2 },
          { secure_url: 'https://images.unsplash.com/photo-1492684223066-81342ee5ff30?w=800&q=80', created_at: '2026-04-01T11:00:00Z', id: 3 },
          { secure_url: 'https://images.unsplash.com/photo-1501281668745-f7f57925c3b4?w=800&q=80', created_at: '2026-03-31T15:00:00Z', id: 4 },
          { secure_url: 'https://images.unsplash.com/photo-1505236858219-8359eb29e329?w=800&q=80', created_at: '2026-03-31T16:00:00Z', id: 5 },
          { secure_url: 'https://images.unsplash.com/photo-1511795409834-ef04bbd61622?w=800&q=80', created_at: '2026-04-01T08:00:00Z', id: 6 },
          { secure_url: 'https://images.unsplash.com/photo-1551818255-e6e10975bc17?w=800&q=80', created_at: '2026-03-30T10:00:00Z', id: 7 },
          { secure_url: 'https://images.unsplash.com/photo-1475721028070-9759c86fcb80?w=800&q=80', created_at: '2026-03-30T11:00:00Z', id: 8 }
        ];

        // 依據上傳時間排序 (由新到舊)
        const sortedData = mockData.sort((a, b) => new Date(b.created_at) - new Date(a.created_at));
        
        setImages(sortedData);
      } catch (error) {
        console.error("Failed to fetch", error);
      } finally {
        setLoading(false);
      }
    };

    fetchImages();
  }, []);

  // ==========================================
  // 🔹 智慧訪客計數器邏輯 (從 Vanilla JS 轉換成 React useEffect)
  // ==========================================
  useEffect(() => {
    const initCounter = async () => {
      const namespace = 'icpslab_site';
      const key = 'visits';
      const localCountKey = 'icps_saved_count';
      const lastVisitTimeKey = 'icps_last_visit_time';
      const TWENTY_FOUR_HOURS = 24 * 60 * 60 * 1000;

      let currentCount = localStorage.getItem(localCountKey) || '------';
      const lastVisitTime = localStorage.getItem(lastVisitTimeKey);
      const now = Date.now();
      const hasVisitedWithin24Hours = lastVisitTime && (now - parseInt(lastVisitTime, 10) < TWENTY_FOUR_HOURS);
      
      try {
        const url = `https://api.counterapi.dev/v1/${namespace}/${key}`;
        if (!hasVisitedWithin24Hours) {
          const response = await fetch(url + '/up');
          if (!response.ok) throw new Error('API 回應錯誤');
          const data = await response.json();
          currentCount = String(data.count).padStart(6, '0');
          localStorage.setItem(lastVisitTimeKey, now.toString());
          localStorage.setItem(localCountKey, currentCount);
        } else {
          try {
            const response = await fetch(url);
            if (response.ok) {
              const data = await response.json();
              currentCount = String(data.count).padStart(6, '0');
              localStorage.setItem(localCountKey, currentCount);
            }
          } catch (e) {
            console.warn('無法從伺服器獲取最新數字，已切換為本地暫存值');
          }
        }
        setVisitorCount(currentCount);
      } catch (error) {
        console.error('計數器載入異常:', error);
        setVisitorCount(currentCount);
      }
    };

    initCounter();
  }, []);

  return (
    <div className="bg-[#f8fafc] text-slate-800 font-sans antialiased selection:bg-blue-200 selection:text-blue-900 relative flex flex-col min-h-screen">
      
      {/* 🔷 頂部導覽列 (Navbar) */}
      <nav className="w-full bg-white border-b border-slate-200 shadow-sm relative z-30">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 flex items-center justify-between py-3 md:py-4">
          <div className="flex items-center gap-3 sm:gap-6 lg:gap-8 min-w-0">
            {/* 高科大 Logo */}
            <a href="https://www.nkust.edu.tw/" target="_blank" rel="noopener noreferrer" className="flex items-center shrink-0 transition-transform duration-300 hover:scale-105">
              <img 
                src="/images/nkust-logo.png" 
                alt="NKUST 國立高雄科技大學" 
                className="h-6 sm:h-9 md:h-10 lg:h-11 w-auto object-contain" 
                onError={(e) => { e.target.src='https://upload.wikimedia.org/wikipedia/zh/thumb/4/46/National_Kaohsiung_University_of_Science_and_Technology_logo.svg/800px-National_Kaohsiung_University_of_Science_and_Technology_logo.svg.png'; }} 
              />
            </a>
            {/* 分隔線 */}
            <div className="h-4 sm:h-6 md:h-8 border-l-[1.5px] border-slate-300/80 shrink-0 rounded-full"></div>
            {/* 實驗室 Logo */}
            <a href="/" className="flex items-center shrink-0 transition-transform duration-300 hover:scale-105">
              <img 
                src="/images/sicp-logo.png" 
                alt="iCPS Lab 智慧網宇實體系統實驗室" 
                className="h-7 sm:h-11 md:h-12 lg:h-[3.25rem] w-auto object-contain" 
                onError={(e) => { e.target.style.display='none'; }} 
              />
            </a>
          </div>

          {/* 右側導覽連結 */}
          <div className="hidden md:flex space-x-8 text-sm font-bold text-slate-600 shrink-0 ml-4">
            <a href="/#news" className="hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">最新消息</a>
            <a href="/activities" className="text-blue-800 border-b-2 border-blue-800 pb-1">活動花絮</a>
            <a href="/#videos" className="hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">影音專區</a>
            <a href="/members" className="hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">實驗室成員</a>
          </div>
        </div>
      </nav>

      {/* 🔷 頁面標題區 */}
      <header className="bg-[#0f172a] py-14 text-center border-b-4 border-blue-700 relative overflow-hidden">
        <div className="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] pointer-events-none"></div>
        <div className="relative z-10">
          <h1 className="text-3xl md:text-4xl font-extrabold text-white tracking-widest mb-3">ICCT-Pacific 2026</h1>
          <p className="text-slate-300 text-sm font-light tracking-wider uppercase">Event Gallery</p>
        </div>
      </header>

      {/* 🔷 網站主體區域 (相片集錦) */}
      <main className="max-w-7xl mx-auto w-full px-6 py-16 relative z-20 flex-1">
        
        {/* 返回按鈕與統計 */}
        <div className="mb-8 border-b border-slate-200 pb-4 flex justify-between items-end">
          <a href="/activities" className="inline-flex items-center text-sm font-bold text-slate-500 hover:text-blue-700 transition">
            <svg xmlns="http://www.w3.org/2000/svg" className="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            返回活動列表
          </a>
          <span className="text-sm font-medium text-slate-400">目前共收錄 {images.length} 張照片</span>
        </div>

        {/* 相片圖片網格 */}
        {loading ? (
          <div className="flex justify-center items-center h-64">
            <div className="animate-spin rounded-full h-12 w-12 border-b-4 border-blue-700 border-t-transparent"></div>
          </div>
        ) : (
          <div className="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            {images.map((img, idx) => (
              <div 
                key={img.id || idx} 
                className="group relative rounded-md overflow-hidden shadow-sm border border-slate-200 hover:shadow-md hover:border-blue-400 transition-all duration-300 bg-slate-100 aspect-[4/3]"
              >
                <img
                  src={img.secure_url}
                  alt={`活動照片 ${idx + 1}`}
                  className="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out"
                  loading="lazy"
                />
                
                {/* 滑鼠移上去時的黑色漸層遮罩 */}
                <div className="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                  <div className="absolute bottom-4 left-4 flex flex-col">
                    <span className="text-white text-sm font-medium">Photo #{idx + 1}</span>
                    <span className="text-slate-300 text-xs mt-0.5">{new Date(img.created_at).toLocaleDateString()}</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}
      </main>

      {/* 🔷 頁尾 (Footer) */}
      <footer className="bg-[#0f172a] py-16 mt-auto border-t border-slate-800 relative z-20">
        <div className="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-start gap-10">
          <div className="md:w-1/2">
            <img 
              src="/images/footer-logo.png" 
              alt="iCPS Lab" 
              className="h-14 md:h-20 w-auto mb-3 object-contain" 
              onError={(e) => { e.target.style.display='none'; }} 
            />
            <p className="text-sm text-blue-400 font-medium mb-4">智慧網宇實體系統實驗室</p>
            <p className="text-sm text-slate-400 leading-relaxed max-w-md">
              Intelligent Cyber-Physical Systems Laboratory <br/>
              國立高雄科技大學 (NKUST)
            </p>
          </div>
          <div className="md:w-1/2 flex flex-col md:items-end text-sm space-y-3">
            <h3 className="text-white font-semibold mb-2 tracking-wide uppercase text-xs">Contact Us</h3>
            <p className="flex items-center gap-2 text-slate-300"><span className="text-slate-500">📍</span> 國立高雄科技大學 (建工校區)</p>
            <p className="flex items-center gap-2 text-slate-300"><span className="text-slate-500">📞</span> 07-3814526 分機 15672</p>
            <p className="flex items-center gap-2 text-slate-300"><span className="text-slate-500">✉️</span> <a href="mailto:allenchang@nkust.edu.tw" className="hover:text-blue-400 transition">allenchang@nkust.edu.tw</a></p>
          </div>
        </div>
        
        <div className="max-w-7xl mx-auto px-6 mt-12 pt-6 border-t border-slate-800 flex flex-col lg:flex-row justify-between items-center gap-6 lg:gap-4">
          <div className="flex flex-col sm:flex-row items-center gap-2 sm:gap-4 text-center sm:text-left">
            <p className="text-xs text-slate-500 leading-normal">
              &copy; 2026 <span className="italic font-['Times_New_Roman',_Times,_serif] text-[1.15em]">i</span>CPS Lab, National Kaohsiung University of Science and Technology.
            </p>
            <p className="text-xs text-slate-500 hidden sm:block">|</p>
            <p className="text-xs text-slate-500">All rights reserved.</p>
          </div>

          <div className="flex items-center gap-2 bg-slate-800/50 px-3 py-1.5 rounded-md border border-slate-700 shadow-sm transition hover:border-slate-600">
            <svg className="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
            <span className="text-xs text-slate-400 font-medium tracking-wide">累積造訪人數</span>
            <span className="text-xs text-slate-600 mx-1">|</span>
            <span className="text-sm font-mono font-bold text-blue-400 tracking-wider">{visitorCount}</span>
          </div>
        </div>
      </footer>
    </div>
  );
}