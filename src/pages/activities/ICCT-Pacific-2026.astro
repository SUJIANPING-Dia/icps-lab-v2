---
const cloudName = import.meta.env.CLOUDINARY_CLOUD_NAME;
const apiKey = import.meta.env.CLOUDINARY_API_KEY;
const apiSecret = import.meta.env.CLOUDINARY_API_SECRET;

const auth = Buffer.from(`${apiKey}:${apiSecret}`).toString('base64');

const res = await fetch(
  `https://api.cloudinary.com/v1_1/${cloudName}/resources/image?type=upload&prefix=events/ICCT-Pacific 2026`,
  {
    headers: {
      Authorization: `Basic ${auth}`
    }
  }
);

const data = await res.json();
const images = data.resources || [];
---

<html>
  <head>
    <title>ICCT-Pacific 2026</title>
  </head>

  <body style="background:#fff; padding:20px; font-family:sans-serif;">

    <h1 style="text-align:center; margin-bottom:30px;">
      ICCT-Pacific 2026 活動照片123
    </h1>

    <div style="
      display:grid;
      grid-template-columns: repeat(3,1fr);
      gap:20px;
    ">
      {images.map(img => (
        <img src={img.secure_url} style="width:100%; border-radius:10px;" />
      ))}
    </div>

  </body>
</html>