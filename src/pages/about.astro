---
import "../styles/global.css";
---

<html lang="zh-TW" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/images/lab-logo.png" />
  <title>關於實驗室 | iCPS Lab 智慧網宇實體系統實驗室</title>
</head>

<body class="bg-[#f8fafc] text-slate-800 font-sans antialiased selection:bg-blue-200 selection:text-blue-900 relative flex flex-col min-h-screen">

  <!-- 🔷 頂部導覽列 (Navbar) -->
  <nav class="w-full bg-white border-b border-slate-200 shadow-sm relative z-30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center justify-between py-3 md:py-4">
      <div class="flex items-center gap-3 sm:gap-6 lg:gap-8 min-w-0">
        <!-- 高科大 Logo -->
        <a href="https://www.nkust.edu.tw/" target="_blank" class="flex items-center shrink-0 transition-transform duration-300 hover:scale-105">
          <img src="/images/nkust-logo.png" alt="NKUST 國立高雄科技大學" class="h-6 sm:h-9 md:h-10 lg:h-11 w-auto object-contain" onerror="this.src='https://upload.wikimedia.org/wikipedia/zh/thumb/4/46/National_Kaohsiung_University_of_Science_and_Technology_logo.svg/800px-National_Kaohsiung_University_of_Science_and_Technology_logo.svg.png';" />
        </a>
        <div class="h-4 sm:h-6 md:h-8 border-l-[1.5px] border-slate-300/80 shrink-0 rounded-full"></div>
        <!-- 實驗室 Logo -->
        <a href="/" class="flex items-center shrink-0 transition-transform duration-300 hover:scale-105">
          <img src="/images/sicp-logo.png" alt="iCPS Lab 智慧網宇實體系統實驗室" class="h-7 sm:h-11 md:h-12 lg:h-[3.25rem] w-auto object-contain" onerror="this.style.display='none';" />
        </a>
      </div>

      <!-- 右側導覽連結 -->
  <div class="hidden md:flex space-x-8 text-sm font-bold text-slate-600 shrink-0 ml-4">
    <a href="/" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
    <span>首頁</span>
    <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Home</span>
  </a>
  <a href="/about" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
    <span>關於 iCPS Lab</span>
    <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">About</span>
  </a>

  <a href="/#news" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
    <span>最新消息</span>
    <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">News</span>
  </a>

  <a href="/activities" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
    <span>活動花絮</span>
    <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Events</span>
  </a>

  <a href="/#videos" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
    <span>影音專區</span>
    <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Media</span>
  </a>

          <a href="/achievements"  class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>成果榮譽</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Achievements</span>
        </a>

  <a href="/members" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
    <span>實驗室成員</span>
    <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Members</span>
  </a>
          <a href="/faq" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>常見問題</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">FAQ</span>
        </a>

</div>

      <!-- 手機版漢堡選單按鈕 (新增) -->
      <button id="mobile-menu-btn" class="md:hidden p-2 text-slate-600 hover:text-blue-800 transition focus:outline-none" aria-label="打開選單">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- 手機版下拉選單 (新增) -->
    <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 w-full bg-white border-b border-slate-200 shadow-lg flex flex-col z-20">
	  <a href="/" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">首頁</a>
      <a href="/about" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">關於 iCPS Lab</a>
      <a href="/#news"class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">最新消息</a>
      <a href="/activities" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">活動花絮</a>
      <a href="/#videos" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">影音專區</a>
	  <a href="/achievements" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">成果與榮譽</a>
      <a href="/members" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">實驗室成員</a>
	  <a href="/faq" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">常見問題</a>
    </div>
  </nav>

  <!-- 🔷 頁面標題區 (Hero Banner) -->
  <header class="bg-gradient-to-r from-slate-900 via-[#0f172a] to-slate-800 py-16 lg:py-20 text-center border-b-[5px] border-blue-700 relative overflow-hidden shadow-inner">
    <div class="absolute inset-0 opacity-20 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] pointer-events-none"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-4">
      <h1 class="text-3xl md:text-5xl font-extrabold text-white tracking-widest mb-4 drop-shadow-md">關於 iCPS Lab</h1>
      <p class="text-blue-200 text-sm md:text-base font-medium tracking-[0.2em] uppercase drop-shadow">Intelligent Cyber-Physical Systems Laboratory</p>
    </div>
  </header>

  <!-- 🔷 網站主體區域 -->
  <main class="flex-grow max-w-7xl mx-auto px-6 py-16 relative z-20 w-full animate-fade-in-up">

    <!-- 回首頁按鈕 -->
    <div class="mb-10">
      <a href="/" class="inline-flex items-center text-sm font-bold text-slate-500 hover:text-blue-700 transition-colors bg-white px-4 py-2 rounded-full shadow-sm border border-slate-200 hover:shadow-md">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
        返回首頁
      </a>
    </div>

    <!-- 垂直間距容器 -->
    <div class="space-y-20">

      <!-- 📌 區塊一：實驗室領航 (教授介紹 - 移至最上方) -->
      <section>
        <div class="flex items-center gap-3 mb-10">
          <div class="w-2 h-8 bg-blue-700 rounded-full"></div>
          <h3 class="text-2xl lg:text-3xl font-bold text-slate-800 tracking-tight">實驗室領航 <span class="text-slate-400 font-light ml-2 text-xl lg:text-2xl">Principal Investigator</span></h3>
        </div>
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <!-- 左側：教授照片 -->
          <div class="w-full aspect-video bg-slate-200 rounded-2xl shadow-lg overflow-hidden border border-slate-200 relative group transition-shadow hover:shadow-xl duration-300">
            <img 
              class="w-full h-full absolute inset-0 object-cover object-center" 
              src="/images/professor-chang.png" 
              alt="張萬榮 教授" 
              onerror="this.src='https://via.placeholder.com/800x450?text=Professor+Chang';" 
            />
          </div>
          
          <!-- 右側：教授理念 -->
          <div class="flex flex-col justify-center h-full space-y-5">
            <h4 class="text-2xl font-bold text-slate-900 border-b border-slate-100 pb-3">
              張萬榮 教授 
              <span class="text-base font-medium text-slate-500 ml-2 font-mono">Wan-Jung Chang, Ph.D.</span>
            </h4>
            
            <p class="text-slate-700 leading-relaxed font-semibold text-lg text-justify text-blue-900/90 bg-blue-50/50 p-4 rounded-lg border-l-4 border-blue-200">
              「工程教育的價值在於探索未知，並將科技回饋社會。我們期許團隊不僅掌握前瞻技術，更能為臨床與產業提出切實可行的解方。」
            </p>
            
            <p class="text-slate-600 leading-relaxed text-sm lg:text-base text-justify">
              張教授深耕 AIoT 與邊緣運算多年，在<strong class="text-slate-800">高科大電子工程系</strong>建構了高度跨域協作的研究環境。對外，積極橋接醫療院所與科技大廠的資源；對內，則致力於營造互助融洽的團隊氛圍，引導學生在紮實的學理基礎上，將創意化為實體應用。
            </p>

            <div class="pt-4 flex flex-wrap gap-4">
              <a href="https://ec.nkust.edu.tw/p/404-1122-98302.php?Lang=zh-tw" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-white bg-slate-800 hover:bg-blue-700 font-medium px-5 py-2.5 rounded-lg transition-all duration-300 shadow-sm hover:shadow-md text-sm">
                查看教授完整簡歷
              </a>
              <a href="mailto:allenchang@nkust.edu.tw" class="inline-flex items-center text-slate-700 bg-white border border-slate-300 hover:bg-slate-50 hover:text-blue-700 font-medium px-5 py-2.5 rounded-lg transition-all duration-300 shadow-sm text-sm">
                ✉️ 寄信聯繫教授
              </a>
            </div>
          </div>
        </div>
      </section>
      
      <!-- 📌 區塊二：實驗室願景 (我們做什麼) -->
      <section>
        <div class="bg-white border-l-[6px] border-blue-700 p-8 lg:p-12 shadow-[0_4px_20px_-4px_rgba(0,0,0,0.05)] rounded-r-xl">
          <h2 class="text-2xl lg:text-3xl font-bold text-slate-900 mb-5 tracking-tight">我們不只寫程式，更致力於解決真實世界的痛點。</h2>
          <p class="text-slate-700 leading-relaxed text-lg mb-5 text-justify">
            <strong class="text-blue-800">智慧網宇實體系統實驗室 (iCPS Lab)</strong> 專注於打破學術研究與產業實務的界線。我們深度融合人工智慧 (AI)、物聯網 (AIoT) 與延展實境 (XR) 技術，將前端的感測數據與後端的雲邊緣運算無縫接軌，打造具備高度智慧化、自動化的虛實整合解決方案。
          </p>
          <p class="text-slate-600 leading-relaxed text-base lg:text-lg text-justify">
            從<strong class="text-slate-800">臨床醫療照護、高科技廠房的智能製造，到城市級的智慧交通系統</strong>，我們的技術皆已實際落地驗證。無論您是尋求技術突破的企業夥伴，還是渴望掌握前瞻科技的優秀學子，iCPS Lab 都是您實踐創新的最佳基地。
          </p>
        </div>
      </section>

      <!-- 📌 區塊三：雙向對話 (左邊對廠商，右邊對學生) -->
      <section class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- 給企業與臨床單位 -->
        <div class="bg-gradient-to-br from-slate-900 to-slate-800 p-8 rounded-2xl shadow-lg relative overflow-hidden group">
          <div class="absolute top-0 right-0 -mt-4 -mr-4 w-24 h-24 bg-blue-600 rounded-full opacity-20 group-hover:scale-150 transition-transform duration-700"></div>
          <div class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center mb-6 text-2xl">🤝</div>
          <h3 class="text-2xl font-bold text-white mb-4">產醫跨域合作</h3>
          <p class="text-slate-300 leading-relaxed mb-6 text-sm lg:text-base">
            我們具備豐富的產學合作與臨床場域驗證經驗，能為企業與醫院提供客製化的技術評估與系統開發。從概念驗證 (PoC) 到系統整合，我們是您最可靠的技術大腦。
          </p>
          <ul class="text-slate-200 space-y-3 mb-8 text-sm">
            <li class="flex items-start"><svg class="w-5 h-5 text-blue-400 mr-2 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg> 臨床痛點 AI 輔助系統開發</li>
            <li class="flex items-start"><svg class="w-5 h-5 text-blue-400 mr-2 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg> 智慧工廠產線自動化與瑕疵檢測</li>
            <li class="flex items-start"><svg class="w-5 h-5 text-blue-400 mr-2 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg> 前瞻技術轉移與聯合技術研發</li>
          </ul>
          <a href="mailto:allenchang@nkust.edu.tw" class="inline-block bg-blue-600 hover:bg-blue-500 text-white font-medium px-5 py-2 rounded-lg transition-colors text-sm">
            提案與洽詢合作 &rarr;
          </a>
        </div>

        <!-- 給學生 -->
        <div class="bg-gradient-to-br from-blue-50 to-white border border-blue-100 p-8 rounded-2xl shadow-sm hover:shadow-lg transition-shadow relative overflow-hidden group">
          <div class="w-12 h-12 bg-blue-100 text-blue-700 rounded-xl flex items-center justify-center mb-6 text-2xl">🎓</div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4">啟動研究生涯</h3>
          <p class="text-slate-600 leading-relaxed mb-6 text-sm lg:text-base">
            我們回歸校園培育人才的初衷，熱烈招收具備熱忱的博碩士與大學部專題生。在這裡，你將不會只讀紙上理論，而是真正動手將技術變成解決真實問題的產品。
          </p>
          <ul class="text-slate-700 space-y-3 mb-8 text-sm font-medium">
            <li class="flex items-start"><svg class="w-5 h-5 text-blue-600 mr-2 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg> 扎實訓練：從演算法開發到系統落地</li>
            <li class="flex items-start"><svg class="w-5 h-5 text-blue-600 mr-2 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg> 國際視野：輔導發表國內外頂尖研討會與期刊</li>
            <li class="flex items-start"><svg class="w-5 h-5 text-blue-600 mr-2 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg> 實戰履歷：帶領參與各大創新創業與黑客松競賽</li>
          </ul>
          <a href="/members" class="inline-block bg-white border-2 border-slate-900 text-slate-900 hover:bg-slate-900 hover:text-white font-medium px-5 py-1.5 rounded-lg transition-colors text-sm">
            認識實驗室學長姐 &rarr;
          </a>
        </div>
      </section>

      <!-- 📌 區塊四：三大核心研究領域 (實力展示) -->
      <section>
        <div class="flex items-center gap-3 mb-10">
          <div class="w-2 h-8 bg-blue-700 rounded-full"></div>
          <h3 class="text-2xl lg:text-3xl font-bold text-slate-800 tracking-tight">核心領域與應用 <span class="text-slate-400 font-light ml-2 text-xl lg:text-2xl">Core Applications</span></h3>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- 照護醫療 -->
          <div class="bg-white border border-slate-100 p-8 rounded-2xl shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-300 flex flex-col group">
            <div class="w-14 h-14 bg-red-50 text-red-500 rounded-2xl flex items-center justify-center mb-6 shrink-0 group-hover:bg-red-500 group-hover:text-white transition-colors duration-300 shadow-sm">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
            </div>
            <h4 class="font-bold text-slate-900 text-xl mb-3">數位醫療與智慧照護</h4>
            <p class="text-sm lg:text-base text-slate-600 leading-relaxed mt-auto text-justify">
              整合熱影像、ToF 感測器與 AI 骨幹辨識。成功應用於精神病房自傷預警、病患日常行為辨識、耳病灶自動診斷，並開發結合 YOLO 的舌肌復健與手術器械教育訓練 XR 平台，有效降低醫療人員負擔。
            </p>
          </div>

          <!-- 智能製造 -->
          <div class="bg-white border border-slate-100 p-8 rounded-2xl shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-300 flex flex-col group">
            <div class="w-14 h-14 bg-amber-50 text-amber-500 rounded-2xl flex items-center justify-center mb-6 shrink-0 group-hover:bg-amber-500 group-hover:text-white transition-colors duration-300 shadow-sm">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            </div>
            <h4 class="font-bold text-slate-900 text-xl mb-3">工業 4.0 智能製造</h4>
            <p class="text-sm lg:text-base text-slate-600 leading-relaxed mt-auto text-justify">
