  <script>
    document.addEventListener("DOMContentLoaded", () => {

      // ── 0. 手機選單 ──
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const hamburgerIcon = document.getElementById('hamburger-icon');
      if (mobileMenuBtn && mobileMenu && hamburgerIcon) {
        mobileMenuBtn.addEventListener('click', () => {
          const isHidden = mobileMenu.classList.contains('hidden');
          mobileMenu.classList.toggle('hidden', !isHidden);
          hamburgerIcon.setAttribute('d', isHidden ? 'M6 18L18 6M6 6l12 12' : 'M4 6h16M4 12h16M4 18h16');
        });
        mobileMenu.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            mobileMenu.classList.add('hidden');
            hamburgerIcon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
          });
        });
      }

      // ── 1. 訪客計數器 ──
      const initCounter = async () => {
        const counterEl = document.getElementById('visitor-count');
        if (!counterEl) return;
        const namespace = 'icpslab_site', key = 'visits';
        const localCountKey = 'icps_saved_count', lastVisitTimeKey = 'icps_last_visit_time';
        const TWENTY_FOUR_HOURS = 24 * 60 * 60 * 1000;
        let currentCount = localStorage.getItem(localCountKey) || '------';
        const lastVisitTime = localStorage.getItem(lastVisitTimeKey);
        const now = Date.now();
        const hasVisitedWithin24Hours = lastVisitTime && (now - parseInt(lastVisitTime, 10) < TWENTY_FOUR_HOURS);
        try {
          const url = `https://api.counterapi.dev/v1/${namespace}/${key}`;
          if (!hasVisitedWithin24Hours) {
            const response = await fetch(url + '/up');
            if (!response.ok) throw new Error('API error');
            const data = await response.json();
            currentCount = String(data.count).padStart(6, '0');
            localStorage.setItem(lastVisitTimeKey, now.toString());
            localStorage.setItem(localCountKey, currentCount);
          } else {
            try {
              const r = await fetch(url);
              if (r.ok) {
                const d = await r.json();
                currentCount = String(d.count).padStart(6, '0');
                localStorage.setItem(localCountKey, currentCount);
              }
            } catch {}
          }
        } catch {}
        counterEl.textContent = currentCount;
      };
      initCounter();

      // ── 2. Scroll Reveal ──
      const revealEls = document.querySelectorAll('.rv');
      const revealObserver = new IntersectionObserver((entries, obs) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            obs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -56px 0px' });
      revealEls.forEach(el => revealObserver.observe(el));

      // ── 3. Sticky tabs active state ──
      const tabs = Array.from(document.querySelectorAll('.page-tab'));
      const sections = tabs
        .map(tab => document.querySelector(tab.getAttribute('href')))
        .filter(Boolean);

      const tabObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const activeHref = `#${entry.target.id}`;
            tabs.forEach(tab => tab.classList.toggle('is-active', tab.getAttribute('href') === activeHref));
          }
        });
      }, { threshold: 0.28, rootMargin: '-18% 0px -62% 0px' });
      sections.forEach(section => tabObserver.observe(section));

      // ── 4. Hero Canvas 粒子線條動畫 ──
      const canvas = document.getElementById('hero-canvas');
      if (canvas) {
        const ctx = canvas.getContext('2d');
        let W, H, particles = [];
        const isReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        const resize = () => {
          const dpr = Math.min(window.devicePixelRatio || 1, 2);
          W = canvas.offsetWidth;
          H = canvas.offsetHeight;
          canvas.width = W * dpr;
          canvas.height = H * dpr;
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        };

        const createParticles = () => {
          const count = window.innerWidth < 768 ? 34 : 62;
          particles = Array.from({ length: count }, () => ({
            x: Math.random() * W,
            y: Math.random() * H,
            vx: (Math.random() - 0.5) * 0.34,
            vy: (Math.random() - 0.5) * 0.34,
            r: Math.random() * 1.7 + 0.6,
            a: Math.random() * 0.45 + 0.15,
          }));
        };

        resize();
        createParticles();
        window.addEventListener('resize', () => { resize(); createParticles(); });

        const draw = () => {
          ctx.clearRect(0, 0, W, H);
          particles.forEach(p => {
            if (!isReduced) {
              p.x += p.vx;
              p.y += p.vy;
              if (p.x < 0) p.x = W;
              if (p.x > W) p.x = 0;
              if (p.y < 0) p.y = H;
              if (p.y > H) p.y = 0;
            }
          });

          const maxDist = window.innerWidth < 768 ? 86 : 120;
          for (let i = 0; i < particles.length; i++) {
            for (let j = i + 1; j < particles.length; j++) {
              const dx = particles[i].x - particles[j].x;
              const dy = particles[i].y - particles[j].y;
              const dist = Math.sqrt(dx * dx + dy * dy);
              if (dist < maxDist) {
                ctx.beginPath();
                ctx.strokeStyle = `rgba(96, 165, 250, ${(1 - dist / maxDist) * 0.18})`;
                ctx.lineWidth = 0.75;
                ctx.moveTo(particles[i].x, particles[i].y);
                ctx.lineTo(particles[j].x, particles[j].y);
                ctx.stroke();
              }
            }
          }

          particles.forEach(p => {
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(147, 197, 253, ${p.a})`;
            ctx.fill();
          });

          if (!isReduced) requestAnimationFrame(draw);
        };
        draw();
      }
    });
  </script>

</body>
</html>
