---
import "../styles/global.css";
---

<html lang="zh-TW" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/images/lab-logo.png" />
  <title>關於實驗室 | iCPS Lab 智慧網宇實體系統實驗室</title>
</head>

<body class="bg-[#f8fafc] text-slate-800 font-sans antialiased selection:bg-blue-200 selection:text-blue-900 relative flex flex-col min-h-screen">

  <!-- 🔷 頂部導覽列 (Navbar) -->
  <nav class="w-full bg-white border-b border-slate-200 shadow-sm relative z-30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center justify-between py-3 md:py-4">
      <div class="flex items-center gap-3 sm:gap-6 lg:gap-8 min-w-0">
        <!-- 高科大 Logo -->
        <a href="https://www.nkust.edu.tw/" target="_blank" class="flex items-center shrink-0 transition-transform duration-300 hover:scale-105">
          <img src="/images/nkust-logo.png" alt="NKUST 國立高雄科技大學" class="h-6 sm:h-9 md:h-10 lg:h-11 w-auto object-contain" onerror="this.src='https://upload.wikimedia.org/wikipedia/zh/thumb/4/46/National_Kaohsiung_University_of_Science_and_Technology_logo.svg/800px-National_Kaohsiung_University_of_Science_and_Technology_logo.svg.png';" />
        </a>
        <div class="h-4 sm:h-6 md:h-8 border-l-[1.5px] border-slate-300/80 shrink-0 rounded-full"></div>
        <!-- 實驗室 Logo -->
        <a href="/" class="flex items-center shrink-0 transition-transform duration-300 hover:scale-105">
          <img src="/images/sicp-logo.png" alt="iCPS Lab 智慧網宇實體系統實驗室" class="h-7 sm:h-11 md:h-12 lg:h-[3.25rem] w-auto object-contain" onerror="this.style.display='none';" />
        </a>
      </div>

      <!-- 右側導覽連結 -->
      <div class="hidden md:flex space-x-8 text-sm font-bold text-slate-600 shrink-0 ml-4">
        <a href="/about" class="text-blue-800 border-b-2 border-blue-800 pb-1">關於 iCPS Lab</a>
        <a href="/#news" class="hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">最新消息</a>
        <a href="/#activities" class="hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">活動花絮</a>
        <a href="/#videos" class="hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">影音專區</a>
        <a href="/members" class="hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">實驗室成員</a>
      </div>
    </div>
  </nav>

  <!-- 🔷 頁面標題區 (Hero Banner - 優化漸層與陰影) -->
  <header class="bg-gradient-to-r from-slate-900 via-[#0f172a] to-slate-800 py-16 lg:py-20 text-center border-b-[5px] border-blue-700 relative overflow-hidden shadow-inner">
    <div class="absolute inset-0 opacity-20 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] pointer-events-none"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-4">
      <h1 class="text-3xl md:text-5xl font-extrabold text-white tracking-widest mb-4 drop-shadow-md">關於 iCPS Lab</h1>
      <p class="text-blue-200 text-sm md:text-base font-medium tracking-[0.2em] uppercase drop-shadow">About iCPS Laboratory</p>
    </div>
  </header>

  <!-- 🔷 網站主體區域 (加入淡入動畫 class) -->
  <main class="flex-grow max-w-7xl mx-auto px-6 py-16 relative z-20 w-full animate-fade-in-up">

    <!-- 回首頁按鈕 -->
    <div class="mb-10">
      <a href="/" class="inline-flex items-center text-sm font-bold text-slate-500 hover:text-blue-700 transition-colors bg-white px-4 py-2 rounded-full shadow-sm border border-slate-200 hover:shadow-md">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
        返回首頁
      </a>
    </div>

    <!-- 所有區塊的外層容器，控制垂直間距 -->
    <div class="space-y-24">
      
      <!-- 📌 區塊一：實驗室願景與核心精神 -->
      <section>
        <div class="bg-white border-l-[6px] border-blue-700 p-8 lg:p-12 shadow-[0_4px_20px_-4px_rgba(0,0,0,0.05)] rounded-r-xl">
          <h2 class="text-2xl lg:text-3xl font-bold text-slate-900 mb-5 tracking-tight">我們不只寫程式，更解決真實世界的痛點。</h2>
          <p class="text-slate-700 leading-relaxed text-lg mb-5 text-justify">
            <strong class="text-blue-800">iCPS Lab 智慧網宇實體系統實驗室</strong> 致力於在智慧網宇實體系統領域內之前瞻實務與學術研究。研究目標融合了人工智慧 (AI)、物聯網 (IoT)、延展實境 (XR) 等技術，並透過網路通訊與物理世界的交互，旨在開發出能夠智慧感測與分析之虛實系統解決方案。
          </p>
          <p class="text-slate-600 leading-relaxed text-base lg:text-lg text-justify">
            智慧網宇實體系統之研究範疇廣泛，主要涵蓋<strong class="text-slate-800">智慧交通系統、智能製造系統、照護醫療系統</strong>等領域。智慧網宇實體系統實驗室非常歡迎對此領域充滿熱忱的同學加入我們，共同開創智慧科技的新紀元。
          </p>
        </div>
      </section>

      <!-- 📌 區塊二：指導教授與實驗室領航 (左影片/右文字) -->
      <section>
        <div class="flex items-center gap-3 mb-10">
          <div class="w-2 h-8 bg-blue-700 rounded-full"></div>
          <h3 class="text-2xl lg:text-3xl font-bold text-slate-800 tracking-tight">指導教授領航 <span class="text-slate-400 font-light ml-2 text-xl lg:text-2xl">Principal Investigator</span></h3>
        </div>
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <!-- 左側：YouTube 影片 (圓角與優化陰影) -->
          <div class="w-full aspect-video bg-slate-200 rounded-2xl shadow-lg overflow-hidden border border-slate-200 relative group transition-shadow hover:shadow-xl duration-300">
            <!-- 👇 請將 src 替換為實際的 YouTube 嵌入連結 -->
            <iframe 
              class="w-full h-full absolute inset-0"
              src="https://www.youtube.com/watch?v=AZQONwyI5IE&list=PL_k9bFPONrNfXPh7cK_JZES1MpifA9_hh&index=2" 
              title="張萬榮教授實驗室介紹" 
              frameborder="0" 
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
              allowfullscreen>
            </iframe>
          </div>
          
          <!-- 右側：教授理念與實驗室風格 -->
          <div class="flex flex-col justify-center h-full space-y-5">
            <h4 class="text-2xl font-bold text-slate-900 border-b border-slate-100 pb-3">
              張萬榮 教授 
              <span class="text-base font-medium text-slate-500 ml-2 font-mono">Wan-Jung Chang, Ph.D.</span>
            </h4>
            
            <p class="text-slate-700 leading-relaxed font-semibold text-lg text-justify text-blue-900/90 bg-blue-50/50 p-4 rounded-lg border-l-4 border-blue-200">
              「工程教育的價值在於探索未知，並將科技回饋社會。我們期許團隊不僅掌握前瞻技術，更能解決臨床與產業的真實痛點。」
            </p>
            
            <p class="text-slate-600 leading-relaxed text-sm lg:text-base text-justify">
              張教授帶領團隊深耕 AIoT 與邊緣運算，致力於在<strong class="text-slate-800">高雄科技大學電子工程系</strong>建構完善的培育環境。實驗室擁有互助融洽的團隊氛圍，鼓勵學生建立扎實的學理基礎，積極發表<strong class="text-slate-800">國內外頂尖研討會與期刊論文</strong>；同時帶領團隊參與各項<strong class="text-slate-800">創新創業競賽</strong>，將理論化為實務應用。
            </p>

            <p class="text-slate-600 leading-relaxed text-sm lg:text-base text-justify">
              iCPS Lab 每年熱烈招收具備熱忱的 <strong class="text-blue-700 font-bold bg-blue-50 px-1.5 py-0.5 rounded">博士、碩士及大學部專題生</strong>。我們回歸校園培育人才的初衷，透過嚴謹的學術訓練與產醫跨域交流，幫助你在這裡獲得兼具理論深度與研發實作的全面成長！
            </p>

            <div class="pt-4">
              <a href="https://ec.nkust.edu.tw/p/404-1122-98302.php?Lang=zh-tw" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-white bg-slate-800 hover:bg-blue-700 font-medium px-5 py-2.5 rounded-lg transition-all duration-300 shadow-sm hover:shadow-md group text-sm">
                查看教授完整簡歷與研究專長
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- 📌 區塊三：三大核心研究領域 (微動效卡片設計) -->
      <section>
        <div class="flex items-center gap-3 mb-10">
          <div class="w-2 h-8 bg-blue-700 rounded-full"></div>
          <h3 class="text-2xl lg:text-3xl font-bold text-slate-800 tracking-tight">核心研究領域 <span class="text-slate-400 font-light ml-2 text-xl lg:text-2xl">Core Research Areas</span></h3>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- 卡片 1 -->
          <div class="bg-white border border-slate-100 p-8 rounded-2xl shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-300 flex flex-col group">
            <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-6 shrink-0 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300 shadow-sm">
              <span class="text-2xl">🏥</span>
            </div>
            <h4 class="font-bold text-slate-900 text-xl mb-3">照護醫療系統</h4>
            <p class="text-sm lg:text-base text-slate-600 leading-relaxed mt-auto text-justify">
              開發基於熱影像、ToF感測器與骨幹辨識之輔助系統。涵蓋精神病房自傷預警、病患日常行為與翻身拍背辨識、耳病灶自動診斷，以及結合YOLO之舌肌復健與手術器械教育訓練平台。
            </p>
          </div>

          <!-- 卡片 2 -->
          <div class="bg-white border border-slate-100 p-8 rounded-2xl shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-300 flex flex-col group">
            <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-6 shrink-0 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300 shadow-sm">
              <span class="text-2xl">🏭</span>
            </div>
            <h4 class="font-bold text-slate-900 text-xl mb-3">智能製造系統</h4>
            <p class="text-sm lg:text-base text-slate-600 leading-relaxed mt-auto text-justify">
              運用 YOLO 深度學習與邊緣運算，開發自動化產線瑕疵檢測系統（如電容缺漏焊、包裝缺陷辨識），實現高精準度與低延遲的檢驗效能，提升工廠產線良率與生產效率。
            </p>
          </div>

          <!-- 卡片 3 -->
          <div class="bg-white border border-slate-100 p-8 rounded-2xl shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-300 flex flex-col group">
            <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-6 shrink-0 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300 shadow-sm">
              <span class="text-2xl">🚗</span>
            </div>
            <h4 class="font-bold text-slate-900 text-xl mb-3">智慧交通與 XR 應用</h4>
            <p class="text-sm lg:text-base text-slate-600 leading-relaxed mt-auto text-justify">
              融合物聯網 (IoT) 與延展實境 (XR) 等技術，建立網路通訊與物理世界交互的智慧感測網路。應用範疇包含智慧交通、環境微塑膠監測等前瞻虛實系統解決方案。
            </p>
          </div>
        </div>
      </section>

    </div>
  </main>

  <!-- 🔷 頁尾 (Footer) -->
  <footer class="bg-[#0f172a] py-16 mt-auto border-t border-slate-800 relative z-20">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-start gap-10">
      <div class="md:w-1/2">
        <img src="/images/footer-logo.png" alt="iCPS Lab" class="h-14 md:h-20 w-auto mb-3 object-contain" onerror="this.style.display='none';" />
        <p class="text-sm text-blue-400 font-medium mb-4">智慧網宇實體系統實驗室</p>
        <p class="text-sm text-slate-400 leading-relaxed max-w-md">
          Intelligent Cyber-Physical Systems Laboratory <br/>
          國立高雄科技大學 (NKUST)
        </p>
      </div>
      <div class="md:w-1/2 flex flex-col md:items-end text-sm space-y-3">
        <h3 class="text-white font-semibold mb-2 tracking-wide uppercase text-xs">Contact Us</h3>
        <p class="flex items-center gap-2 text-slate-300"><span class="text-slate-500">📍</span> 國立高雄科技大學 (建工校區)</p>
        <p class="flex items-center gap-2 text-slate-300"><span class="text-slate-500">📞</span> 07-3814526 分機 15672</p>
        <p class="flex items-center gap-2 text-slate-300"><span class="text-slate-500">✉️</span> <a href="mailto:allenchang@nkust.edu.tw" class="hover:text-blue-400 transition">allenchang@nkust.edu.tw</a></p>
      </div>
    </div>
    
    <div class="max-w-7xl mx-auto px-6 mt-12 pt-6 border-t border-slate-800 flex flex-col lg:flex-row justify-between items-center gap-6 lg:gap-4">
      <div class="flex flex-col sm:flex-row items-center gap-2 sm:gap-4 text-center sm:text-left">
        <p class="text-xs text-slate-500 leading-normal">
          &copy; 2026 <span class="italic font-['Times_New_Roman',_Times,_serif] text-[1.15em]">i</span>CPS Lab, National Kaohsiung University of Science and Technology.
        </p>
        <p class="text-xs text-slate-500 hidden sm:block">|</p>
        <p class="text-xs text-slate-500">All rights reserved.</p>
      </div>

      <div class="flex items-center gap-2 bg-slate-800/50 px-3 py-1.5 rounded-md border border-slate-700 shadow-sm transition hover:border-slate-600">
        <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
        <span class="text-xs text-slate-400 font-medium tracking-wide">累積造訪人數</span>
        <span class="text-xs text-slate-600 mx-1">|</span>
        <span class="text-sm font-mono font-bold text-blue-400 tracking-wider" id="visitor-count">載入中...</span>
      </div>
    </div>
  </footer>

  <!-- 🔷 自定義動畫樣式 -->
  <style>
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(15px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    .animate-fade-in-up {
      animation: fadeInUp 0.6s ease-out forwards;
    }
  </style>

  <!-- 🔷 智慧訪客計數器邏輯 -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const initCounter = async () => {
        const counterEl = document.getElementById('visitor-count');
        if (!counterEl) return;

        const namespace = 'icpslab_site';
        const key = 'visits';
        const localCountKey = 'icps_saved_count';
        const lastVisitTimeKey = 'icps_last_visit_time';
        const TWENTY_FOUR_HOURS = 24 * 60 * 60 * 1000;

        let currentCount = localStorage.getItem(localCountKey) || '------';
        
        const lastVisitTime = localStorage.getItem(lastVisitTimeKey);
        const now = Date.now();
        const hasVisitedWithin24Hours = lastVisitTime && (now - parseInt(lastVisitTime, 10) < TWENTY_FOUR_HOURS);
        
        try {
          const url = `https://api.counterapi.dev/v1/${namespace}/${key}`;
          
          if (!hasVisitedWithin24Hours) {
            const response = await fetch(url + '/up');
            if (!response.ok) throw new Error('API 回應錯誤');
            
            const data = await response.json();
            currentCount = String(data.count).padStart(6, '0');
            
            localStorage.setItem(lastVisitTimeKey, now.toString());
            localStorage.setItem(localCountKey, currentCount);
            counterEl.textContent = currentCount;
            
          } else {
            try {
              const response = await fetch(url);
              if (response.ok) {
                const data = await response.json();
                currentCount = String(data.count).padStart(6, '0');
                localStorage.setItem(localCountKey, currentCount);
              }
            } catch (e) {
              console.warn('無法從伺服器獲取最新數字，已切換為本地暫存值');
            }
            counterEl.textContent = currentCount;
          }
          
        } catch (error) {
          console.error('計數器載入異常:', error);
          counterEl.textContent = currentCount;
        }
      };

      initCounter();
    });
  </script>

</body>
</html>