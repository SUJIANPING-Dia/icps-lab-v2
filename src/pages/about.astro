---
import "../styles/global.css";
---

<html lang="zh-TW" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/images/lab-logo.png" />
  <title>關於實驗室 | iCPS Lab 智慧網宇實體系統實驗室</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
</head>

<body class="bg-[#f8fafc] text-slate-800 font-sans antialiased selection:bg-blue-200 selection:text-blue-900 relative flex flex-col min-h-screen">

  <!-- ============================================================ -->
  <!-- 🔒 導覽列：原版不動                                          -->
  <!-- ============================================================ -->
  <nav class="w-full bg-white border-b border-slate-200 shadow-sm relative z-30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center justify-between py-3 md:py-4">
      <div class="flex items-center gap-3 sm:gap-6 lg:gap-8 min-w-0">
        <a href="https://www.nkust.edu.tw/" target="_blank" class="flex items-center shrink-0 transition-transform duration-300 hover:scale-105">
          <img src="/images/nkust-logo.png" alt="NKUST 國立高雄科技大學" class="h-6 sm:h-9 md:h-10 lg:h-11 w-auto object-contain" onerror="this.src='https://upload.wikimedia.org/wikipedia/zh/thumb/4/46/National_Kaohsiung_University_of_Science_and_Technology_logo.svg/800px-National_Kaohsiung_University_of_Science_and_Technology_logo.svg.png';" />
        </a>
        <div class="h-4 sm:h-6 md:h-8 border-l-[1.5px] border-slate-300/80 shrink-0 rounded-full"></div>
        <a href="/" class="flex items-center shrink-0 transition-transform duration-300 hover:scale-105">
          <img src="/images/sicp-logo.png" alt="iCPS Lab 智慧網宇實體系統實驗室" class="h-7 sm:h-11 md:h-12 lg:h-[3.25rem] w-auto object-contain" onerror="this.style.display='none';" />
        </a>
      </div>
      <div class="hidden md:flex space-x-8 text-sm font-bold text-slate-600 shrink-0 ml-4">
        <a href="/" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1"><span>首頁</span><span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Home</span></a>
        <a href="/about" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1"><span>關於 iCPS Lab</span><span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">About</span></a>
        <a href="/#news" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1"><span>最新消息</span><span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">News</span></a>
        <a href="/activities" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1"><span>活動花絮</span><span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Events</span></a>
        <a href="/#videos" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1"><span>影音專區</span><span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Media</span></a>
        <a href="/achievements" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1"><span>成果榮譽</span><span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Achievements</span></a>
        <a href="/members" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1"><span>實驗室成員</span><span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Members</span></a>
        <a href="/faq" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1"><span>常見問題</span><span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">FAQ</span></a>
      </div>
      <button id="mobile-menu-btn" class="md:hidden p-2 text-slate-600 hover:text-blue-800 transition focus:outline-none" aria-label="打開選單">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
    <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 w-full bg-white border-b border-slate-200 shadow-lg flex flex-col z-20">
      <a href="/" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">首頁</a>
      <a href="/about" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">關於 iCPS Lab</a>
      <a href="/#news" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">最新消息</a>
      <a href="/activities" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">活動花絮</a>
      <a href="/#videos" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">影音專區</a>
      <a href="/achievements" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">成果與榮譽</a>
      <a href="/members" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">實驗室成員</a>
      <a href="/faq" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">常見問題</a>
    </div>
  </nav>

  <!-- ============================================================ -->
  <!-- ✨ 頁面標題區 (Hero Banner) — 升級版                         -->
  <!-- ============================================================ -->
  <header class="hero-banner relative py-20 lg:py-28 text-center border-b-[5px] border-blue-700 overflow-hidden">
    <!-- 動態幾何背景 canvas -->
    <canvas id="hero-canvas" class="absolute inset-0 w-full h-full pointer-events-none z-0"></canvas>
    
    <!-- 漸層底色層 -->
    <div class="absolute inset-0 bg-gradient-to-br from-slate-950 via-[#0a1628] to-slate-900 z-0"></div>
    
    <!-- 藍色光暈 -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] bg-blue-600/20 rounded-full blur-[80px] z-[1] pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-[300px] h-[200px] bg-blue-800/15 rounded-full blur-[60px] z-[1] pointer-events-none"></div>
    
    <!-- 標題內容 -->
    <div class="relative z-10 max-w-3xl mx-auto px-4">
      <div class="hero-badge inline-flex items-center gap-2 bg-white/5 border border-white/10 text-blue-300 text-xs font-medium tracking-[0.2em] uppercase px-4 py-1.5 rounded-full mb-6 backdrop-blur-sm">
        <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse"></span>
        Intelligent Cyber-Physical Systems Laboratory
      </div>
      <h1 class="hero-title text-4xl md:text-6xl font-black text-white tracking-tight mb-4 leading-tight drop-shadow-xl">
        關於 <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-300 to-cyan-300">iCPS Lab</span>
      </h1>
      <p class="hero-sub text-slate-400 text-sm md:text-base font-medium tracking-[0.25em] uppercase mt-2">
        Bridging Technology &amp; Real-World Impact
      </p>
    </div>
  </header>

  <!-- ============================================================ -->
  <!-- ✨ 網站主體區域 — 升級版                                     -->
  <!-- ============================================================ -->
  <main class="flex-grow max-w-7xl mx-auto px-6 py-16 relative z-20 w-full overflow-hidden">

    <!-- 回首頁按鈕 -->
    <div class="mb-12 rv rv-left">
      <a href="/" class="inline-flex items-center text-sm font-semibold text-slate-500 hover:text-blue-700 transition-all duration-200 bg-white px-4 py-2 rounded-full shadow-sm border border-slate-200 hover:shadow-md hover:-translate-x-0.5 group">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5 transition-transform duration-200 group-hover:-translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
        返回首頁
      </a>
    </div>

    <!-- 垂直間距容器 -->
    <div class="space-y-28">

      <!-- =========================================================== -->
      <!-- 📌 區塊一：教授介紹                                         -->
      <!-- =========================================================== -->
      <section>
        <div class="section-label flex items-center gap-3 mb-12 rv rv-up">
          <div class="w-1.5 h-8 bg-gradient-to-b from-blue-500 to-blue-700 rounded-full"></div>
          <h3 class="text-2xl lg:text-3xl font-bold text-slate-800 tracking-tight">
            實驗室領航
            <span class="text-slate-400 font-light ml-3 text-xl lg:text-2xl">Principal Investigator</span>
          </h3>
        </div>
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <!-- 左側：教授照片 -->
          <div class="prof-img-wrap rv rv-left">
            <div class="relative w-full aspect-video rounded-2xl overflow-hidden shadow-2xl border border-slate-200/80 group">
              <img 
                class="w-full h-full absolute inset-0 object-cover object-center transition-transform duration-700 group-hover:scale-105" 
                src="/images/professor-chang.png" 
                alt="張萬榮 教授" 
                onerror="this.src='https://via.placeholder.com/800x450?text=Professor+Chang';" 
              />
              <!-- 底部漸層遮罩 -->
              <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <!-- 浮動標籤 -->
              <div class="absolute bottom-4 left-4 right-4 opacity-0 group-hover:opacity-100 transition-all duration-500 translate-y-2 group-hover:translate-y-0">
                <span class="inline-block bg-white/90 backdrop-blur-sm text-slate-800 text-xs font-bold px-3 py-1 rounded-full shadow">iCPS Lab Principal Investigator</span>
              </div>
            </div>
          </div>
          
          <!-- 右側：教授理念 -->
          <div class="flex flex-col justify-center h-full space-y-6 rv rv-right">
            <div>
              <h4 class="text-2xl font-bold text-slate-900 pb-3 border-b border-slate-100">
                張萬榮 教授 
                <span class="text-base font-normal text-slate-400 ml-2 font-mono">Wan-Jung Chang, Ph.D.</span>
              </h4>
            </div>
            
            <!-- 引言區塊 -->
            <blockquote class="relative pl-5 border-l-4 border-blue-500 bg-gradient-to-r from-blue-50 to-transparent py-4 pr-4 rounded-r-lg">
              <div class="absolute -top-2 -left-1 text-blue-200 text-5xl font-serif leading-none select-none">"</div>
              <p class="text-slate-700 leading-relaxed font-medium text-base lg:text-lg text-justify relative z-10">
                工程教育的價值在於探索未知，並將科技回饋社會。我們期許團隊不僅掌握前瞻技術，更能為臨床與產業提出切實可行的解方。
              </p>
            </blockquote>
            
            <p class="text-slate-600 leading-relaxed text-sm lg:text-base text-justify">
              張教授深耕 AIoT 與邊緣運算多年，在<strong class="text-slate-800">高科大電子工程系</strong>建構了高度跨域協作的研究環境。對外積極橋接醫療院所與科技大廠；對內致力於營造互助融洽的團隊氛圍，引導學生在紮實學理基礎上，將創意化為實體應用。
            </p>

            <div class="pt-2 flex flex-wrap gap-3">
              <a href="https://ec.nkust.edu.tw/p/404-1122-98302.php?Lang=zh-tw" target="_blank" rel="noopener noreferrer" 
                 class="btn-primary inline-flex items-center gap-2 text-white bg-slate-900 hover:bg-blue-700 font-semibold px-5 py-2.5 rounded-lg transition-all duration-300 shadow-sm hover:shadow-blue-700/30 hover:shadow-lg text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                查看完整簡歷
              </a>
              <a href="mailto:allenchang@nkust.edu.tw" 
                 class="btn-secondary inline-flex items-center gap-2 text-slate-700 bg-white border border-slate-200 hover:border-blue-300 hover:text-blue-700 hover:bg-blue-50 font-semibold px-5 py-2.5 rounded-lg transition-all duration-300 shadow-sm text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2-2v10a2 2 0 002 2z"/></svg>
                寄信聯繫教授
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- =========================================================== -->
      <!-- 📌 區塊二：願景                                             -->
      <!-- =========================================================== -->
      <section class="space-y-10">
        <!-- 願景區塊 -->
        <div class="vision-block relative bg-white rounded-2xl overflow-hidden shadow-sm rv rv-up">
          <!-- 左側藍色裝飾條 -->
          <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-gradient-to-b from-blue-500 via-blue-700 to-blue-900 rounded-l-2xl"></div>
          <div class="p-8 lg:p-12 pl-10 lg:pl-14">
            <div class="flex items-start gap-4 mb-5">
              <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-5 h-5 text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              </div>
              <h2 class="text-2xl lg:text-3xl font-bold text-slate-900 leading-snug tracking-tight">
                我們不只寫程式，<br class="hidden sm:block"/>更致力於解決真實世界的痛點。
              </h2>
            </div>
            <p class="text-slate-700 leading-relaxed text-base lg:text-lg mb-4 text-justify">
              <strong class="text-blue-800">智慧網宇實體系統實驗室 (iCPS Lab)</strong> 專注於打破學術研究與產業實務的界線。我們深度融合人工智慧 (AI)、物聯網 (AIoT) 與延展實境 (XR) 技術，將前端的感測數據與後端的雲邊緣運算無縫接軌，打造具備高度智慧化、自動化的虛實整合解決方案。
            </p>
            <p class="text-slate-500 leading-relaxed text-sm lg:text-base text-justify">
              從<strong class="text-slate-700">臨床醫療照護、高科技廠房的智能製造，到城市級的智慧交通系統</strong>，我們的技術皆已實際落地驗證。無論您是尋求技術突破的企業夥伴，還是渴望掌握前瞻科技的優秀學子，iCPS Lab 都是您實踐創新的最佳基地。
            </p>
          </div>
        </div>
      </section>

      <!-- =========================================================== -->
      <!-- 📌 區塊三：雙向對話                                         -->
      <!-- =========================================================== -->
      <section class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- 產醫合作 (深色) -->
        <div class="collab-card relative bg-gradient-to-br from-slate-900 to-[#0a1628] p-8 rounded-2xl shadow-xl overflow-hidden group rv rv-up">
          <!-- 裝飾圓 -->
          <div class="absolute -top-10 -right-10 w-40 h-40 bg-blue-600/20 rounded-full blur-2xl group-hover:bg-blue-500/30 transition-colors duration-700"></div>
          <div class="absolute bottom-0 left-0 w-32 h-32 bg-cyan-500/10 rounded-full blur-2xl"></div>
          
          <div class="relative z-10">
            <div class="w-12 h-12 bg-blue-500/20 border border-blue-400/30 rounded-xl flex items-center justify-center mb-6 text-2xl group-hover:bg-blue-500/30 transition-colors">🤝</div>
            <h3 class="text-2xl font-bold text-white mb-3">產醫跨域合作</h3>
            <div class="w-10 h-0.5 bg-blue-500 rounded mb-5 group-hover:w-20 transition-all duration-500"></div>
            <p class="text-slate-300 leading-relaxed mb-6 text-sm lg:text-base">
              我們具備豐富的產學合作與臨床場域驗證經驗，能為企業與醫院提供客製化的技術評估與系統開發。從概念驗證 (PoC) 到系統整合，我們是您最可靠的技術大腦。
            </p>
            <ul class="text-slate-300 space-y-3 mb-8 text-sm">
              <li class="flex items-center gap-2.5">
                <span class="w-5 h-5 bg-blue-500/20 border border-blue-400/40 rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-3 h-3 text-blue-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                </span>
                臨床痛點 AI 輔助系統開發
              </li>
              <li class="flex items-center gap-2.5">
                <span class="w-5 h-5 bg-blue-500/20 border border-blue-400/40 rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-3 h-3 text-blue-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                </span>
                智慧工廠產線自動化與瑕疵檢測
              </li>
              <li class="flex items-center gap-2.5">
                <span class="w-5 h-5 bg-blue-500/20 border border-blue-400/40 rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-3 h-3 text-blue-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                </span>
                前瞻技術轉移與聯合技術研發
              </li>
            </ul>
            <a href="mailto:allenchang@nkust.edu.tw" 
               class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-semibold px-5 py-2.5 rounded-lg transition-all duration-300 text-sm shadow-lg shadow-blue-900/40 hover:shadow-blue-600/40 hover:-translate-y-0.5">
              提案與洽詢合作
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </div>

        <!-- 給學生 (淺色) -->
        <div class="student-card relative bg-white border border-slate-100 p-8 rounded-2xl shadow-sm hover:shadow-xl overflow-hidden group rv rv-up rv-delay-200">
          <!-- 裝飾幾何 -->
          <div class="absolute top-0 right-0 w-40 h-40 bg-blue-50 rounded-full -translate-y-1/2 translate-x-1/2 group-hover:bg-blue-100 transition-colors duration-500"></div>
          
          <div class="relative z-10">
            <div class="w-12 h-12 bg-blue-100 text-blue-700 rounded-xl flex items-center justify-center mb-6 text-2xl group-hover:bg-blue-600 group-hover:text-white transition-all duration-300">🎓</div>
            <h3 class="text-2xl font-bold text-slate-900 mb-3">啟動研究生涯</h3>
            <div class="w-10 h-0.5 bg-blue-200 rounded mb-5 group-hover:w-20 group-hover:bg-blue-500 transition-all duration-500"></div>
            <p class="text-slate-600 leading-relaxed mb-6 text-sm lg:text-base">
              我們熱烈招收具備熱忱的博碩士與大學部專題生。在這裡，你將不只讀紙上理論，而是真正動手將技術變成解決真實問題的產品。
            </p>
            <ul class="text-slate-700 space-y-3 mb-8 text-sm font-medium">
              <li class="flex items-center gap-2.5">
                <span class="w-5 h-5 bg-blue-50 border border-blue-200 rounded-full flex items-center justify-center shrink-0 group-hover:bg-blue-600 group-hover:border-blue-600 transition-colors duration-300">
                  <svg class="w-3 h-3 text-blue-600 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                </span>
                扎實訓練：從演算法開發到系統落地
              </li>
              <li class="flex items-center gap-2.5">
