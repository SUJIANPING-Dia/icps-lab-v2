---
import "../styles/global.css";

let activities = [];

try {
  const cloudName = import.meta.env.CLOUDINARY_CLOUD_NAME;
  const apiKey = import.meta.env.CLOUDINARY_API_KEY;
  const apiSecret = import.meta.env.CLOUDINARY_API_SECRET;

  const response = await fetch(`https://api.cloudinary.com/v1_1/${cloudName}/resources/search`, {
    method: 'POST',
    headers: {
      'Authorization': `Basic ${btoa(apiKey + ':' + apiSecret)}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      expression: '', // 抓取全部照片，由前端進行篩選
      with_field: 'context',
      sort_by: [{ created_at: 'desc' }],
      max_results: 500
    })
  });

  const result = await response.json();

  if (result.resources) {
    const albumsMap = new Map();

    result.resources.forEach(img => {
      // 處理 Cloudinary 虛擬資料夾的問題
      let folderPath = img.asset_folder || img.folder || "";

      if (folderPath.startsWith('events/')) {
        if (folderPath.endsWith('/')) folderPath = folderPath.slice(0, -1);
        
        const albumId = folderPath.split('/').pop();

        if (albumId && albumId !== 'events' && !albumsMap.has(albumId)) {
          albumsMap.set(albumId, {
            id: albumId,
            title: img.context?.custom?.title || albumId,
            date: img.created_at.substring(0, 10).replace(/-/g, '.'),
            img: img.secure_url.replace('/upload/', '/upload/f_auto,q_auto/')
          });
        }
      }
    });

    activities = Array.from(albumsMap.values());
  }
} catch (error) {
  console.error("Cloudinary API 獲取失敗:", error);
}
