---
import "../styles/global.css";

// ==========================================
// 🔹 預設的 Q&A 資料區 (您可以在這裡自由新增/修改問題與解答)
// ==========================================
const faqs = [
  {
    category: "關於實驗室",
    items: [
      {
        question: "iCPS Lab 主要的研究領域是什麼？",
        answer: "本實驗室 (Intelligent Cyber-Physical Systems Laboratory) 主要專注於三大領域：AI 人工智慧、Healthcare 智慧醫療，以及 Smart Manufacturing 智慧製造。我們致力於將物聯網 (IoT)、邊緣運算與深度學習技術落地應用於實際的醫療與工業場域中。"
      },
      {
        question: "實驗室的指導教授是誰？",
        answer: "本實驗室由 張萬榮 教授指導。張教授專精於雲端與智慧物聯網系統、人工智慧醫療聯網系統 (MIoT) 以及人工智慧製造聯網系統 (IIoT) 等領域。詳細學經歷可至「實驗室成員」頁面查看。"
      },
      {
        question: "實驗室的地點在哪裡？",
        answer: "我們位於 國立高雄科技大學 (建工校區)。詳細位置與聯絡方式請見頁面底部的 Contact Us 資訊。"
      }
    ]
  },
  {
    category: "招生與專題",
    items: [
      {
        question: "請問實驗室目前有在招收新生嗎？",
        answer: "是的！我們持續招募對 AIoT、智慧醫療、智慧製造有熱忱的博士生、碩士生以及大學部專題生。也十分歡迎外籍生 (International Students) 加入我們的研究團隊。"
      },
      {
        question: "大學部學生想加入實驗室專題，需要具備什麼基礎？",
        answer: "我們歡迎有熱忱的同學！如果能具備基礎的 Python 程式能力、對機器學習 (Machine Learning) 或物聯網 (IoT) 有初步認識會更好。最重要的是要有願意學習新技術與團隊合作的態度。"
      },
      {
        question: "研究生在實驗室會參與產學合作計畫嗎？",
        answer: "非常多！我們的研究高度強調「落地應用」，因此研究生在學期間常有機會參與醫院 (如：智慧病房、輔助診斷) 或業界 (如：產線瑕疵檢測、智慧製造) 的實際產學合作計畫，累積寶貴的實戰經驗。"
      }
    ]
  },
  {
    category: "設備與資源",
    items: [
      {
        question: "實驗室提供哪些硬體設備供學生使用？",
        answer: "為因應 AI 運算需求，實驗室配備有多台高效能 GPU 伺服器 (如 RTX 3090/4090 等) 供模型訓練使用。此外，也備有各類邊緣運算裝置 (Jetson Nano/Xavier)、深度攝影機 (ToF Sensor)、熱影像儀以及各種 IoT 感測模組供開發測試。"
      },
      {
        question: "實驗室有提供參加研討會的補助嗎？",
        answer: "鼓勵學生發表論文是我們的宗旨之一。只要論文被國內外知名學術研討會或期刊接受，實驗室皆會依規定提供相關的註冊費、差旅費等補助，詳細辦法可於加入後向專任助理詢問。"
      }
    ]
  }
];
---

<html lang="zh-TW" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/images/lab-logo.png" />
  <title>常見問題 FAQ | iCPS Lab 智慧網宇實體系統實驗室</title>
</head>

<body class="bg-[#f8fafc] text-slate-800 font-sans antialiased selection:bg-blue-200 selection:text-blue-900 relative">

  <!-- 🔷 頂部導覽列 (Navbar) -->
  <nav class="w-full bg-white border-b border-slate-200 shadow-sm relative z-30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center justify-between py-3 md:py-4">
      <div class="flex items-center gap-3 sm:gap-6 lg:gap-8 min-w-0">
        <!-- 高科大 Logo -->
        <a href="https://www.nkust.edu.tw/" target="_blank" class="flex items-center shrink-0 transition-transform duration-300 hover:scale-105">
          <img src="/images/nkust-logo.png" alt="NKUST 國立高雄科技大學" class="h-6 sm:h-9 md:h-10 lg:h-11 w-auto object-contain" onerror="this.src='https://upload.wikimedia.org/wikipedia/zh/thumb/4/46/National_Kaohsiung_University_of_Science_and_Technology_logo.svg/800px-National_Kaohsiung_University_of_Science_and_Technology_logo.svg.png';" />
        </a>
        <!-- 分隔線 -->
        <div class="h-4 sm:h-6 md:h-8 border-l-[1.5px] border-slate-300/80 shrink-0 rounded-full"></div>
        <!-- 實驗室 Logo -->
        <a href="/" class="flex items-center shrink-0 transition-transform duration-300 hover:scale-105">
          <img src="/images/sicp-logo.png" alt="iCPS Lab 智慧網宇實體系統實驗室" class="h-7 sm:h-11 md:h-12 lg:h-[3.25rem] w-auto object-contain" onerror="this.style.display='none';" />
        </a>
      </div>

      <!-- 右側導覽連結 -->
      <div class="hidden md:flex space-x-8 text-sm font-bold text-slate-600 shrink-0 ml-4">
        <a href="/#about" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>關於 iCPS Lab</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">About</span>
        </a>
        <a href="/#news" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>最新消息</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">News</span>
        </a>
        <a href="/#activities" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>活動花絮</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Events</span>
        </a>
        <a href="/#videos" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>影音專區</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Media</span>
        </a>
        <a href="/members" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>實驗室成員</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Members</span>
        </a>
        <a href="/faq" class="group flex flex-col items-center text-blue-800 transition border-b-2 border-blue-800 pb-1">
          <span>常見問題</span>
          <span class="text-xs font-normal text-blue-600">FAQ</span>
        </a>
      </div>

      <!-- 手機版漢堡選單按鈕 -->
      <button id="mobile-menu-btn" class="md:hidden p-2 text-slate-600 hover:text-blue-800 transition focus:outline-none" aria-label="打開選單">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- 手機版下拉選單 -->
    <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 w-full bg-white border-b border-slate-200 shadow-lg flex flex-col z-20">
      <a href="/#about" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800 border-b border-slate-100">關於 iCPS Lab</a>
      <a href="/#news" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800 border-b border-slate-100">最新消息</a>
      <a href="/#activities" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800 border-b border-slate-100">活動花絮</a>
      <a href="/#videos" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800 border-b border-slate-100">影音專區</a>
      <a href="/members" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800 border-b border-slate-100">實驗室成員</a>
      <a href="/faq" class="block px-6 py-4 text-blue-800 bg-blue-50 font-bold hover:bg-blue-100">常見問題</a>
    </div>
  </nav>

  <!-- 🔷 頁面標題區 -->
  <header class="bg-[#0f172a] py-14 text-center border-b-4 border-blue-700 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] pointer-events-none"></div>
    <div class="relative z-10">
      <h1 class="text-3xl md:text-4xl font-extrabold text-white tracking-widest mb-3">常見問題</h1>
      <p class="text-slate-300 text-sm font-light tracking-wider uppercase">Frequently Asked Questions</p>
    </div>
  </header>

  <!-- 🔷 網站主體區域 -->
  <main class="max-w-4xl mx-auto px-6 py-16 relative z-20 min-h-[60vh]">

    <!-- 回首頁按鈕 -->
    <div class="mb-10 text-center md:text-left">
      <a href="/" class="inline-flex items-center text-sm font-bold text-slate-500 hover:text-blue-700 transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
        返回首頁
      </a>
    </div>

    <!-- 簡介文字 -->
    <div class="text-center mb-12">
      <h2 class="text-2xl font-bold text-slate-800 mb-4">有任何疑問嗎？</h2>
      <p class="text-slate-600 text-sm md:text-base max-w-2xl mx-auto leading-relaxed">
        這裡整理了關於加入實驗室、研究方向以及資源設備的常見問題。<br class="hidden sm:block"/>
        如果找不到您需要的答案，歡迎隨時透過頁尾的聯絡方式與我們聯繫。
      </p>
    </div>

    <!-- Q&A 手風琴列表 -->
    <div class="space-y-12">
      {faqs.map((faqGroup, groupIndex) => (
        <div>
          <!-- 類別標題 -->
          <h3 class="text-xl font-bold text-blue-800 mb-6 border-b-2 border-slate-200 pb-2 flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            {faqGroup.category}
          </h3>
          
          <div class="space-y-4">
            {faqGroup.items.map((item, itemIndex) => {
              const uniqueId = `faq-${groupIndex}-${itemIndex}`;
              return (
                <div class="bg-white border border-slate-200 rounded-sm overflow-hidden shadow-sm hover:border-blue-300 transition duration-300">
                  <!-- 問題按鈕 (點擊展開/收合) -->
                  <button 
                    class="faq-btn w-full px-6 py-5 text-left flex justify-between items-center focus:outline-none focus:bg-slate-50 group"
                    aria-expanded="false"
                    aria-controls={uniqueId}
                  >
                    <span class="font-bold text-slate-800 text-[15px] sm:text-base group-hover:text-blue-700 transition pr-4">
                      {item.question}
                    </span>
                    <span class="faq-icon text-slate-400 group-hover:text-blue-600 transition shrink-0 transform duration-300">
                      <!-- 預設顯示的「+」圖示 -->
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    </span>
                  </button>
                  
                  <!-- 解答內容 (預設隱藏) -->
                  <div id={uniqueId} class="faq-content hidden bg-slate-50 border-t border-slate-100">
                    <div class="px-6 py-5 text-slate-600 text-sm sm:text-[15px] leading-relaxed">
                      {item.answer}
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>

  </main>

  <!-- 🔷 頁尾 (Footer) -->
  <footer class="bg-[#0f172a] py-16 mt-12 border-t border-slate-800 relative z-20">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-start gap-10">
      <div class="md:w-1/2">
        <img src="/images/footer-logo.png" alt="iCPS Lab" class="h-14 md:h-20 w-auto mb-3 object-contain" onerror="this.style.display='none';" />
        <p class="text-sm text-blue-400 font-medium mb-4">智慧網宇實體系統實驗室</p>
        <p class="text-sm text-slate-400 leading-relaxed max-w-md">
          Intelligent Cyber-Physical Systems Laboratory <br/>
          國立高雄科技大學 (NKUST)
        </p>
      </div>
      <div class="md:w-1/2 flex flex-col md:items-end text-sm space-y-3">
        <h3 class="text-white font-semibold mb-2 tracking-wide uppercase text-xs">Contact Us</h3>
        <p class="flex items-center gap-2 text-slate-300"><span class="text-slate-500">📍</span> 國立高雄科技大學 (建工校區)</p>
        <p class="flex items-center gap-2 text-slate-300"><span class="text-slate-500">📞</span> 07-3814526 分機 15672</p>
        <p class="flex items-center gap-2 text-slate-300"><span class="text-slate-500">✉️</span> <a href="mailto:allenchang@nkust.edu.tw" class="hover:text-blue-400 transition">allenchang@nkust.edu.tw</a></p>
      </div>
    </div>
    
    <div class="max-w-7xl mx-auto px-6 mt-12 pt-6 border-t border-slate-800 flex flex-col lg:flex-row justify-between items-center gap-6 lg:gap-4">
      <div class="flex flex-col sm:flex-row items-center gap-2 sm:gap-4 text-center sm:text-left">
        <p class="text-xs text-slate-500 leading-normal">
          &copy; 2026 <span class="italic font-['Times_New_Roman',_Times,_serif] text-[1.15em]">i</span>CPS Lab, National Kaohsiung University of Science and Technology.
        </p>
        <p class="text-xs text-slate-500 hidden sm:block">|</p>
        <p class="text-xs text-slate-500">All rights reserved.</p>
      </div>

      <div class="flex items-center gap-2 bg-slate-800/50 px-3 py-1.5 rounded-md border border-slate-700 shadow-sm transition hover:border-slate-600">
        <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
        <span class="text-xs text-slate-400 font-medium tracking-wide">累積造訪人數</span>
        <span class="text-xs text-slate-600 mx-1">|</span>
        <span class="text-sm font-mono font-bold text-blue-400 tracking-wider" id="visitor-count">載入中...</span>
      </div>
    </div>
  </footer>

  <!-- 🔷 控制 Q&A 手風琴、手機導覽列、計數器的 JavaScript -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      
      // --- 0. 手機版導覽列 (漢堡選單) 邏輯 ---
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const hamburgerIcon = document.getElementById('hamburger-icon');

      if (mobileMenuBtn && mobileMenu && hamburgerIcon) {
        mobileMenuBtn.addEventListener('click', () => {
          const isHidden = mobileMenu.classList.contains('hidden');
          if (isHidden) {
            mobileMenu.classList.remove('hidden');
            hamburgerIcon.setAttribute('d', 'M6 18L18 6M6 6l12 12');
          } else {
            mobileMenu.classList.add('hidden');
            hamburgerIcon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
          }
        });

        const mobileLinks = mobileMenu.querySelectorAll('a');
        mobileLinks.forEach(link => {
          link.addEventListener('click', () => {
            mobileMenu.classList.add('hidden');
            hamburgerIcon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
          });
        });
      }

      // --- 1. Q&A 手風琴 (Accordion) 邏輯 ---
      const faqBtns = document.querySelectorAll('.faq-btn');

      faqBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const contentId = btn.getAttribute('aria-controls');
          const content = document.getElementById(contentId);
          const icon = btn.querySelector('.faq-icon svg');
          const isExpanded = btn.getAttribute('aria-expanded') === 'true';

          // 關閉目前正在查看的 Q&A
          if (isExpanded) {
            btn.setAttribute('aria-expanded', 'false');
            content.classList.add('hidden');
            // 恢復成 "+" 圖示
            icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>';
            btn.classList.remove('bg-slate-50', 'text-blue-800');
          } 
          // 展開點擊的 Q&A
          else {
            btn.setAttribute('aria-expanded', 'true');
            content.classList.remove('hidden');
            // 變成 "-" 關閉圖示
            icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"></path>';
            btn.classList.add('bg-slate-50', 'text-blue-800');
          }
        });
      });

      // --- 2. 智慧訪客計數器邏輯 ---
      const initCounter = async () => {
        const counterEl = document.getElementById('visitor-count');
        if (!counterEl) return;

        const namespace = 'icpslab_site';
        const key = 'visits';
        const localCountKey = 'icps_saved_count';
        const lastVisitTimeKey = 'icps_last_visit_time';
        const TWENTY_FOUR_HOURS = 24 * 60 * 60 * 1000;

        let currentCount = localStorage.getItem(localCountKey) || '------';
        
        const lastVisitTime = localStorage.getItem(lastVisitTimeKey);
        const now = Date.now();
        const hasVisitedWithin24Hours = lastVisitTime && (now - parseInt(lastVisitTime, 10) < TWENTY_FOUR_HOURS);
        
        try {
          const url = `https://api.counterapi.dev/v1/${namespace}/${key}`;
          
          if (!hasVisitedWithin24Hours) {
            const response = await fetch(url + '/up');
            if (!response.ok) throw new Error('API 回應錯誤');
            
            const data = await response.json();
            currentCount = String(data.count).padStart(6, '0');
            
            localStorage.setItem(lastVisitTimeKey, now.toString());
            localStorage.setItem(localCountKey, currentCount);
            counterEl.textContent = currentCount;
            
          } else {
            try {
              const response = await fetch(url);
              if (response.ok) {
                const data = await response.json();
                currentCount = String(data.count).padStart(6, '0');
                localStorage.setItem(localCountKey, currentCount);
              }
            } catch (e) {
              console.warn('無法從伺服器獲取最新數字，已切換為本地暫存值');
            }
            counterEl.textContent = currentCount;
          }
          
        } catch (error) {
          console.error('計數器載入異常:', error);
          counterEl.textContent = currentCount;
        }
      };

      initCounter();
    });
  </script>

</body>
</html>