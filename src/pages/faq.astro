  <!-- 🔷 控制邏輯的 JavaScript -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const hamburgerIcon = document.getElementById('hamburger-icon');

      if (mobileMenuBtn && mobileMenu && hamburgerIcon) {
        mobileMenuBtn.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
          hamburgerIcon.setAttribute('d', mobileMenu.classList.contains('hidden') ? 'M4 6h16M4 12h16M4 18h16' : 'M6 18L18 6M6 6l12 12');
        });
      }

      const setupAccordions = () => {
        const faqBtns = document.querySelectorAll('.faq-btn');
        faqBtns.forEach(btn => {
          const newBtn = btn.cloneNode(true);
          btn.parentNode.replaceChild(newBtn, btn);
          
          newBtn.addEventListener('click', () => {
            const contentId = newBtn.getAttribute('aria-controls');
            const content = document.getElementById(contentId);
            const icon = newBtn.querySelector('.faq-icon svg');
            const isExpanded = newBtn.getAttribute('aria-expanded') === 'true';

            if (isExpanded) {
              newBtn.setAttribute('aria-expanded', 'false');
              content.classList.add('hidden');
              icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>';
              newBtn.classList.remove('bg-slate-50', 'text-blue-800');
            } else {
              newBtn.setAttribute('aria-expanded', 'true');
              content.classList.remove('hidden');
              icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"></path>';
              newBtn.classList.add('bg-slate-50', 'text-blue-800');
            }
          });
        });
      };
      setupAccordions();

      const tabBtns = document.querySelectorAll('.faq-tab-btn');
      const categoryGroups = document.querySelectorAll('.faq-category-group');
      let currentActiveTabTarget = 'category-0'; 

      const switchTab = (targetId) => {
        currentActiveTabTarget = targetId;
        
        tabBtns.forEach(btn => {
          if (btn.getAttribute('data-target') === targetId) {
            btn.className = "faq-tab-btn flex-shrink-0 lg:w-full text-left px-5 py-3 rounded-lg text-[15px] font-bold transition-all duration-200 border border-transparent bg-blue-600 text-white shadow-md";
          } else {
            btn.className = "faq-tab-btn flex-shrink-0 lg:w-full text-left px-5 py-3 rounded-lg text-[15px] font-bold transition-all duration-200 border border-transparent bg-white text-slate-600 hover:bg-blue-50 hover:text-blue-800 border-slate-200";
          }
        });

        categoryGroups.forEach(group => {
          if (group.id === targetId) {
            group.classList.remove('hidden');
            group.classList.remove('fade-in');
            void group.offsetWidth; 
            group.classList.add('fade-in');
          } else {
            group.classList.add('hidden');
          }
        });
      };

      tabBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          switchTab(btn.getAttribute('data-target'));
          if(searchInput.value.trim() !== '') {
             clearSearchBtn.click();
          }
        });
      });

      const searchInput = document.getElementById('faq-search-input');
      const clearSearchBtn = document.getElementById('clear-search');
      const noResultsMsg = document.getElementById('no-results-msg');
      const sidebar = document.getElementById('faq-sidebar');

      const performSearch = (searchTerm) => {
        searchTerm = searchTerm.toLowerCase().trim();
        let hasAnyResult = false;

        if (searchTerm === '') {
          clearSearchBtn.classList.add('hidden');
          sidebar.classList.remove('opacity-50', 'pointer-events-none'); 
          noResultsMsg.classList.add('hidden');
          
          document.querySelectorAll('.faq-item').forEach(item => item.classList.remove('hidden'));
          switchTab(currentActiveTabTarget); 
          return;
        }

        clearSearchBtn.classList.remove('hidden');
        sidebar.classList.add('opacity-50', 'pointer-events-none'); 

        categoryGroups.forEach(group => {
          let hasResultInGroup = false;
          const items = group.querySelectorAll('.faq-item');
          
          items.forEach(item => {
            const q = item.getAttribute('data-question');
            const a = item.getAttribute('data-answer');
            
            if (q.includes(searchTerm) || a.includes(searchTerm)) {
              item.classList.remove('hidden');
              hasResultInGroup = true;
              hasAnyResult = true;
            } else {
              item.classList.add('hidden');
            }
          });

          if (hasResultInGroup) {
            group.classList.remove('hidden');
            group.classList.add('fade-in');
          } else {
            group.classList.add('hidden');
          }
        });

        if (!hasAnyResult) {
          noResultsMsg.classList.remove('hidden');
        } else {
          noResultsMsg.classList.add('hidden');
        }
      };

      searchInput.addEventListener('input', (e) => {
        performSearch(e.target.value);
      });

      clearSearchBtn.addEventListener('click', () => {
        searchInput.value = '';
        searchInput.focus();
        performSearch('');
      });

      const initCounter = async () => {
        const counterEl = document.getElementById('visitor-count');
        if (!counterEl) return;
        counterEl.textContent = '1,234'; 
      };
      initCounter();

    });
  </script>

</body>
