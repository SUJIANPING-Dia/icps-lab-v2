  <style is:global>
    /* =====================================================
       ✨ 動畫系統 v2 — Scroll Reveal + 頁籤過渡
    ===================================================== */

    /* --- Scroll Reveal 基底 --- */
    [data-rv] {
      opacity: 0;
      transition:
        opacity  0.7s cubic-bezier(0.22, 1, 0.36, 1),
        transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    }
    [data-rv="up"]    { transform: translateY(32px); }
    [data-rv="left"]  { transform: translateX(-32px); }
    [data-rv="right"] { transform: translateX(32px); }
    [data-rv="fade"]  { transform: none; }
    [data-rv="zoom"]  { transform: scale(0.97); }

    [data-rv].rv-visible {
      opacity: 1;
      transform: translate(0, 0) scale(1);
    }

    /* 延遲 helpers（套在子元素上） */
    .rv-d1 { transition-delay: 80ms !important; }
    .rv-d2 { transition-delay: 160ms !important; }
    .rv-d3 { transition-delay: 240ms !important; }
    .rv-d4 { transition-delay: 320ms !important; }
    .rv-d5 { transition-delay: 400ms !important; }

    /* --- 頁籤內容 — 切換動畫 --- */
    .tab-panel {
      display: none;
    }
    .tab-panel.tab-active {
      display: block;
      animation: tabEnter 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    @keyframes tabEnter {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* --- 卡片 hover glow --- */
    .member-card {
      transition: box-shadow 0.3s ease, border-color 0.3s ease, transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .member-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 28px -4px rgba(59, 130, 246, 0.13), 0 2px 8px -2px rgba(0,0,0,0.06);
      border-color: #bfdbfe;
    }

    /* 大學部專題卡特有 hover */
    .project-card {
      transition: box-shadow 0.3s ease, border-color 0.3s ease, transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .project-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 28px -4px rgba(59, 130, 246, 0.13);
      border-color: #93c5fd;
    }

    /* 助理卡片 avatar hover */
    .assistant-card:hover .assistant-avatar {
      box-shadow: 0 0 0 3px #bfdbfe;
    }
    .assistant-avatar {
      transition: box-shadow 0.3s ease;
    }

    /* 教授卡片研究興趣列 hover */
    .interest-row {
      transition: background 0.2s ease;
      border-radius: 6px;
      padding: 6px 8px;
      margin: -6px -8px;
    }
    .interest-row:hover {
      background: #f1f5f9;
    }

    /* 頁籤按鈕下底線滑動效果 */
    .tab-btn {
      position: relative;
      transition: color 0.25s ease;
    }
    .tab-btn::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      right: 0;
      height: 2px;
      background: #1d4ed8;
      border-radius: 2px 2px 0 0;
      transform: scaleX(0);
      transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .tab-btn.tab-active-style::after { transform: scaleX(1); }

    /* 成員照片懸停縮放 */
    .avatar-zoom {
      transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .member-card:hover .avatar-zoom,
    .project-card:hover .avatar-zoom {
      transform: scale(1.05);
    }

    /* 年度標題進場線 */
    .year-divider-line {
      flex: 1;
      height: 1px;
      background: linear-gradient(to right, #e2e8f0, transparent);
    }
  </style>
</head>

