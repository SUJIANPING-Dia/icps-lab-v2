---
import "../styles/global.css";

// ==========================================
// 🔹 實驗室成員資料區 (新增成員只需在這裡加入)
// ==========================================
// 👇 專任助理調整為 3 位，將原本單一的 desc 拆分為職稱 (title) 與多項工作職掌 (duties)
const assistants = [
  { 
    name: "林穎琪", 
    title: "專任經理",
    duties: ["實驗室相關業務", "公部門計畫進度與經費管控", "產學合作進度管控", "勞動部計畫進度管控", "公文收發與行政庶務", "臨時交辦任務"], 
    email: "yingchi2025@nkust.edu.tw", 
    ext: "07-3814526 #15650", 
    img: "/images/S1.JPG" 
  },
  { 
    name: "孫婉怡", 
    title: "專任資深經理",
    duties: ["公部門計畫進度與經費管控", "協助執行勞動部「AI智慧製造產業人才培訓據點」計畫", "公文收發與行政庶務", "臨時交辦任務"], 
    email: "avasun33@nkust.edu.tw", 
    ext: "07-3814526 #15650", 
    img: "/images/S2.JPG" 
  },
  { 
    name: "邱于菁", 
    title: "專任經理",
    duties: ["勞動部「AI智慧製造產業人才培訓據點」計畫(聯絡窗口)", "公文收發與行政庶務", "臨時交辦任務"], 
    email: "ycc0613@nkust.edu.tw", 
    ext: "07-3814526 #15678", 
    img: "/images/S3.jpg" 
  }
];

// 👇 博士班目前無成員，清空陣列
const phds = [];

// 👇 碩士生調整為 7 人
const masters = [
  { name: "賴穎寬", desc: "基於人工智慧低解析熱影像骨幹辨識技術之精神病患自我傷害行為照護系統", img: "/images/A1.jpg" },
  { name: "許庭瑄", desc: "基於ToF感測器之人體姿態日常行為辨識模型", img: "/images/A2.jpg" },
  { name: "陳閔昱", desc: "中外耳病灶識別暨臨床診斷報告自動生成系統", img: "/images/A3.jpg" },
  { name: "張鈞翔", desc: "精神病房隔離室病患之自我傷害行為辨識暨護理紀錄自動生成系統", img: "/images/A4.jpg" },
  { name: "李家馨", desc: "基於熱影像與ToF感測器之翻身拍背系統", img: "/images/A5.jpg" },
  { name: "陳冠廷", desc: "基於yolo物件辨識之舌肌復健遊戲平台", img: "/images/A6.jpg" },
  { name: "鍾詩威", desc: "智慧型手術器械辨識與教育訓練平台", img: "/images/A7.jpg" }
];

// 👇 大學部調整為 20 人
const undergrads = [
  { name: "蔡一銘", desc: "FtMirror" },
  { name: "林詩婷", desc: "FtMirror" },
  { name: "許峻銘", desc: "FtMirror" },

  { name: "王柏鑑", desc: "手術器械辨識" },
  { name: "林傳興", desc: "手術器械辨識" },
  { name: "林建宇", desc: "手術器械辨識" },

  { name: "紀政佑", desc: "iReflex" },
  { name: "李政華", desc: "iReflex" },
  { name: "張德堯", desc: "iReflex" },
  { name: "林竣宇", desc: "iReflex" },
  { name: "梁書毓", desc: "iReflex" },

  { name: "陳品勳", desc: "iMP Viewer" },
  { name: "李沛琪", desc: "iMP Viewer" },
  { name: "吳亮廷", desc: "iMP Viewer" },

  { name: "謝修瑜", desc: "CUP周圍電容瑕疵辨識" },
  { name: "楊宗翰", desc: "CUP周圍電容瑕疵辨識" },
  { name: "丁維暘", desc: "CUP周圍電容瑕疵辨識" },
  { name: "藍信安", desc: "CUP周圍電容瑕疵辨識" },
  { name: "胡景翔", desc: "CUP周圍電容瑕疵辨識" }
];

// 👇 外籍生目前無成員，清空陣列
const internationals = [];

---

<html lang="zh-TW" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/images/lab-logo.png" />
  <title>實驗室成員 | iCPS Lab 智慧網宇實體系統實驗室</title>
</head>

<body class="bg-[#f8fafc] text-slate-800 font-sans antialiased selection:bg-blue-200 selection:text-blue-900 relative">

  <!-- 🔷 頂部導覽列 (Navbar) -->
  <nav class="w-full bg-white border-b border-slate-200 shadow-sm relative z-30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center justify-between py-3 md:py-4">
      <div class="flex items-center gap-3 sm:gap-6 lg:gap-8 min-w-0">
        <!-- 高科大 Logo -->
        <a href="https://www.nkust.edu.tw/" target="_blank" class="flex items-center shrink-0 transition-transform duration-300 hover:scale-105">
          <img src="/images/nkust-logo.png" alt="NKUST 國立高雄科技大學" class="h-6 sm:h-9 md:h-10 lg:h-11 w-auto object-contain" onerror="this.src='https://upload.wikimedia.org/wikipedia/zh/thumb/4/46/National_Kaohsiung_University_of_Science_and_Technology_logo.svg/800px-National_Kaohsiung_University_of_Science_and_Technology_logo.svg.png';" />
        </a>
        <!-- 分隔線 -->
        <div class="h-4 sm:h-6 md:h-8 border-l-[1.5px] border-slate-300/80 shrink-0 rounded-full"></div>
        <!-- 實驗室 Logo -->
        <a href="/" class="flex items-center shrink-0 transition-transform duration-300 hover:scale-105">
          <img src="/images/sicp-logo.png" alt="iCPS Lab 智慧網宇實體系統實驗室" class="h-7 sm:h-11 md:h-12 lg:h-[3.25rem] w-auto object-contain" onerror="this.style.display='none';" />
        </a>
      </div>

      <!-- 右側導覽連結 -->
      <div class="hidden md:flex space-x-8 text-sm font-bold text-slate-600 shrink-0 ml-4">
        <a href="/#news" class="hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">最新消息</a>
        <a href="/#videos" class="hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">影音專區</a>
        <a href="/members" class="text-blue-800 border-b-2 border-blue-800 pb-1">實驗室成員</a>
      </div>
    </div>
  </nav>

  <!-- 🔷 頁面標題區 -->
  <header class="bg-[#0f172a] py-14 text-center border-b-4 border-blue-700 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] pointer-events-none"></div>
    <div class="relative z-10">
      <h1 class="text-3xl md:text-4xl font-extrabold text-white tracking-widest mb-3">實驗室成員</h1>
      <p class="text-slate-300 text-sm font-light tracking-wider uppercase">Laboratory Members</p>
    </div>
  </header>

  <!-- 🔷 網站主體區域 -->
  <main class="max-w-7xl mx-auto px-6 py-16 relative z-20 min-h-screen">

    <!-- 回首頁按鈕 -->
    <div class="mb-10">
      <a href="/" class="inline-flex items-center text-sm font-bold text-slate-500 hover:text-blue-700 transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
        返回首頁
      </a>
    </div>

    <div class="space-y-16">
      
      <!-- 🔹 專任助理 (最上層 - 最大張圖卡) -->
      <div>
        <h3 class="text-xl font-bold text-slate-800 mb-6 border-l-4 border-slate-300 pl-3">專任助理 Research Assistants</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {assistants.map((person) => (
            <div class="bg-white border border-slate-200 p-5 flex flex-col sm:flex-row items-start gap-5 hover:shadow-md hover:border-blue-300 transition rounded-sm">
              <img src={person.img} alt={person.name} class="w-16 h-16 sm:w-20 sm:h-20 rounded-full object-cover bg-slate-100 border border-slate-200 shrink-0 mt-1" onerror="this.src='/images/default-avatar.png';" />
              
              <div class="flex-1 w-full">
                <div class="mb-4">
                  <h4 class="font-bold text-slate-900 text-lg leading-tight">{person.name}</h4>
                  <span class="inline-block mt-1.5 text-[11px] font-bold tracking-widest text-blue-700 bg-blue-50 px-2 py-0.5 rounded border border-blue-100">
                    {person.title}
                  </span>
                </div>
                
                <div class="mb-4">
                  <p class="text-xs font-bold text-slate-500 mb-2 flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path></svg>
                    主要工作職掌
                  </p>
                  <ul class="space-y-1.5">
                    {person.duties.map(duty => (
                      <li class="text-[13px] text-slate-600 flex items-start gap-2">
                        <span class="text-blue-400 mt-[3px] text-[10px]">●</span>
                        <span class="leading-snug">{duty}</span>
                      </li>
                    ))}
                  </ul>
                </div>
                
                <div class="space-y-2 pt-4 border-t border-slate-100 text-[13px] text-slate-600">
                  <p class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-slate-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    <a href={`mailto:${person.email}`} class="hover:text-blue-600 truncate transition" title={person.email}>{person.email}</a>
                  </p>
                  <p class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-slate-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                    校內分機：{person.ext}
                  </p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <hr class="border-slate-200" />

      <!-- 🔹 學生 (使用頁籤分類) -->
      <div>
        <h3 class="text-xl font-bold text-slate-800 mb-6 border-l-4 border-slate-300 pl-3">學生 Students</h3>
        
        <!-- 頁籤選單 -->
        <div class="border-b border-slate-200 mb-8 overflow-x-auto">
          <nav class="flex space-x-2 md:space-x-8 min-w-max px-1" aria-label="Tabs">
            <button class="tab-btn border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300 whitespace-nowrap py-3 px-4 border-b-2 font-bold text-sm md:text-base transition-colors duration-200" data-target="tab-phd">
              博士班 ({phds.length})
            </button>
            <button class="tab-btn border-blue-700 text-blue-700 active whitespace-nowrap py-3 px-4 border-b-2 font-bold text-sm md:text-base transition-colors duration-200" data-target="tab-master">
              碩士班 ({masters.length})
            </button>
            <button class="tab-btn border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300 whitespace-nowrap py-3 px-4 border-b-2 font-bold text-sm md:text-base transition-colors duration-200" data-target="tab-undergrad">
              大學部 ({undergrads.length})
            </button>
            <button class="tab-btn border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300 whitespace-nowrap py-3 px-4 border-b-2 font-bold text-sm md:text-base transition-colors duration-200" data-target="tab-international">
              外籍生 ({internationals.length})
            </button>
          </nav>
        </div>

        <!-- 頁籤內容區塊 -->
        <div class="min-h-[300px]">
          
          <!-- [博士班] 內容 (中等圖卡) -->
          <div id="tab-phd" class="tab-content hidden animate-[fadeIn_0.3s_ease-in-out]">
            {phds.length > 0 ? (
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                {phds.map((person) => (
                  <div class="bg-white border border-slate-200 p-5 flex items-start gap-4 hover:shadow-md hover:border-blue-300 transition rounded-sm">
                    <img src={person.img} alt={person.name} class="w-14 h-14 sm:w-16 sm:h-16 rounded-full object-cover bg-slate-100 border border-slate-200 shrink-0 mt-1" onerror="this.src='/images/default-avatar.png';" />
                    <div class="flex-1">
                      <h4 class="font-bold text-slate-900 text-base mb-1.5">{person.name}</h4>
                      <p class="text-[13px] sm:text-sm text-slate-600 leading-relaxed"><span class="font-semibold text-slate-700">研究題目：</span>{person.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            ) : (
              <div class="bg-slate-50 border-2 border-dashed border-slate-300 p-12 flex flex-col items-center justify-center text-center rounded-sm mx-auto max-w-3xl mt-4">
                <span class="text-5xl mb-4">🎓</span>
                <h4 class="text-xl font-bold text-slate-800 mb-3">目前無博士班成員</h4>
                <p class="text-slate-500 text-base leading-relaxed">
                  歡迎對雲端智慧物聯網系統、AI醫療或製造聯網等前瞻技術有興趣的菁英加入！<br/>
                  <span class="text-blue-600 font-bold mt-3 inline-block bg-blue-50 px-4 py-1.5 rounded-full border border-blue-100">🔥 博士班熱烈招募中 🔥</span>
                </p>
              </div>
            )}
          </div>

          <!-- [碩士班] 內容 (中等圖卡：比大學部大，比助理小) -->
          <div id="tab-master" class="tab-content block animate-[fadeIn_0.3s_ease-in-out]">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
              {masters.map((person) => (
                <div class="bg-white border border-slate-200 p-5 flex items-start gap-4 hover:shadow-md hover:border-blue-300 transition rounded-sm">
                  <img src={person.img} alt={person.name} class="w-14 h-14 sm:w-16 sm:h-16 rounded-full object-cover border border-slate-200 shrink-0 mt-1" onerror="this.src='/images/default-avatar.png';" />
                  <div class="flex-1">
                    <h4 class="font-bold text-slate-900 text-base mb-1.5">{person.name}</h4>
                    <p class="text-[13px] sm:text-sm text-slate-600 leading-relaxed"><span class="font-semibold text-slate-700">研究題目：</span>{person.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- [大學部專題生] 內容 (最小圖卡，無照片) -->
          <div id="tab-undergrad" class="tab-content hidden animate-[fadeIn_0.3s_ease-in-out]">
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-3">
              {undergrads.map((person) => (
                <div class="bg-white border border-slate-200 p-3 rounded-sm hover:border-blue-300 hover:shadow-sm transition cursor-default">
                  <h4 class="font-bold text-slate-800 text-sm mb-1 flex items-center gap-2">
                    <div class="w-1.5 h-1.5 rounded-full bg-blue-500"></div> {person.name}
                  </h4>
                  <p class="text-[11px] text-slate-500 leading-tight">專題：{person.desc}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- [外籍生] 內容 (比照碩博班中等圖卡) -->
          <div id="tab-international" class="tab-content hidden animate-[fadeIn_0.3s_ease-in-out]">
            {internationals.length > 0 ? (
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                {internationals.map((person) => (
                  <div class="bg-white border border-slate-200 p-5 flex items-start gap-4 hover:shadow-md hover:border-blue-300 transition rounded-sm">
                    <img src={person.img} alt={person.name} class="w-14 h-14 sm:w-16 sm:h-16 rounded-full object-cover bg-slate-100 border border-slate-200 shrink-0 mt-1" onerror="this.src='/images/default-avatar.png';" />
                    <div class="flex-1">
                      <h4 class="font-bold text-slate-900 text-base mb-1.5">{person.name}</h4>
                      <p class="text-[13px] sm:text-sm text-slate-600 leading-relaxed">{person.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            ) : (
              <div class="bg-slate-50 border-2 border-dashed border-slate-300 p-12 flex flex-col items-center justify-center text-center rounded-sm mx-auto max-w-3xl mt-4">
                <span class="text-5xl mb-4">🌍</span>
                <h4 class="text-xl font-bold text-slate-800 mb-3">目前無外籍生 (No International Students Currently)</h4>
                <p class="text-slate-500 text-base leading-relaxed">
                  Welcome international students to join us! We focus on AIoT, Medical IoT, and Industrial IoT.<br/>
                  <span class="text-blue-600 font-bold mt-3 inline-block bg-blue-50 px-4 py-1.5 rounded-full border border-blue-100">🔥 International Students Recruiting / 外籍生熱烈招募中 🔥</span>
                </p>
              </div>
            )}
          </div>

        </div>
      </div>

    </div>
  </main>

  <!-- 🔷 頁尾 (Footer) -->
  <footer class="bg-[#0f172a] py-16 mt-12 border-t border-slate-800 relative z-20">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-start gap-10">
      <div class="md:w-1/2">
        <h2 class="text-2xl font-bold text-white tracking-wider mb-2"><span class="italic font-['Times_New_Roman',_Times,_serif] text-[1.15em] mr-0.5">i</span>CPS Lab</h2>
        <p class="text-sm text-blue-400 font-medium mb-4">智慧網宇實體系統實驗室</p>
        <p class="text-sm text-slate-400 leading-relaxed max-w-md">
          Intelligent Cyber-Physical Systems Laboratory <br/>
          國立高雄科技大學 (NKUST)
        </p>
      </div>
      <div class="md:w-1/2 flex flex-col md:items-end text-sm space-y-3">
        <h3 class="text-white font-semibold mb-2 tracking-wide uppercase text-xs">Contact Us</h3>
        <p class="flex items-center gap-2 text-slate-300"><span class="text-slate-500">📍</span> 國立高雄科技大學 (建工校區)</p>
        <p class="flex items-center gap-2 text-slate-300"><span class="text-slate-500">📞</span> 07-3814526 分機 15672</p>
        <p class="flex items-center gap-2 text-slate-300"><span class="text-slate-500">✉️</span> <a href="mailto:allenchang@nkust.edu.tw" class="hover:text-blue-400 transition">allenchang@nkust.edu.tw</a></p>
      </div>
    </div>
    
    <!-- 👇 同步首頁的版權與累積造訪人數區塊 -->
    <div class="max-w-7xl mx-auto px-6 mt-12 pt-6 border-t border-slate-800 flex flex-col lg:flex-row justify-between items-center gap-6 lg:gap-4">
      
      <!-- 左側：版權宣告 -->
      <div class="flex flex-col sm:flex-row items-center gap-2 sm:gap-4 text-center sm:text-left">
        <p class="text-xs text-slate-500">&copy; 2026 <span class="italic font-['Times_New_Roman',_Times,_serif] text-[1.15em]">i</span>CPS Lab, National Kaohsiung University of Science and Technology.</p>
        <p class="text-xs text-slate-500 hidden sm:block">|</p>
        <p class="text-xs text-slate-500">All rights reserved.</p>
      </div>

      <!-- 右側：累積造訪人數區塊 -->
      <div class="flex items-center gap-2 bg-slate-800/50 px-3 py-1.5 rounded-md border border-slate-700 shadow-sm transition hover:border-slate-600">
        <!-- 眼睛小圖示 -->
        <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
        <span class="text-xs text-slate-400 font-medium tracking-wide">累積造訪人數</span>
        <span class="text-xs text-slate-600 mx-1">|</span>
        <!-- 動態數字顯示區域 -->
        <span class="text-sm font-mono font-bold text-blue-400 tracking-wider" id="visitor-count">載入中...</span>
      </div>
    </div>
  </footer>

  <!-- 🔷 控制頁籤切換與計數器的 JavaScript -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      // --- 1. 頁籤切換邏輯 ---
      const tabBtns = document.querySelectorAll('.tab-btn');
      const tabContents = document.querySelectorAll('.tab-content');

      tabBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          // 移除所有按鈕的 active 樣式
          tabBtns.forEach(b => {
            b.classList.remove('border-blue-700', 'text-blue-700', 'active');
            b.classList.add('border-transparent', 'text-slate-500');
          });

          // 為當前點擊的按鈕加上 active 樣式
          btn.classList.remove('border-transparent', 'text-slate-500');
          btn.classList.add('border-blue-700', 'text-blue-700', 'active');

          // 隱藏所有頁籤內容
          tabContents.forEach(content => {
            content.classList.remove('block');
            content.classList.add('hidden');
          });

          // 顯示對應的頁籤內容
          const targetId = btn.getAttribute('data-target');
          const targetContent = document.getElementById(targetId);
          if (targetContent) {
            targetContent.classList.remove('hidden');
            targetContent.classList.add('block');
          }
        });
      });

      // --- 2. 智慧訪客計數器邏輯 (與首頁同步的 24小時防洗次數機制) ---
      const initCounter = async () => {
        const counterEl = document.getElementById('visitor-count');
        if (!counterEl) return;

        const namespace = 'icpslab_site';
        const key = 'visits';
        const localCountKey = 'icps_saved_count';
        const lastVisitTimeKey = 'icps_last_visit_time';
        const TWENTY_FOUR_HOURS = 24 * 60 * 60 * 1000;

        // 讀取備用的顯示數字
        let currentCount = localStorage.getItem(localCountKey) || '------';
        
        // 讀取上次造訪時間並判斷是否在 24 小時內
        const lastVisitTime = localStorage.getItem(lastVisitTimeKey);
        const now = Date.now();
        const hasVisitedWithin24Hours = lastVisitTime && (now - parseInt(lastVisitTime, 10) < TWENTY_FOUR_HOURS);
        
        try {
          const url = `https://api.counterapi.dev/v1/${namespace}/${key}`;
          
          if (!hasVisitedWithin24Hours) {
            // 情況 A：超過 24 小時未造訪，呼叫 /up 增加次數
            const response = await fetch(url + '/up');
            if (!response.ok) throw new Error('API 回應錯誤');
            
            const data = await response.json();
            currentCount = String(data.count).padStart(6, '0');
            
            // 更新時間戳記與數字
            localStorage.setItem(lastVisitTimeKey, now.toString());
            localStorage.setItem(localCountKey, currentCount);
            counterEl.textContent = currentCount;
            
          } else {
            // 情況 B：24 小時內已造訪過，只拉取最新數字不增加
            try {
              const response = await fetch(url);
              if (response.ok) {
                const data = await response.json();
                currentCount = String(data.count).padStart(6, '0');
                localStorage.setItem(localCountKey, currentCount);
              }
            } catch (e) {
              console.warn('無法從伺服器獲取最新數字，已切換為本地暫存值');
            }
            counterEl.textContent = currentCount;
          }
          
        } catch (error) {
          console.error('計數器載入異常:', error);
          counterEl.textContent = currentCount;
        }
      };

      initCounter();
    });
  </script>

  <!-- 簡單的淡入動畫設定 -->
  <style>
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(5px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>

</body>
</html>