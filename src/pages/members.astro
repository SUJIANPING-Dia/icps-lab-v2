                        <span class="text-xs text-slate-400 font-mono bg-slate-100 px-2 py-0.5 rounded">
                          預計 {expectedGradYear} 學年度畢業
                        </span>
                        <span class="text-xs font-bold text-blue-700 bg-blue-50 px-2 py-0.5 rounded border border-blue-100">
                          {getGradeText('undergrad', year)}
                        </span>
                      </div>

                      {/* 此年度的各專題卡片 */}
                      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 pl-5 border-l-2 border-slate-200">
                        {Object.entries(projectsInYear).map(([topic, members]) => (
                          <div class="bg-white border border-slate-200 p-5 rounded-md hover:border-blue-400 hover:shadow-md transition duration-300 flex flex-col h-full">
                            <div class="flex items-start gap-3 mb-3">
                              <div class="bg-blue-50 p-2 rounded shrink-0">
                                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                                </svg>
                              </div>
                              <div>
                                <h5 class="font-bold text-slate-800 text-[15px] leading-snug pt-0.5">{topic}</h5>
                                <p class="text-[12px] text-slate-500 mt-1">專題小組 ({(members as any[]).length} 人)</p>
                              </div>
                            </div>

                            <div class="mb-4 flex-1">
                              <p class="text-[13.5px] text-slate-600 leading-relaxed">
                                {undergradProjectSummaries[topic] || "尚無此專題的詳細介紹。"}
                              </p>
                            </div>

                            <div class="border-t border-slate-100 pt-4 mt-auto">
                              <div class="flex flex-wrap gap-2">
                                {(members as any[]).map((m: any) => (
                                  <span class="inline-flex items-center gap-1.5 bg-slate-50 border border-slate-200 text-slate-700 text-[13px] font-medium px-2.5 py-1 rounded-full hover:bg-slate-100 transition">
                                    <div class="w-1.5 h-1.5 rounded-full bg-blue-500"></div>
                                    {m.name}
                                  </span>
                                ))}
                              </div>
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  );
                })}
              </div>
            ) : (
              <div class="bg-slate-50 border-2 border-dashed border-slate-300 p-12 flex flex-col items-center justify-center text-center rounded-sm mx-auto max-w-3xl mt-4">
                <span class="text-5xl mb-4">🎓</span>
                <h4 class="text-xl font-bold text-slate-800 mb-3">目前無大學部成員</h4>
              </div>
            )}
          </div>

          <!-- ═══ 外籍生 ═══ -->
          <div id="tab-international" class="tab-content hidden animate-fade-in">
            {internationals.length > 0 ? (
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                {internationals.map((person) => (
                  <div class="bg-white border border-slate-200 p-5 flex items-start gap-4 hover:shadow-md hover:border-blue-300 transition rounded-sm">
                    <img src={getAvatar(person.img, person.name)} alt={person.name} class="w-14 h-14 sm:w-16 sm:h-16 rounded-full object-cover bg-slate-100 border border-slate-200 shrink-0 mt-1" onerror="this.src='/images/default-avatar.png';" />
                    <div class="flex-1">
                      <h4 class="font-bold text-slate-900 text-base mb-1.5">{person.name}</h4>
                      <p class="text-[13px] sm:text-sm text-slate-600 leading-relaxed">{person.project}</p>
                    </div>
                  </div>
                ))}
              </div>
            ) : (
              <div class="bg-slate-50 border-2 border-dashed border-slate-300 p-12 flex flex-col items-center justify-center text-center rounded-sm mx-auto max-w-3xl mt-4">
                <span class="text-5xl mb-4">🌍</span>
                <h4 class="text-xl font-bold text-slate-800 mb-3">目前無外籍生 (No International Students Currently)</h4>
                <p class="text-slate-500 text-base leading-relaxed">
                  Welcome international students to join us! We focus on AIoT, Medical IoT, and Industrial IoT.<br/>
                  <span class="text-blue-600 font-bold mt-3 inline-block bg-blue-50 px-4 py-1.5 rounded-full border border-blue-100">🔥 International Students Recruiting / 外籍生熱烈招募中 🔥</span>
                </p>
              </div>
            )}
          </div>

          <!-- ═══ 歷屆畢業生 ═══ -->
          <div id="tab-graduate" class="tab-content hidden animate-fade-in">
            {graduates.length > 0 ? (
              <div class="space-y-10">
                {sortedGradYears.map((year) => (
                  <div>
                    <h4 class="text-lg font-bold text-slate-700 mb-4 flex items-center gap-2">
                      <span class="w-2 h-2 rounded-full bg-slate-400"></span>
                      {year === '未知年份' ? year : `${year} 學年度畢業`}
                      <span class="text-sm font-normal text-slate-400">({groupedGraduates[year].length}人)</span>
                    </h4>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                      {groupedGraduates[year].map((person) => (
                        <div class="bg-white border border-slate-200 p-4 flex items-center gap-4 rounded-sm hover:border-slate-300 transition">
                          <img src={getAvatar(person.img, person.name)} alt={person.name} class="w-12 h-12 rounded-full object-cover border border-slate-200" onerror="this.src='/images/default-avatar.png';" />
                          <div>
                            <h5 class="font-bold text-slate-800">
                              {person.name}
                              <span class="text-[11px] font-normal text-slate-500 ml-1 border border-slate-200 px-1.5 py-0.5 rounded">
                                {person.degree === 'master' ? '碩士' : person.degree === 'phd' ? '博士' : '大學部'}
                              </span>
                            </h5>
                            <p class="text-[12px] text-slate-500 mt-1 truncate max-w-[180px]" title={person.project}>{person.project || '無論文紀錄'}</p>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            ) : (
              <div class="bg-slate-50 border-2 border-dashed border-slate-300 p-12 flex flex-col items-center justify-center text-center rounded-sm mx-auto max-w-3xl mt-4">
                <span class="text-5xl mb-4">🎓</span>
                <h4 class="text-xl font-bold text-slate-800 mb-3">目前尚無畢業生資料</h4>
                <p class="text-slate-500 text-base leading-relaxed">
                  系統將於學生畢業時，自動將紀錄彙整至此，並依年度展示。
                </p>
              </div>
            )}
          </div>

        </div>
      </div>

    </div>
  </main>

  <!-- 🔷 頁尾 -->
  <footer class="bg-[#0f172a] py-16 mt-12 border-t border-slate-800 relative z-20">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-start gap-10">
      <div class="md:w-1/2">
        <img src="/images/footer-logo.png" alt="iCPS Lab" class="h-14 md:h-20 w-auto mb-3 object-contain" onerror="this.style.display='none';" />
        <p class="text-sm text-blue-400 font-medium mb-4">智慧網宇實體系統實驗室</p>
        <p class="text-sm text-slate-400 leading-relaxed max-w-md">
          Intelligent Cyber-Physical Systems Laboratory <br/>
          國立高雄科技大學 (NKUST)
        </p>
      </div>
      <div class="md:w-1/2 flex flex-col md:items-end text-sm space-y-3">
        <h3 class="text-white font-semibold mb-2 tracking-wide uppercase text-xs">Contact Us</h3>
        <p class="flex items-center gap-2 text-slate-300"><span class="text-slate-500">📍</span> 國立高雄科技大學 (建工校區)</p>
        <p class="flex items-center gap-2 text-slate-300"><span class="text-slate-500">📞</span> 07-3814526 分機 15672</p>
        <p class="flex items-center gap-2 text-slate-300"><span class="text-slate-500">✉️</span> <a href="mailto:allenchang@nkust.edu.tw" class="hover:text-blue-400 transition">allenchang@nkust.edu.tw</a></p>
      </div>
    </div>
    <div class="max-w-7xl mx-auto px-6 mt-12 pt-6 border-t border-slate-800 flex flex-col lg:flex-row justify-between items-center gap-6 lg:gap-4">
      <div class="flex flex-col sm:flex-row items-center gap-2 sm:gap-4 text-center sm:text-left">
        <p class="text-xs text-slate-500 leading-normal">
          &copy; 2026 <span class="italic font-['Times_New_Roman',_Times,_serif] text-[1.15em]">i</span>CPS Lab, National Kaohsiung University of Science and Technology.
        </p>
        <p class="text-xs text-slate-500 hidden sm:block">|</p>
        <p class="text-xs text-slate-500">All rights reserved.</p>
      </div>
      <div class="flex items-center gap-2 bg-slate-800/50 px-3 py-1.5 rounded-md border border-slate-700 shadow-sm transition hover:border-slate-600">
        <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
        <span class="text-xs text-slate-400 font-medium tracking-wide">累積造訪人數</span>
        <span class="text-xs text-slate-600 mx-1">|</span>
        <span class="text-sm font-mono font-bold text-blue-400 tracking-wider" id="visitor-count">載入中...</span>
      </div>
    </div>
  </footer>

  <script>
    document.addEventListener("DOMContentLoaded", () => {

      // --- 手機版漢堡選單 ---
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu    = document.getElementById('mobile-menu');
      const hamburgerIcon = document.getElementById('hamburger-icon');
      if (mobileMenuBtn && mobileMenu && hamburgerIcon) {
        mobileMenuBtn.addEventListener('click', () => {
          const isHidden = mobileMenu.classList.contains('hidden');
          mobileMenu.classList.toggle('hidden', !isHidden);
          hamburgerIcon.setAttribute('d', isHidden
            ? 'M6 18L18 6M6 6l12 12'
            : 'M4 6h16M4 12h16M4 18h16'
          );
        });
        mobileMenu.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            mobileMenu.classList.add('hidden');
            hamburgerIcon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
          });
        });
      }

      // --- 頁籤切換 ---
      const tabBtns     = document.querySelectorAll('.tab-btn');
      const tabContents = document.querySelectorAll('.tab-content');
      tabBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          tabBtns.forEach(b => {
            b.classList.remove('border-blue-700', 'text-blue-700', 'active');
            b.classList.add('border-transparent', 'text-slate-500');
          });
          btn.classList.remove('border-transparent', 'text-slate-500');
          btn.classList.add('border-blue-700', 'text-blue-700', 'active');

          tabContents.forEach(c => { c.classList.remove('block'); c.classList.add('hidden'); });
          const target = document.getElementById(btn.getAttribute('data-target') ?? '');
          if (target) { target.classList.remove('hidden'); target.classList.add('block'); }
        });
      });

      // --- 訪客計數器 ---
      const initCounter = async () => {
        const el = document.getElementById('visitor-count');
        if (!el) return;
        const namespace = 'icpslab_site', key = 'visits';
        const localCountKey = 'icps_saved_count', lastVisitKey = 'icps_last_visit_time';
        const TTL = 24 * 60 * 60 * 1000;
        let current = localStorage.getItem(localCountKey) ?? '------';
        const lastVisit = localStorage.getItem(lastVisitKey);
        const now = Date.now();
        try {
          const base = `https://api.counterapi.dev/v1/${namespace}/${key}`;
          if (!lastVisit || now - parseInt(lastVisit, 10) >= TTL) {
            const r = await fetch(base + '/up');
            if (!r.ok) throw new Error();
            const d = await r.json();
            current = String(d.count).padStart(6, '0');
            localStorage.setItem(lastVisitKey, now.toString());
            localStorage.setItem(localCountKey, current);
          } else {
            try {
              const r = await fetch(base);
              if (r.ok) { const d = await r.json(); current = String(d.count).padStart(6, '0'); localStorage.setItem(localCountKey, current); }
            } catch { /* 使用本地暫存 */ }
          }
        } catch { /* 靜默失敗 */ }
        el.textContent = current;
      };
      initCounter();
    });
  </script>

</body>
</html>