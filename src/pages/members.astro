                        <span class="text-xs font-bold text-blue-700 bg-blue-50 px-2 py-0.5 rounded-md border border-blue-100">{getGradeText('undergrad', year)}</span>
                        <div class="year-divider-line"></div>
                      </div>
                      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 pl-5 border-l-2 border-slate-100">
                        {Object.entries(projectsInYear).map(([topic, members]) => (
                          <div class="project-card bg-white border border-slate-200 p-5 rounded-xl flex flex-col h-full">
                            <div class="flex items-start gap-3 mb-3">
                              <div class="bg-blue-50 p-2 rounded-lg shrink-0">
                                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                                </svg>
                              </div>
                              <div>
                                <h5 class="font-bold text-slate-800 text-[15px] leading-snug pt-0.5">{topic}</h5>
                                <p class="text-[12px] text-slate-500 mt-1">專題小組 ({(members as any[]).length} 人)</p>
                              </div>
                            </div>
                            <p class="text-[13.5px] text-slate-600 leading-relaxed flex-1">
                              {undergradProjectSummaries[topic] || "尚無此專題的詳細介紹。"}
                            </p>
                            <div class="border-t border-slate-100 pt-3 mt-4">
                              <div class="flex flex-wrap gap-2">
                                {(members as any[]).map((m: any) => (
                                  <span class="inline-flex items-center gap-1.5 bg-slate-50 border border-slate-200 text-slate-700 text-[13px] font-medium px-2.5 py-1 rounded-full hover:bg-blue-50 hover:border-blue-200 hover:text-blue-700 transition-colors duration-200 cursor-default">
                                    <div class="w-1.5 h-1.5 rounded-full bg-blue-400"></div>
                                    {m.name}
                                  </span>
                                ))}
                              </div>
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  );
                })}
              </div>
            ) : (
              <div class="bg-slate-50 border-2 border-dashed border-slate-200 p-12 flex flex-col items-center justify-center text-center rounded-xl mx-auto max-w-3xl mt-4">
                <span class="text-5xl mb-4">🎓</span>
                <h4 class="text-xl font-bold text-slate-800 mb-3">目前無大學部成員</h4>
              </div>
            )}
          </div>

          <!-- ═══ 外籍生 ═══ -->
          <div id="tab-international" class="tab-panel">
            {internationals.length > 0 ? (
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                {internationals.map((person) => (
                  <div class="member-card bg-white border border-slate-200 p-5 flex items-start gap-4 rounded-xl">
                    <div class="overflow-hidden rounded-full w-14 h-14 sm:w-16 sm:h-16 shrink-0 mt-1 border-2 border-slate-100">
                      <img src={getAvatar(person.img, person.name)} alt={person.name} class="avatar-zoom w-full h-full object-cover" onerror="this.src='/images/default-avatar.png';" />
                    </div>
                    <div class="flex-1">
                      <h4 class="font-bold text-slate-900 text-base mb-1.5">{person.name}</h4>
                      <p class="text-[13px] text-slate-600 leading-relaxed">{person.project}</p>
                    </div>
                  </div>
                ))}
              </div>
            ) : (
              <div class="bg-slate-50 border-2 border-dashed border-slate-200 p-12 flex flex-col items-center justify-center text-center rounded-xl mx-auto max-w-3xl mt-4">
                <span class="text-5xl mb-4">🌍</span>
                <h4 class="text-xl font-bold text-slate-800 mb-3">目前無外籍生</h4>
                <p class="text-slate-500 text-base leading-relaxed">
                  Welcome international students! We focus on AIoT, Medical IoT, and Industrial IoT.<br/>
                  <span class="text-blue-600 font-bold mt-3 inline-block bg-blue-50 px-4 py-1.5 rounded-full border border-blue-100">🔥 International Students Recruiting 🔥</span>
                </p>
              </div>
            )}
          </div>

          <!-- ═══ 歷屆畢業生 ═══ -->
          <div id="tab-graduate" class="tab-panel">
            {graduates.length > 0 ? (
              <div class="space-y-10">
                {sortedGradYears.map((year) => (
                  <div>
                    <div class="flex items-center gap-3 mb-4">
                      <span class="w-2.5 h-2.5 rounded-full bg-slate-400 shrink-0"></span>
                      <h4 class="text-base font-bold text-slate-700">
                        {year === '未知年份' ? year : `${year} 學年度畢業`}
                      </h4>
                      <span class="text-xs text-slate-400 font-mono">({groupedGraduates[year].length} 人)</span>
                      <div class="year-divider-line"></div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                      {groupedGraduates[year].map((person) => (
                        <div class="member-card bg-white border border-slate-200 p-4 flex items-center gap-4 rounded-xl">
                          <div class="overflow-hidden rounded-full w-12 h-12 shrink-0 border-2 border-slate-100">
                            <img src={getAvatar(person.img, person.name)} alt={person.name} class="avatar-zoom w-full h-full object-cover" onerror="this.src='/images/default-avatar.png';" />
                          </div>
                          <div>
                            <h5 class="font-bold text-slate-800">
                              {person.name}
                              <span class="text-[11px] font-normal text-slate-500 ml-1 border border-slate-200 px-1.5 py-0.5 rounded-md">
                                {person.degree === 'master' ? '碩士' : person.degree === 'phd' ? '博士' : '大學部'}
                              </span>
                            </h5>
                            <p class="text-[12px] text-slate-500 mt-1 truncate max-w-[180px]" title={person.project}>{person.project || '無論文紀錄'}</p>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            ) : (
              <div class="bg-slate-50 border-2 border-dashed border-slate-200 p-12 flex flex-col items-center justify-center text-center rounded-xl mx-auto max-w-3xl mt-4">
                <span class="text-5xl mb-4">🎓</span>
                <h4 class="text-xl font-bold text-slate-800 mb-3">目前尚無畢業生資料</h4>
                <p class="text-slate-500">系統將於學生畢業時自動彙整至此。</p>
              </div>
            )}
          </div>

        </div>
      </div>

    </div>
  </main>

  <!-- =============================================================== -->
  <!-- 🔒 頁尾 — 不動                                                 -->
  <!-- =============================================================== -->
  <footer class="bg-[#0f172a] py-16 mt-12 border-t border-slate-800 relative z-20">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-start gap-10">
      <div class="md:w-1/2">
        <img src="/images/footer-logo.png" alt="iCPS Lab" class="h-14 md:h-20 w-auto mb-3 object-contain" onerror="this.style.display='none';" />
        <p class="text-sm text-blue-400 font-medium mb-4">智慧網宇實體系統實驗室</p>
        <p class="text-sm text-slate-400 leading-relaxed max-w-md">Intelligent Cyber-Physical Systems Laboratory <br/>國立高雄科技大學 (NKUST)</p>
      </div>
      <div class="md:w-1/2 flex flex-col md:items-end text-sm space-y-3">
        <h3 class="text-white font-semibold mb-2 tracking-wide uppercase text-xs">Contact Us</h3>
        <p class="flex items-center gap-2 text-slate-300"><span class="text-slate-500">📍</span> 國立高雄科技大學 (建工校區)</p>
        <p class="flex items-center gap-2 text-slate-300"><span class="text-slate-500">📞</span> 07-3814526 分機 15672</p>
        <p class="flex items-center gap-2 text-slate-300"><span class="text-slate-500">✉️</span> <a href="mailto:allenchang@nkust.edu.tw" class="hover:text-blue-400 transition">allenchang@nkust.edu.tw</a></p>
      </div>
    </div>
    <div class="max-w-7xl mx-auto px-6 mt-12 pt-6 border-t border-slate-800 flex flex-col lg:flex-row justify-between items-center gap-6 lg:gap-4">
      <div class="flex flex-col sm:flex-row items-center gap-2 sm:gap-4 text-center sm:text-left">
        <p class="text-xs text-slate-500">&copy; 2026 <span class="italic font-['Times_New_Roman',_Times,_serif] text-[1.15em]">i</span>CPS Lab, National Kaohsiung University of Science and Technology.</p>
        <p class="text-xs text-slate-500 hidden sm:block">|</p>
        <p class="text-xs text-slate-500">All rights reserved.</p>
      </div>
      <div class="flex items-center gap-2 bg-slate-800/50 px-3 py-1.5 rounded-md border border-slate-700 shadow-sm transition hover:border-slate-600">
        <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
        <span class="text-xs text-slate-400 font-medium tracking-wide">累積造訪人數</span>
        <span class="text-xs text-slate-600 mx-1">|</span>
        <span class="text-sm font-mono font-bold text-blue-400 tracking-wider" id="visitor-count">載入中...</span>
      </div>
    </div>
  </footer>

  <script>
    document.addEventListener("DOMContentLoaded", () => {

      // ── 漢堡選單 ──
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu    = document.getElementById('mobile-menu');
      const hamburgerIcon = document.getElementById('hamburger-icon');
      if (mobileMenuBtn && mobileMenu && hamburgerIcon) {
        mobileMenuBtn.addEventListener('click', () => {
          const isHidden = mobileMenu.classList.contains('hidden');
          mobileMenu.classList.toggle('hidden', !isHidden);
          hamburgerIcon.setAttribute('d', isHidden ? 'M6 18L18 6M6 6l12 12' : 'M4 6h16M4 12h16M4 18h16');
        });
        mobileMenu.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            mobileMenu.classList.add('hidden');
            hamburgerIcon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
          });
        });
      }

      // ── 頁籤切換（含動畫） ──
      const tabBtns     = document.querySelectorAll('.tab-btn');
      const tabPanels   = document.querySelectorAll('.tab-panel');

      tabBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          // 樣式切換
          tabBtns.forEach(b => {
            b.classList.remove('tab-active-style', 'text-blue-700', 'border-blue-700');
            b.classList.add('text-slate-500', 'border-transparent');
            // 計數 badge 恢復灰色
            const badge = b.querySelector('span');
            if (badge) { badge.classList.remove('bg-blue-100', 'text-blue-700'); badge.classList.add('bg-slate-100', 'text-slate-500'); }
          });
          btn.classList.add('tab-active-style', 'text-blue-700', 'border-blue-700');
          btn.classList.remove('text-slate-500', 'border-transparent');
          const activeBadge = btn.querySelector('span');
          if (activeBadge) { activeBadge.classList.remove('bg-slate-100', 'text-slate-500'); activeBadge.classList.add('bg-blue-100', 'text-blue-700'); }

          // 面板切換（remove → add 讓 CSS animation 重新觸發）
          const targetId = btn.getAttribute('data-target') ?? '';
          tabPanels.forEach(p => {
            p.classList.remove('tab-active');
            p.classList.add('hidden-panel');
          });
          const target = document.getElementById(targetId);
          if (target) {
            target.classList.remove('hidden-panel');
            // 強制 reflow 後再加 class，讓 animation 每次都重新播放
            void (target as HTMLElement).offsetWidth;
            target.classList.add('tab-active');

            // 頁籤切換後，對裡面的卡片補觸發 scroll reveal
            target.querySelectorAll('[data-rv]').forEach(el => {
              if (!el.classList.contains('rv-visible')) {
                el.classList.add('rv-visible');
              }
            });
          }
        });
      });

      // ── Scroll Reveal ──
      const revealEls = document.querySelectorAll('[data-rv]');
      const revealObs = new IntersectionObserver((entries, obs) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('rv-visible');
            obs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
      revealEls.forEach(el => revealObs.observe(el));

      // ── 訪客計數器 ──
      const initCounter = async () => {
        const el = document.getElementById('visitor-count');
        if (!el) return;
        const namespace = 'icpslab_site', key = 'visits';
        const localKey = 'icps_saved_count', timeKey = 'icps_last_visit_time';
        const TTL = 24 * 60 * 60 * 1000;
        let current = localStorage.getItem(localKey) ?? '------';
        const last = localStorage.getItem(timeKey);
        const now = Date.now();
        try {
          const base = `https://api.counterapi.dev/v1/${namespace}/${key}`;
          if (!last || now - parseInt(last, 10) >= TTL) {
            const r = await fetch(base + '/up');
            if (!r.ok) throw new Error();
            const d = await r.json();
            current = String(d.count).padStart(6, '0');
            localStorage.setItem(timeKey, now.toString());
            localStorage.setItem(localKey, current);
          } else {
            try { const r = await fetch(base); if (r.ok) { const d = await r.json(); current = String(d.count).padStart(6, '0'); localStorage.setItem(localKey, current); } } catch {}
          }
        } catch {}
        el.textContent = current;
      };
      initCounter();

    });
  </script>

</body>
