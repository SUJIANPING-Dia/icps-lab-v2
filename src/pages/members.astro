const today = new Date();
let currentAcYear = today.getFullYear() - 1911;
if (today.getMonth() < 7) currentAcYear -= 1;

const zhNumbers = ["零", "一", "二", "三", "四", "五", "六", "七", "八", "九", "十"];
function getGradeText(degree: string, enrollYear: number): string {
  let diff = currentAcYear - enrollYear + 1;
  if (diff < 1) diff = 1;
  const numStr = zhNumbers[diff] ?? diff.toString();
  if (degree === 'master') return diff > 2 ? `碩${diff} (延)` : `碩${numStr}`;
  if (degree === 'phd') return diff > 4 ? `博${diff} (延)` : `博${numStr}`;
  return diff > 4 ? `${diff}年級 (延)` : `${numStr}年級`;
}

function getAvatar(img: string | null | undefined, name: string): string {
  if (img && img.trim() !== '') return img;
  return `https://ui-avatars.com/api/?name=${encodeURIComponent(name)}&background=E2E8F0&color=475569&bold=true`;
}

const phds         = allStudents.filter(s => s.status === 'active' && s.degree === 'phd');
const masters      = allStudents.filter(s => s.status === 'active' && s.degree === 'master');
const undergrads   = allStudents.filter(s => s.status === 'active' && s.degree === 'undergrad');
const internationals = allStudents.filter(s => s.status === 'active' && s.degree === 'international');
const graduates    = allStudents.filter(s => s.status === 'graduated');

const mastersByYear = masters.reduce((map, student) => {
  const yr = student.enrollmentYear ?? 0;
  if (!map[yr]) map[yr] = [];
  map[yr].push(student);
  return map;
}, {} as Record<number, typeof masters>);
const sortedMasterYears = Object.keys(mastersByYear).map(Number).sort((a, b) => a - b);

const phdsByYear = phds.reduce((map, student) => {
  const yr = student.enrollmentYear ?? 0;
  if (!map[yr]) map[yr] = [];
  map[yr].push(student);
  return map;
}, {} as Record<number, typeof phds>);
const sortedPhdYears = Object.keys(phdsByYear).map(Number).sort((a, b) => a - b);

const undergradByYear = undergrads.reduce((yearMap, student) => {
  const yr = student.enrollmentYear ?? 0;
  if (!yearMap[yr]) yearMap[yr] = {};
  const projectName = student.project || '未分類專題';
  if (!yearMap[yr][projectName]) yearMap[yr][projectName] = [];
  yearMap[yr][projectName].push(student);
  return yearMap;
}, {} as Record<number, Record<string, typeof undergrads>>);
const sortedUndergradYears = Object.keys(undergradByYear).map(Number).sort((a, b) => a - b);

const groupedGraduates = graduates.reduce((groups, student) => {
  const y = student.graduationYear ?? '未知年份';
  const key = String(y);
  if (!groups[key]) groups[key] = [];
  groups[key].push(student);
  return groups;
}, {} as Record<string, typeof graduates>);
const sortedGradYears = Object.keys(groupedGraduates).sort((a, b) => Number(b) - Number(a));
