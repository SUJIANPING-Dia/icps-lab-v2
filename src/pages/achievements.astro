---
import "../styles/global.css";
import achievements from "../data/achievements.json";

const achievementStats = achievements.map((group) => ({
  category: group.category,
  type: group.type,
  count: group.yearlyData.reduce((sum, yearBlock) => sum + yearBlock.items.length, 0),
}));

const totalRecords = achievementStats.reduce((sum, item) => sum + item.count, 0);
const publicationCount = achievementStats.filter(item => item.type === "publication").reduce((sum, item) => sum + item.count, 0);
const awardCount = achievementStats.filter(item => item.type === "award").reduce((sum, item) => sum + item.count, 0);
const projectCount = achievementStats.filter(item => item.type === "project").reduce((sum, item) => sum + item.count, 0);
const patentCount = achievementStats.filter(item => item.type === "patent").reduce((sum, item) => sum + item.count, 0);
const allYears = achievements.flatMap(group => group.yearlyData.map(yearBlock => Number(yearBlock.year)).filter(Boolean));
const latestYear = allYears.length ? Math.max(...allYears) : "—";
---

<html lang="zh-TW" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/images/lab-logo.png" />
  <title>成果與榮譽 | iCPS Lab 智慧網宇實體系統實驗室</title>

  <style is:global>
    .hide-scrollbar::-webkit-scrollbar{display:none}.hide-scrollbar{-ms-overflow-style:none;scrollbar-width:none}
    [data-rv]{opacity:0;transition:opacity .72s cubic-bezier(.22,1,.36,1),transform .72s cubic-bezier(.22,1,.36,1)}
    [data-rv="up"]{transform:translateY(26px)}[data-rv="left"]{transform:translateX(-26px)}[data-rv="zoom"]{transform:scale(.97)}
    [data-rv].rv-visible{opacity:1;transform:translate(0,0) scale(1)}
    .fade-in{animation:fadeIn .36s cubic-bezier(.22,1,.36,1) both}@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
    @keyframes heroRise{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}.hero-rise{opacity:0;animation:heroRise .75s cubic-bezier(.22,1,.36,1) forwards}.hero-rise.delay-1{animation-delay:.1s}.hero-rise.delay-2{animation-delay:.22s}.hero-rise.delay-3{animation-delay:.34s}
    .category-group{display:none}.category-group.is-active{display:block}.rotate-180{transform:rotate(180deg)}
    .achievement-card{transition:transform .25s cubic-bezier(.22,1,.36,1),box-shadow .25s ease,border-color .25s ease,background .25s ease}
    .achievement-card:hover{transform:translateY(-3px);border-color:rgba(37,99,235,.35);box-shadow:0 18px 42px -28px rgba(15,23,42,.45),0 10px 28px -22px rgba(37,99,235,.35)}
    .tab-btn.is-active .tab-count{background:rgba(255,255,255,.18);color:white}.year-content{overflow:hidden}
  </style>

</head>
<body class="bg-[#f8fafc] text-slate-800 font-sans antialiased selection:bg-blue-200 selection:text-blue-900 relative">
<nav class="w-full bg-white border-b border-slate-200 shadow-sm relative z-30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center justify-between py-3 md:py-4">
      <div class="flex items-center gap-3 sm:gap-6 lg:gap-8 min-w-0">
        <a href="https://www.nkust.edu.tw/" target="_blank" class="flex items-center shrink-0 transition-transform duration-300 hover:scale-105">
          <img src="/images/nkust-logo.png" alt="NKUST 國立高雄科技大學" class="h-6 sm:h-9 md:h-10 lg:h-11 w-auto object-contain" onerror="this.src='https://upload.wikimedia.org/wikipedia/zh/thumb/4/46/National_Kaohsiung_University_of_Science_and_Technology_logo.svg/800px-National_Kaohsiung_University_of_Science_and_Technology_logo.svg.png';" />
        </a>
        <div class="h-4 sm:h-6 md:h-8 border-l-[1.5px] border-slate-300/80 shrink-0 rounded-full"></div>
        <a href="/" class="flex items-center shrink-0 transition-transform duration-300 hover:scale-105">
          <img src="/images/sicp-logo.png" alt="iCPS Lab 智慧網宇實體系統實驗室" class="h-7 sm:h-11 md:h-12 lg:h-[3.25rem] w-auto object-contain" onerror="this.style.display='none';" />
        </a>
      </div>

      <div class="hidden md:flex space-x-8 text-sm font-bold text-slate-600 shrink-0 ml-4">
        <a href="/" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>首頁</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Home</span>
        </a>
        <a href="/about" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>關於 iCPS Lab</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">About</span>
        </a>
        <a href="/#news" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>最新消息</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">News</span>
        </a>
        <a href="/activities" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>活動花絮</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Events</span>
        </a>
        <a href="/#videos" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>影音專區</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Media</span>
        </a>
        <a href="/achievements" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>成果榮譽</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600 text-blue-800">Achievements</span>
        </a>
        <a href="/members" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>實驗室成員</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Members</span>
        </a>
        <a href="/faq" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>常見問題</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">FAQ</span>
        </a>
      </div>

      <button id="mobile-menu-btn" class="md:hidden p-2 text-slate-600 hover:text-blue-800 transition focus:outline-none" aria-label="打開選單">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 w-full bg-white border-b border-slate-200 shadow-lg flex flex-col z-20">
      <a href="/" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">首頁</a>
      <a href="/about" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">關於 iCPS Lab</a>
      <a href="/#news"class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">最新消息</a>
      <a href="/activities" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">活動花絮</a>
      <a href="/#videos" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">影音專區</a>
      <a href="/achievements" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">成果與榮譽</a>
      <a href="/members" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">實驗室成員</a>
      <a href="/faq" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">常見問題</a>
    </div>
  </nav>

  <header class="relative overflow-hidden border-b border-blue-900/20 bg-[#081426]">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_15%,rgba(59,130,246,.32),transparent_34%),radial-gradient(circle_at_78%_25%,rgba(14,165,233,.22),transparent_30%),linear-gradient(135deg,#0f172a_0%,#0b1d35_52%,#082f49_100%)]"></div>
    <div class="absolute inset-0 opacity-[0.08] bg-[linear-gradient(to_right,#fff_1px,transparent_1px),linear-gradient(to_bottom,#fff_1px,transparent_1px)] bg-[size:48px_48px]"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 py-16 lg:py-20">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-7 text-white">
          <a href="/" class="hero-rise delay-1 inline-flex items-center gap-2 mb-8 px-4 py-2 rounded-full bg-white/8 border border-white/10 text-blue-100 text-sm font-bold backdrop-blur-md hover:bg-white/12 transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            返回首頁
          </a>
          <div class="hero-rise delay-1 inline-flex items-center gap-3 mb-5"><span class="w-10 h-1 rounded-full bg-blue-400"></span><span class="text-blue-200 text-xs font-black tracking-[0.26em] uppercase">Achievements Directory</span></div>
          <h1 class="hero-rise delay-2 text-4xl md:text-6xl font-black tracking-tight leading-tight mb-5">成果與榮譽</h1>
          <p class="hero-rise delay-3 max-w-2xl text-blue-100/80 text-base md:text-lg leading-relaxed">彙整實驗室論文發表、競賽得獎、產學計畫與專利成果，透過分類與搜尋快速掌握研究累積與技術落地成果。</p>
        </div>
        <div class="lg:col-span-5 hero-rise delay-3">
          <div class="rounded-[2rem] bg-white/10 border border-white/15 backdrop-blur-xl p-5 shadow-2xl shadow-blue-950/30">
            <div class="grid grid-cols-2 gap-3">
              <div class="rounded-2xl bg-white/90 border border-white/60 p-5 shadow-sm"><div class="text-3xl font-black text-slate-900 tabular-nums">{totalRecords}</div><div class="mt-1 text-[11px] font-bold tracking-[0.16em] uppercase text-slate-500">Records</div></div>
              <div class="rounded-2xl bg-white/90 border border-white/60 p-5 shadow-sm"><div class="text-3xl font-black text-blue-700 tabular-nums">{publicationCount}</div><div class="mt-1 text-[11px] font-bold tracking-[0.16em] uppercase text-slate-500">Publications</div></div>
              <div class="rounded-2xl bg-white/90 border border-white/60 p-5 shadow-sm"><div class="text-3xl font-black text-amber-600 tabular-nums">{awardCount}</div><div class="mt-1 text-[11px] font-bold tracking-[0.16em] uppercase text-slate-500">Awards</div></div>
              <div class="rounded-2xl bg-white/90 border border-white/60 p-5 shadow-sm"><div class="text-3xl font-black text-slate-900 tabular-nums">{latestYear}</div><div class="mt-1 text-[11px] font-bold tracking-[0.16em] uppercase text-slate-500">Latest Year</div></div>
            </div>
          </div>
        </div>
      </div>
      <div class="hero-rise delay-3 mt-10 max-w-4xl relative group">
        <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none"><svg class="h-5 w-5 text-slate-400 group-focus-within:text-blue-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg></div>
        <input type="text" id="search-input" class="block w-full pl-14 pr-12 py-4 bg-white text-slate-900 placeholder-slate-400 border border-white/40 rounded-2xl focus:outline-none focus:ring-4 focus:ring-blue-400/30 focus:border-blue-300 transition-all duration-300 shadow-xl shadow-slate-950/20" placeholder="搜尋論文題目、作者、獲獎專案、年度或合作計畫...">
        <button id="clear-search" class="absolute inset-y-0 right-0 pr-5 flex items-center hidden text-slate-400 hover:text-slate-700 transition" aria-label="清除搜尋"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg></button>
      </div>
    </div>
  </header>


  <main class="relative z-20 bg-gradient-to-br from-slate-50 via-white to-blue-50/40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12 lg:py-16">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-10">
        <aside class="lg:col-span-3" id="sidebar" data-rv="left">
          <div class="lg:sticky lg:top-8 space-y-5">
            <div class="rounded-3xl bg-white/90 border border-slate-200 shadow-sm p-4">
              <div class="px-2 pb-3 mb-3 border-b border-slate-100"><div class="text-xs font-black tracking-[0.18em] text-blue-600 uppercase">Browse by Category</div><div class="text-sm text-slate-500 mt-1">依成果類型快速篩選</div></div>
              <div class="flex lg:flex-col overflow-x-auto lg:overflow-visible hide-scrollbar gap-2 pb-1 lg:pb-0" id="tabs-container">
                {achievements.map((group, index) => {
                  const totalItems = group.yearlyData.reduce((sum, yearBlock) => sum + yearBlock.items.length, 0);
                  return (
                    <>
                      {group.section && (<div class={`${index !== 0 ? 'lg:mt-5' : ''} px-1 flex-shrink-0 lg:w-full hidden lg:block`}><h2 class="text-[11px] font-black text-slate-400 tracking-widest uppercase border-b border-slate-100 pb-2">{group.section}</h2></div>)}
                      <button class={`tab-btn flex-shrink-0 lg:w-full text-left px-4 py-3 rounded-2xl text-sm font-bold transition-all duration-200 border ${index === 0 ? 'is-active bg-blue-600 text-white border-blue-600 shadow-lg shadow-blue-600/20' : 'bg-white text-slate-600 hover:bg-blue-50 hover:text-blue-800 border-slate-200'}`} data-target={`category-${index}`}>
                        <div class="flex items-center justify-between gap-4"><span class="whitespace-nowrap lg:whitespace-normal">{group.category}</span><span class="tab-count inline-flex items-center justify-center rounded-full min-w-7 h-7 px-2 text-xs bg-slate-100 text-slate-500">{totalItems}</span></div>
                      </button>
                    </>
                  );
                })}
              </div>
            </div>
            <div class="hidden lg:block rounded-3xl bg-slate-900 text-white p-5 overflow-hidden relative">
              <div class="absolute -right-10 -top-10 w-32 h-32 bg-blue-500/20 rounded-full blur-2xl"></div>
              <div class="relative z-10"><div class="text-xs font-black tracking-[0.18em] text-blue-300 uppercase mb-3">Summary</div><div class="grid grid-cols-2 gap-3 text-center"><div class="rounded-2xl bg-white/8 border border-white/10 p-3"><div class="text-xl font-black">{projectCount}</div><div class="text-[10px] text-slate-400 uppercase">Projects</div></div><div class="rounded-2xl bg-white/8 border border-white/10 p-3"><div class="text-xl font-black">{patentCount}</div><div class="text-[10px] text-slate-400 uppercase">Patents</div></div></div></div>
            </div>
          </div>
        </aside>
        <section class="lg:col-span-9" id="content-area" data-rv="up">
          <div id="no-results-msg" class="hidden text-center py-16 px-6 bg-white rounded-3xl border border-dashed border-slate-300 shadow-sm"><div class="mx-auto w-16 h-16 rounded-full bg-slate-100 flex items-center justify-center mb-4"><svg class="h-8 w-8 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg></div><h3 class="text-lg font-bold text-slate-800 mb-2">找不到相關紀錄</h3><p class="text-slate-500">請嘗試更換關鍵字，或改用年度、作者、專案名稱搜尋。</p></div>
          <div id="groups-container">
            {achievements.map((group, groupIndex) => (
              <div id={`category-${groupIndex}`} class={`category-group fade-in ${groupIndex === 0 ? 'is-active' : ''}`}>
                <div class="mb-8 rounded-[2rem] bg-white border border-slate-200 shadow-sm p-6 lg:p-8 overflow-hidden relative">
                  <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-blue-600 via-cyan-400 to-transparent"></div>
                  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-5">
                    <div><div class="inline-flex items-center gap-2 text-blue-600 text-xs font-black tracking-[0.18em] uppercase mb-3"><span class="w-8 h-1 bg-blue-600 rounded-full"></span>Achievement Category</div><h2 class="text-2xl lg:text-3xl font-black text-slate-900 tracking-tight">{group.category}</h2><p class="text-slate-500 text-sm lg:text-base mt-3 max-w-2xl leading-relaxed">{group.description}</p></div>
                    <div class="shrink-0 inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-50 text-blue-700 border border-blue-100 text-sm font-bold">{group.yearlyData.reduce((sum, yearBlock) => sum + yearBlock.items.length, 0)} 筆紀錄</div>
                  </div>
                </div>
                <div class="space-y-5">
                  {group.yearlyData.map((yearBlock, yearIndex) => (
                    <div class="year-block bg-white rounded-[1.5rem] border border-slate-200 overflow-hidden shadow-sm">
                      <button class="year-toggle-btn w-full flex items-center justify-between px-5 sm:px-6 py-4 bg-white hover:bg-slate-50 transition-colors group" data-target={`year-content-${groupIndex}-${yearIndex}`}>
                        <div class="flex items-center gap-3 min-w-0"><span class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-slate-900 text-white text-sm font-black tracking-wider font-mono shadow-sm group-hover:bg-blue-600 transition-colors shrink-0">{yearBlock.year}</span><div class="text-left min-w-0"><div class="text-slate-900 font-black">{yearBlock.year} 年度成果</div><div class="text-slate-400 text-xs font-bold tracking-widest uppercase mt-0.5">{yearBlock.items.length} records</div></div></div>
                        <svg class={`w-5 h-5 text-slate-400 transition-transform duration-300 ${yearIndex === 0 ? 'rotate-180' : ''}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                      </button>
                      <div id={`year-content-${groupIndex}-${yearIndex}`} class={`year-content px-5 sm:px-6 pb-5 space-y-4 border-t border-slate-100 ${yearIndex === 0 ? 'pt-5' : 'hidden pt-5'}`}>
                        {yearBlock.items.map((item) => {
                          const isPublication = group.type === "publication";
                          const isAward = group.type === "award";
                          const isProject = group.type === "project";
                          const isPatent = group.type === "patent";
                          const rawContent = item.content || item.project || "";
                          const cleanProjectName = rawContent.replace(/指導學生參加\s*/g, '').replace(/\([\d,]+元\)/g, '').trim();
                          const titleText = isPublication ? (item.title || '') : cleanProjectName;
                          const metaText = isPublication ? `${item.authors || ''} ${item.venue || ''}` : `${item.amount || ''}`;
                          const searchStr = `${titleText} ${metaText} ${yearBlock.year} ${group.category}`.toLowerCase();
                          return (
                            <div class="achievement-item" data-search={searchStr}>
                              {isPublication ? (
                                <article class="achievement-card bg-white border border-slate-200 rounded-2xl p-5 lg:p-6">
                                  <div class="flex flex-col sm:flex-row gap-5 justify-between items-start">
                                    <div class="min-w-0 flex-1"><div class="inline-flex items-center gap-2 mb-3 text-[11px] font-black tracking-widest uppercase text-blue-700 bg-blue-50 border border-blue-100 px-2.5 py-1 rounded-full">Publication</div><h3 class="text-lg lg:text-xl font-black text-slate-900 leading-snug mb-3 hover:text-blue-700 transition-colors">{item.title}</h3><p class="text-slate-600 text-sm leading-relaxed mb-2"><span class="font-bold text-slate-500">Authors：</span>{item.authors}</p><p class="text-blue-700/80 text-sm font-medium italic"><span class="font-bold text-slate-500 not-italic">Venue：</span>{item.venue}</p></div>
                                    {item.link && (<a href={item.link} target="_blank" rel="noopener noreferrer" class="shrink-0 inline-flex items-center gap-2 px-4 py-2.5 bg-slate-900 text-white rounded-full text-sm font-bold hover:bg-blue-600 transition-all shadow-sm">View<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg></a>)}
                                  </div>
                                </article>
                              ) : (
                                <article class="achievement-card bg-white border border-slate-200 rounded-2xl p-5 lg:p-6">
                                  <div class="flex items-start gap-4">
                                    <div class={`flex items-center justify-center shrink-0 w-12 h-12 rounded-2xl border ${isAward ? 'bg-amber-50 border-amber-100' : isPatent ? 'bg-violet-50 border-violet-100' : 'bg-emerald-50 border-emerald-100'}`}><span class="text-2xl">{isAward ? "🏆" : isPatent ? "📜" : "💡"}</span></div>
                                    <div class="flex-1 min-w-0"><div class="flex flex-wrap items-center gap-2 mb-2"><span class={`text-[11px] font-black tracking-widest uppercase px-2.5 py-1 rounded-full border ${isAward ? 'text-amber-700 bg-amber-50 border-amber-100' : isPatent ? 'text-violet-700 bg-violet-50 border-violet-100' : 'text-emerald-700 bg-emerald-50 border-emerald-100'}`}>{isAward ? "Award" : isPatent ? "Patent" : "Project"}</span><span class="text-[11px] font-bold text-slate-400 bg-slate-100 px-2 py-1 rounded-full">{yearBlock.year}</span></div><h3 class="text-base lg:text-lg text-slate-900 font-black leading-relaxed">{cleanProjectName}</h3>{item.amount && (<div class="mt-3 inline-flex items-center px-3 py-1 rounded-full text-xs font-black bg-emerald-50 text-emerald-700 border border-emerald-100">核定金額：{item.amount}</div>)}</div>
                                  </div>
                                </article>
                              )}
                            </div>
                          );
                        })}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>
      </div>
    </div>
  </main>

<footer class="bg-[#0f172a] py-16 mt-12 border-t border-slate-800 relative z-20">
