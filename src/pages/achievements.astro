---
import "../styles/global.css";
import achievements from "../data/achievements.json";
---

<html lang="zh-TW" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/images/lab-logo.png" />
  <title>成果與榮譽 | iCPS Lab 智慧網宇實體系統實驗室</title>
  <style>
    .hide-scrollbar::-webkit-scrollbar {
      display: none;
    }
    .hide-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    .fade-in {
      animation: fadeIn 0.3s ease-in-out forwards;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(5px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .rotate-180 {
      transform: rotate(180deg);
    }
  </style>
</head>

<body class="bg-[#f8fafc] text-slate-800 font-sans antialiased selection:bg-blue-200 selection:text-blue-900 relative">

  <!-- 🔷 頂部導覽列 (Navbar) -->
  <nav class="w-full bg-white border-b border-slate-200 shadow-sm relative z-30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center justify-between py-3 md:py-4">
      <div class="flex items-center gap-3 sm:gap-6 lg:gap-8 min-w-0">
        <a href="https://www.nkust.edu.tw/" target="_blank" class="flex items-center shrink-0 transition-transform duration-300 hover:scale-105">
          <img src="/images/nkust-logo.png" alt="NKUST 國立高雄科技大學" class="h-6 sm:h-9 md:h-10 lg:h-11 w-auto object-contain" onerror="this.src='https://upload.wikimedia.org/wikipedia/zh/thumb/4/46/National_Kaohsiung_University_of_Science_and_Technology_logo.svg/800px-National_Kaohsiung_University_of_Science_and_Technology_logo.svg.png';" />
        </a>
        <div class="h-4 sm:h-6 md:h-8 border-l-[1.5px] border-slate-300/80 shrink-0 rounded-full"></div>
        <a href="/" class="flex items-center shrink-0 transition-transform duration-300 hover:scale-105">
          <img src="/images/sicp-logo.png" alt="iCPS Lab 智慧網宇實體系統實驗室" class="h-7 sm:h-11 md:h-12 lg:h-[3.25rem] w-auto object-contain" onerror="this.style.display='none';" />
        </a>
      </div>

      <div class="hidden md:flex space-x-8 text-sm font-bold text-slate-600 shrink-0 ml-4">
        <a href="/" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>首頁</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Home</span>
        </a>
        <a href="/about" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>關於 iCPS Lab</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">About</span>
        </a>
        <a href="/#news" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>最新消息</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">News</span>
        </a>
        <a href="/activities" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>活動花絮</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Events</span>
        </a>
        <a href="/#videos" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>影音專區</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Media</span>
        </a>
        <a href="/achievements" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>成果榮譽</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600 text-blue-800">Achievements</span>
        </a>
        <a href="/members" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>實驗室成員</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">Members</span>
        </a>
        <a href="/faq" class="group flex flex-col items-center hover:text-blue-800 transition border-b-2 border-transparent hover:border-blue-800 pb-1">
          <span>常見問題</span>
          <span class="text-xs font-normal text-slate-400 group-hover:text-blue-600">FAQ</span>
        </a>
      </div>

      <button id="mobile-menu-btn" class="md:hidden p-2 text-slate-600 hover:text-blue-800 transition focus:outline-none" aria-label="打開選單">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 w-full bg-white border-b border-slate-200 shadow-lg flex flex-col z-20">
      <a href="/" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">首頁</a>
      <a href="/about" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">關於 iCPS Lab</a>
      <a href="/#news"class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">最新消息</a>
      <a href="/activities" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">活動花絮</a>
      <a href="/#videos" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">影音專區</a>
      <a href="/achievements" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">成果與榮譽</a>
      <a href="/members" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">實驗室成員</a>
      <a href="/faq" class="block px-6 py-4 text-slate-600 font-bold hover:bg-slate-50 hover:text-blue-800">常見問題</a>
    </div>
  </nav>

  <!-- 🔷 頁面標題區 -->
  <header class="bg-[#0f172a] py-12 md:py-16 text-center border-b-4 border-blue-700 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] pointer-events-none"></div>
    <div class="relative z-10 px-4">
      <h1 class="text-3xl md:text-4xl font-extrabold text-white tracking-widest mb-3">成果與榮譽</h1>
      <p class="text-slate-300 text-sm font-light tracking-wider uppercase mb-8">Achievements & Awards</p>
      
      <div class="max-w-2xl mx-auto relative group">
        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
          <svg class="h-5 w-5 text-slate-400 group-focus-within:text-blue-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <input 
          type="text" 
          id="search-input" 
          class="block w-full pl-12 pr-10 py-4 bg-white/10 backdrop-blur-md border border-white/20 rounded-xl text-white placeholder-slate-300 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white focus:text-slate-800 focus:placeholder-slate-400 transition-all duration-300 shadow-lg" 
          placeholder="搜尋論文題目、獲獎專案或作者姓名... (例如：Deep Learning、2024)"
        >
        <button id="clear-search" class="absolute inset-y-0 right-0 pr-4 flex items-center hidden text-slate-400 hover:text-slate-600">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
    </div>
  </header>

  <!-- 🔷 網站主體區域 -->
  <main class="max-w-6xl mx-auto px-4 sm:px-6 py-12 relative z-20 min-h-[50vh]">

    <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">
      
      <!-- 左側/上方 分類導覽列 (Tabs) -->
      <aside class="w-full lg:w-1/4 shrink-0" id="sidebar">
        <div class="lg:sticky lg:top-8">
          
          <div class="flex lg:flex-col overflow-x-auto lg:overflow-visible hide-scrollbar gap-2 pb-2 lg:pb-0" id="tabs-container">
            {achievements.map((group, index) => {
              // 計算該分類的總項目數量
              const totalItems = group.yearlyData.reduce((sum, yearBlock) => sum + yearBlock.items.length, 0);
              
              return (
                <>
                  {group.section && (
                    <div class={`${index !== 0 ? 'mt-6' : ''} mb-2 px-1 flex-shrink-0 lg:w-full`}>
                      <h2 class="text-xs font-black text-slate-400 tracking-widest uppercase border-b border-slate-200 pb-2">
                        {group.section}
                      </h2>
                    </div>
                  )}
                  <button 
                    class={`tab-btn flex-shrink-0 lg:w-full text-left px-5 py-3 rounded-lg text-[15px] font-bold transition-all duration-200 border border-transparent 
                    ${index === 0 
                      ? 'bg-blue-600 text-white shadow-md' 
                      : 'bg-white text-slate-600 hover:bg-blue-50 hover:text-blue-800 border-slate-200'}`}
                    data-target={`category-${index}`}
                  >
                    <div class="flex items-center justify-between">
                      <span>{group.category}</span>
                      <span class="hidden lg:inline-flex items-center justify-center bg-black/10 rounded-full w-6 h-6 text-xs ml-2 opacity-80 mix-blend-multiply text-current">
                        {totalItems}
                      </span>
                    </div>
                  </button>
                </>
              );
            })}
          </div>
        </div>
      </aside>

      <!-- 右側/下方 內容區 -->
      <section class="flex-1 w-full" id="content-area">
        
        <div id="no-results-msg" class="hidden text-center py-16 px-6 bg-white rounded-xl border border-dashed border-slate-300">
          <svg class="mx-auto h-12 w-12 text-slate-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <h3 class="text-lg font-bold text-slate-800 mb-2">找不到相關紀錄</h3>
          <p class="text-slate-500">很抱歉，沒有找到符合您搜尋字詞的成果或獎項。請嘗試更換關鍵字。</p>
        </div>

        <div id="groups-container">
          {achievements.map((group, groupIndex) => (
            <div 
              id={`category-${groupIndex}`} 
              class={`category-group fade-in ${groupIndex === 0 ? 'block' : 'hidden'}`}
            >
              <div class="mb-10">
                <h2 class="text-2xl font-extrabold text-slate-800 mb-3 flex items-center gap-3">
                  <span class="w-2 h-6 bg-blue-600 rounded-full"></span>
                  {group.category}
                </h2>
                <p class="text-slate-500 text-[15px] pl-5">{group.description}</p>
              </div>
              
              <div class="space-y-6">
                {group.yearlyData.map((yearBlock, yearIndex) => (
                  <div class="year-block bg-white rounded-xl border border-slate-100 overflow-hidden shadow-sm">
                    <!-- 年份標題 (改為可點擊的摺疊按鈕) -->
                    <button 
                      class="year-toggle-btn w-full flex items-center justify-between px-5 py-4 bg-slate-50/50 hover:bg-slate-100 transition-colors group"
                      data-target={`year-content-${groupIndex}-${yearIndex}`}
                    >
                      <div class="flex items-center gap-3">
                        <span class="bg-slate-800 text-white px-3 py-1 rounded-md text-sm font-bold tracking-wider font-mono shadow-sm group-hover:bg-blue-600 transition-colors">
                          {yearBlock.year}
                        </span>
                        <span class="text-slate-400 text-sm font-medium group-hover:text-slate-600 transition-colors">({yearBlock.items.length} 篇)</span>
                      </div>
                      <svg 
                        class={`w-5 h-5 text-slate-400 transition-transform duration-300 ${yearIndex === 0 ? 'rotate-180' : ''}`} 
                        fill="none" stroke="currentColor" viewBox="0 0 24 24"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                      </svg>
                    </button>

                    <!-- 該年份的項目列表 -->
                    <div 
                      id={`year-content-${groupIndex}-${yearIndex}`} 
                      class={`year-content p-5 space-y-4 border-t border-slate-100 ${yearIndex === 0 ? '' : 'hidden'}`}
                    >
                    {yearBlock.items.map((item) => {
                        // 判斷目前這個分類的類型
                        const isPublication = group.type === "publication";
                        const isAward = group.type === "award";
                        const isProject = group.type === "project";

                        // 移除 "指導學生參加" 以及末尾的括號金額 (例如：(330,000元))
                        const cleanProjectName = item.project
                          ?.replace(/指導學生參加\s*/g, '')
                          ?.replace(/\([\d,]+元\)/g, '')
                          ?.trim() || "";

                        // 搜尋用的文字串 (使用清理過的內容確保精準度)
                        const searchStr = isPublication 
                          ? `${item.title} ${item.authors} ${item.venue} ${yearBlock.year}`.toLowerCase()
                          : `${cleanProjectName} ${yearBlock.year}`.toLowerCase();

                        return (
                          <div class="achievement-item" data-search={searchStr}>
                            
                            {isPublication ? (
                              /* ----------- 1. 論文卡片樣式 ----------- */
                              <div class="flex flex-col sm:flex-row gap-4 justify-between items-start bg-white border border-slate-200 rounded-lg p-5 hover:border-blue-400 hover:shadow-md transition duration-300">
                                <div class="flex-1">
                                  <h3 class="text-lg font-bold text-slate-800 leading-snug mb-2 hover:text-blue-700 transition">{item.title}</h3>
                                  <p class="text-slate-600 text-[15px] mb-1"><span class="font-semibold text-slate-500">Authors:</span> {item.authors}</p>
                                  <p class="text-blue-700/80 text-sm font-medium italic"><span class="font-semibold text-slate-500 not-italic">Venue:</span> {item.venue}</p>
                                </div>
                                <a href={item.link} target="_blank" class="shrink-0 p-2.5 bg-blue-50 rounded-full text-blue-600 hover:bg-blue-600 hover:text-white transition-all group self-end sm:self-start">
                                  <svg class="w-5 h-5 group-hover:-translate-y-0.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                                </a>
                              </div>

                            ) : (
                              /* ----------- 2. 獲獎紀錄與研究計畫樣式 (最簡資料版) ----------- */
                              <div class="flex items-start gap-5 p-5 rounded-xl bg-white border border-slate-200 hover:border-blue-400 hover:shadow-lg transition duration-300 group">
                                <div class="flex flex-col items-center justify-center shrink-0 w-12 h-12 bg-slate-50 rounded-lg border border-slate-100 group-hover:bg-blue-50 group-hover:border-blue-100 transition-colors">
                                  <span class="text-2xl">{isAward ? "🏆" : "💡"}</span>
                                </div>
                                <div class="flex-1 min-w-0">
                                  <div class="text-slate-700 font-bold leading-relaxed text-lg">
                                    {cleanProjectName}
                                  </div>
                                  {item.amount && (
                                    <div class="mt-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-black bg-emerald-50 text-emerald-700 border border-emerald-100">
                                      核定金額：{item.amount}
                                    </div>
                                  )}
                                </div>
                              </div>
                            )}

                          </div>
                        );
                      })}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>

      </section>
    </div>

  </main>

  <!-- 🔷 頁尾 (Footer) -->
  <footer class="bg-[#0f172a] py-16 mt-12 border-t border-slate-800 relative z-20">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-start gap-10">
      <div class="md:w-1/2">
        <img src="/images/footer-logo.png" alt="iCPS Lab" class="h-14 md:h-20 w-auto mb-3 object-contain" onerror="this.style.display='none';" />
        <p class="text-sm text-blue-400 font-medium mb-4">智慧網宇實體系統實驗室</p>
        <p class="text-sm text-slate-400 leading-relaxed max-w-md">
          Intelligent Cyber-Physical Systems Laboratory <br/>
          國立高雄科技大學 (NKUST)
        </p>
      </div>
      <div class="md:w-1/2 flex flex-col md:items-end text-sm space-y-3">
        <h3 class="text-white font-semibold mb-2 tracking-wide uppercase text-xs">Contact Us</h3>
        <p class="flex items-center gap-2 text-slate-300"><span class="text-slate-500">📍</span> 國立高雄科技大學 (建工校區)</p>
        <p class="flex items-center gap-2 text-slate-300"><span class="text-slate-500">📞</span> 07-3814526 分機 15672</p>
        <p class="flex items-center gap-2 text-slate-300"><span class="text-slate-500">✉️</span> <a href="mailto:allenchang@nkust.edu.tw" class="hover:text-blue-400 transition">allenchang@nkust.edu.tw</a></p>
      </div>
    </div>
    
    <div class="max-w-7xl mx-auto px-6 mt-12 pt-6 border-t border-slate-800 flex flex-col lg:flex-row justify-between items-center gap-6 lg:gap-4">
      <div class="flex flex-col sm:flex-row items-center gap-2 sm:gap-4 text-center sm:text-left">
        <p class="text-xs text-slate-500 leading-normal">
          &copy; 2026 <span class="italic font-['Times_New_Roman',_Times,_serif] text-[1.15em]">i</span>CPS Lab, National Kaohsiung University of Science and Technology.
        </p>
        <p class="text-xs text-slate-500 hidden sm:block">|</p>
        <p class="text-xs text-slate-500">All rights reserved.</p>
      </div>

      <div class="flex items-center gap-2 bg-slate-800/50 px-3 py-1.5 rounded-md border border-slate-700 shadow-sm transition hover:border-slate-600">
        <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
        <span class="text-xs text-slate-400 font-medium tracking-wide">累積造訪人數</span>
        <span class="text-xs text-slate-600 mx-1">|</span>
        <span class="text-sm font-mono font-bold text-blue-400 tracking-wider" id="visitor-count">載入中...</span>
      </div>
    </div>
  </footer>

  <!-- 🔷 控制邏輯的 JavaScript -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      
      // 1. 手機版選單控制
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const hamburgerIcon = document.getElementById('hamburger-icon');

      if (mobileMenuBtn && mobileMenu && hamburgerIcon) {
        mobileMenuBtn.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
          hamburgerIcon.setAttribute('d', mobileMenu.classList.contains('hidden') ? 'M4 6h16M4 12h16M4 18h16' : 'M6 18L18 6M6 6l12 12');
        });
      }

      // 2. 側邊欄 Tab 切換功能
      const tabBtns = document.querySelectorAll('.tab-btn');
      const categoryGroups = document.querySelectorAll('.category-group');
      let currentActiveTabTarget = 'category-0'; 

      const switchTab = (targetId) => {
        currentActiveTabTarget = targetId;
        
        // 更新按鈕樣式
        tabBtns.forEach(btn => {
          if (btn.getAttribute('data-target') === targetId) {
            btn.className = "tab-btn flex-shrink-0 lg:w-full text-left px-5 py-3 rounded-lg text-[15px] font-bold transition-all duration-200 border border-transparent bg-blue-600 text-white shadow-md";
          } else {
            btn.className = "tab-btn flex-shrink-0 lg:w-full text-left px-5 py-3 rounded-lg text-[15px] font-bold transition-all duration-200 border border-transparent bg-white text-slate-600 hover:bg-blue-50 hover:text-blue-800 border-slate-200";
          }
        });

        // 更新內容區顯示
        categoryGroups.forEach(group => {
          if (group.id === targetId) {
            group.classList.remove('hidden');
            group.classList.remove('fade-in');
            void group.offsetWidth; // 觸發重繪以重啟動畫
            group.classList.add('fade-in');
          } else {
            group.classList.add('hidden');
          }
        });
      };

      tabBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          switchTab(btn.getAttribute('data-target'));
          // 點擊分類時若有搜尋文字，則清除並重置
          if(searchInput.value.trim() !== '') {
             clearSearchBtn.click();
          }
        });
      });

      // 3. 搜尋過濾功能
      const searchInput = document.getElementById('search-input');
      const clearSearchBtn = document.getElementById('clear-search');
      const noResultsMsg = document.getElementById('no-results-msg');
      const sidebar = document.getElementById('sidebar');

      const performSearch = (searchTerm) => {
        searchTerm = searchTerm.toLowerCase().trim();
        let hasAnyResult = false;

        if (searchTerm === '') {
          clearSearchBtn.classList.add('hidden');
          sidebar.classList.remove('opacity-50', 'pointer-events-none'); 
          noResultsMsg.classList.add('hidden');
          
          document.querySelectorAll('.year-block').forEach(block => block.classList.remove('hidden'));
          document.querySelectorAll('.achievement-item').forEach(item => item.classList.remove('hidden'));
          switchTab(currentActiveTabTarget); 
          return;
        }

        clearSearchBtn.classList.remove('hidden');
        sidebar.classList.add('opacity-50', 'pointer-events-none'); 

        categoryGroups.forEach(group => {
          let hasResultInGroup = false;
          const yearBlocks = group.querySelectorAll('.year-block');
          
          yearBlocks.forEach(block => {
            let hasResultInYear = false;
            const items = block.querySelectorAll('.achievement-item');
            
            items.forEach(item => {
              const searchData = item.getAttribute('data-search');
              
              if (searchData.includes(searchTerm)) {
                item.classList.remove('hidden');
                hasResultInYear = true;
                hasResultInGroup = true;
                hasAnyResult = true;
              } else {
                item.classList.add('hidden');
              }
            });

            // 若該年份區塊內有符合結果，就顯示該年份標題區塊，否則隱藏整個年份區塊
            if (hasResultInYear) {
              block.classList.remove('hidden');
              // 搜尋模式下強制展開符合結果的年份
              const content = block.querySelector('.year-content');
              const icon = block.querySelector('svg');
              content.classList.remove('hidden');
              icon.classList.add('rotate-180');
            } else {
              block.classList.add('hidden');
            }
          });

          // 如果搜尋狀態下該群組有結果才顯示
          if (hasResultInGroup) {
            group.classList.remove('hidden');
            group.classList.add('fade-in');
          } else {
            group.classList.add('hidden');
          }
        });

        if (!hasAnyResult) {
          noResultsMsg.classList.remove('hidden');
        } else {
          noResultsMsg.classList.add('hidden');
        }
      };

      searchInput.addEventListener('input', (e) => {
        performSearch(e.target.value);
      });

      clearSearchBtn.addEventListener('click', () => {
        searchInput.value = '';
        searchInput.focus();
        performSearch('');
      });

      // 4. 智慧訪客計數器邏輯 (24小時內防洗次數 + 防破圖備用機制)
      const initCounter = async () => {
        const counterEl = document.getElementById('visitor-count');
        if (!counterEl) return;

        const namespace = 'icpslab_site';
        const key = 'visits';
        const localCountKey = 'icps_saved_count';
        const lastVisitTimeKey = 'icps_last_visit_time';
        const TWENTY_FOUR_HOURS = 24 * 60 * 60 * 1000; // 24小時換算成毫秒

        // 從 localStorage 讀取最後一次成功的數字當作備用
        let currentCount = localStorage.getItem(localCountKey) || '------';
        
        // 讀取最後一次增加次數的時間，並取得當下時間
        const lastVisitTime = localStorage.getItem(lastVisitTimeKey);
        const now = Date.now();

        // 判斷是否在 24 小時之內有造訪過
        const hasVisitedWithin24Hours = lastVisitTime && (now - parseInt(lastVisitTime, 10) < TWENTY_FOUR_HOURS);
        
        try {
          const url = `https://api.counterapi.dev/v1/${namespace}/${key}`;
          
          if (!hasVisitedWithin24Hours) {
            // 超過 24 小時未造訪，或是首次造訪 -> 呼叫 /up 增加次數
            const response = await fetch(url + '/up');
            if (!response.ok) throw new Error('API 回應錯誤');
            
            const data = await response.json();
            currentCount = String(data.count).padStart(6, '0');
            
            // 紀錄當下時間，接下來 24 小時內都不會再增加
            localStorage.setItem(lastVisitTimeKey, now.toString());
            localStorage.setItem(localCountKey, currentCount);
            counterEl.textContent = currentCount;
            
          } else {
            // 24 小時內已造訪過 -> 嘗試獲取最新數字 (不增加)
            try {
              const response = await fetch(url);
              if (response.ok) {
                const data = await response.json();
                currentCount = String(data.count).padStart(6, '0');
                localStorage.setItem(localCountKey, currentCount);
              }
            } catch (e) {
              console.warn('無法從伺服器獲取最新數字，已切換為本地暫存值');
            }
            counterEl.textContent = currentCount;
          }
          
        } catch (error) {
          console.error('計數器載入異常:', error);
          counterEl.textContent = currentCount;
        }
      };

      initCounter();

      // 5. 年份摺疊切換邏輯
      const yearToggleBtns = document.querySelectorAll('.year-toggle-btn');
      yearToggleBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const targetId = btn.getAttribute('data-target');
          const content = document.getElementById(targetId);
          const icon = btn.querySelector('svg');
          
          if (content.classList.contains('hidden')) {
            content.classList.remove('hidden');
            icon.classList.add('rotate-180');
          } else {
            content.classList.add('hidden');
            icon.classList.remove('rotate-180');
          }
        });
      });

    });
  </script>

</body>
</html>