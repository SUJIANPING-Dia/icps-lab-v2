---

<section id="news" class="scroll-mt-12">
  <div class="border-b-2 border-slate-800 pb-3 mb-8 flex justify-between items-end">
    <h2 class="text-3xl font-bold text-slate-900 flex items-center gap-3">
      <div class="w-2 h-8 bg-blue-700"></div>
      最新消息
      <span class="text-sm font-normal text-slate-500 uppercase tracking-wider ml-2 hidden sm:inline">News & Announcements</span>
    </h2>
  </div>

  <div class="bg-white border border-slate-200 rounded-sm shadow-sm">
    <ul id="news-list" class="divide-y divide-slate-100">
      {newsData.map((item) => (
        <li class="group news-item">
          <button class="news-toggle-btn w-full text-left transition-colors hover:bg-slate-50 flex flex-col md:flex-row md:items-center px-6 py-5 gap-4 justify-between focus:outline-none">
            <div class="flex flex-col md:flex-row md:items-center gap-4">
              <div class="flex items-center gap-4 md:w-56 shrink-0">
                <span class="text-slate-500 font-mono text-sm tracking-tight">{item.date}</span>
                <span class={`px-2.5 py-1 text-xs font-medium rounded-sm border ${item.tagTheme}`}>{item.tag}</span>
              </div>
              <span class="text-slate-800 font-medium group-hover:text-blue-700 transition">{item.title}</span>
            </div>
            <svg class="w-5 h-5 text-slate-400 toggle-icon transition-transform duration-300 shrink-0 hidden md:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          
          <div style="grid-template-rows: 0fr;" data-expanded="false" class="grid transition-[grid-template-rows] duration-300 ease-in-out">
            <div class="overflow-hidden">
              <div class="px-6 pb-6 md:pl-[16.5rem] text-slate-700 text-sm leading-relaxed space-y-5">
                {item.img && (
                  <div class="w-full max-w-3xl aspect-[1477/1108] bg-slate-100 rounded border border-slate-200 overflow-hidden flex items-center justify-center relative mt-2">
                    <img src={item.img} alt={item.imgAlt} class="w-full h-full object-cover absolute inset-0" onerror="this.style.display='none';" />
                    <span class="text-slate-400 font-medium">[ {item.imgAlt} ]</span>
                  </div>
                )}
                <div set:html={item.content}></div>
              </div>
            </div>
          </div>
        </li>
      ))}
    </ul>
  </div>

  <div id="pagination-controls" class="flex justify-center items-center mt-8 gap-2"></div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const toggleButtons = document.querySelectorAll('.news-toggle-btn');
    toggleButtons.forEach(button => {
      button.addEventListener('click', function() {
        const content = this.nextElementSibling;
        const icon = this.querySelector('.toggle-icon');
        const isExpanded = content.getAttribute('data-expanded') === 'true';

        // 🟢 新增：如果要展開當前項目，先收起所有其他已展開的項目
        if (!isExpanded) {
          const allExpanded = document.querySelectorAll('#news-list [data-expanded="true"]');
          allExpanded.forEach(expandedContent => {
            expandedContent.style.gridTemplateRows = '0fr';
            expandedContent.setAttribute('data-expanded', 'false');
            const expandedIcon = expandedContent.previousElementSibling.querySelector('.toggle-icon');
            if (expandedIcon) expandedIcon.style.transform = 'rotate(0deg)';
          });
        }

        // 切換當前項目的狀態
        if (!isExpanded) {
          content.style.gridTemplateRows = '1fr';
          content.setAttribute('data-expanded', 'true');
          if (icon) icon.style.transform = 'rotate(180deg)';
        } else {
          content.style.gridTemplateRows = '0fr';
          content.setAttribute('data-expanded', 'false');
          if (icon) icon.style.transform = 'rotate(0deg)';
        }
      });
    });

    const itemsPerPage = 5;
    let currentPage = 1;
    const newsItems = Array.from(document.querySelectorAll('.news-item'));
    const paginationContainer = document.getElementById('pagination-controls');

    function renderPagination() {
      const totalPages = Math.ceil(newsItems.length / itemsPerPage);
      if (totalPages <= 1) {
        paginationContainer.innerHTML = '';
        return;
      }

      let html = '';
      const prevDisabled = currentPage === 1 ? 'opacity-30 cursor-not-allowed' : 'hover:bg-slate-100 hover:text-slate-800';
      html += `<button onclick="window.changePage(${currentPage - 1})" class="px-3 py-1.5 text-sm font-medium rounded border border-slate-300 text-slate-600 transition ${prevDisabled}" ${currentPage === 1 ? 'disabled' : ''}>上一頁</button>`;

      for (let i = 1; i <= totalPages; i++) {
        const activeClass = i === currentPage ? 'bg-blue-700 text-white border-blue-700 shadow-sm' : 'bg-white text-slate-600 border-slate-300 hover:bg-slate-50';
        html += `<button onclick="window.changePage(${i})" class="w-8 h-8 flex items-center justify-center text-sm font-bold rounded border transition ${activeClass}">${i}</button>`;
      }

      const nextDisabled = currentPage === totalPages ? 'opacity-30 cursor-not-allowed' : 'hover:bg-slate-100 hover:text-slate-800';
      html += `<button onclick="window.changePage(${currentPage + 1})" class="px-3 py-1.5 text-sm font-medium rounded border border-slate-300 text-slate-600 transition ${nextDisabled}" ${currentPage === totalPages ? 'disabled' : ''}>下一頁</button>`;

      paginationContainer.innerHTML = html;
    }

    window.changePage = function(page, scrollToNews = true) {
      const totalPages = Math.ceil(newsItems.length / itemsPerPage);
      if (page < 1 || page > totalPages) return;
      
      currentPage = page;
      const startIndex = (currentPage - 1) * itemsPerPage;
      const endIndex = startIndex + itemsPerPage;

      newsItems.forEach((item, index) => {
        const content = item.querySelector('[data-expanded]');
        const icon = item.querySelector('.toggle-icon');
        
        // 換頁時自動收合所有展開的項目
        if(content && content.getAttribute('data-expanded') === 'true') {
          content.style.gridTemplateRows = '0fr';
          content.setAttribute('data-expanded', 'false');
          if (icon) icon.style.transform = 'rotate(0deg)';
        }

        if (index >= startIndex && index < endIndex) {
          item.style.display = 'block';
        } else {
          item.style.display = 'none';
        }
      });

      renderPagination();

      if (scrollToNews) {
        const newsSection = document.getElementById('news');
        const elementPosition = newsSection.getBoundingClientRect().top;
        const offsetPosition = elementPosition + window.pageYOffset;
        window.scrollTo({ top: offsetPosition, behavior: 'smooth' });
      }
    };

    window.changePage(1, false);
  });
</script>