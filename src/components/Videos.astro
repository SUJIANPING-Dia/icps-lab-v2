---
// 這裡可以隨時新增或修改您的 YouTube 影片資料
// 因為不需要顯示文字，所以只要保留 youtubeId 即可 (title 是給無障礙閱讀器用的)
const videos = [
  {
    title: "實驗室影片 1",
    youtubeId: "x6QEfvkknOM" 
  },
  {
    title: "實驗室影片 2",
    youtubeId: "p8HWT9Qop3M" 
  },
  {
    title: "實驗室影片 3",
    youtubeId: "1LYw3fPlm5s" // 補上第 3 個範例影片
  }
];
---

<section id="videos" class="scroll-mt-24">
  <!-- 標題區塊 -->
  <div class="flex items-center gap-4 mb-10">
    <h2 class="text-3xl font-bold text-slate-800 tracking-tight">影音專區</h2>
    <div class="h-px flex-1 bg-slate-200"></div>
    <span class="text-sm font-semibold text-blue-600 tracking-widest uppercase">Featured Videos</span>
  </div>

  <!-- 影片網格區塊：設定 lg:grid-cols-3 讓大螢幕一排顯示 3 個 -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {videos.map((video) => (
      <!-- 單純的影片外框，保留圓角與微微的陰影效果 -->
      <div class="rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300 bg-slate-100">
        
        <!-- 16:9 完美比例的 YouTube 嵌入框 -->
        <div class="aspect-video relative">
          <iframe
            class="absolute inset-0 w-full h-full"
            src={`https://www.youtube.com/embed/${video.youtubeId}`}
            title={video.title}
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        </div>
        
      </div>
    ))}
  </div>
</section>